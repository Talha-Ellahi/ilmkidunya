$(document).ready(function () {
  $('.review-slide')
    .on('init', function (event, slick) {
      // Show the slider once initialized
      $(this).css({
        display: 'block',
        visibility: 'visible'
      });
    })
    .slick({
      infinite: true,
      autoplay: true,
      autoplaySpeed: 1000,
      slidesToShow: 1,
      slidesToScroll: 1,
      dots: false,
    });
});



