<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log('=== DICTIONARY PAGE LOADED ===');

        // Configuration
        const currentLanguage = '@Model.lang1?.Code';
        const translatedLanguage = '@Model.lang2?.Code';
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        let currentPage = 1;
        const itemsPerPage = 10;
        let isLoading = false;

        // Header search variables
        let selectedLanguageHeader = '@Model.lang2.Name';

        console.log('Current Language:', currentLanguage);
        console.log('Translated Language:', translatedLanguage);

        // Check if languages are valid
        if (!currentLanguage || !translatedLanguage) {
            console.error('❌ Language codes are not available');
            return;
        }

        const languagesAreSame = currentLanguage === translatedLanguage;
        console.log('Languages are same:', languagesAreSame);

        // Initialize header search functionality
        initializeHeaderCustomSelect();

        // If languages are the same, hide the meaning column
        if (languagesAreSame) {
            console.log('🔄 Source and target languages are the same, hiding meaning column');
            hideMeaningColumn();
        } else {
            console.log('🔄 Starting initial translation for first page');
            translateWords();
        }

        // Process definitions for all words
        processDefinitions();

        // Load More functionality
        if (loadMoreBtn) {
            loadMoreBtn.addEventListener('click', function() {
                console.log('📥 Load More button clicked, current page:', currentPage);
                if (isLoading) return;
                loadMoreWords();
            });
        }

        // ========== LOAD MORE FUNCTIONALITY ==========
        function loadMoreWords() {
            console.log('🚀 Starting loadMoreWords, page:', currentPage + 1);
            isLoading = true;
            loadMoreBtn.textContent = 'Loading...';
            loadMoreBtn.style.opacity = '0.7';

            currentPage++;

            const lang1 = '@Model.lang1?.Name.ToLower()';
            const lang2 = '@Model.lang2?.Name.ToLower()';

            fetch(`/dictionary/${lang1}-to-${lang2}-dictionary/loadmore?page=${currentPage}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok: ' + response.status);
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success && data.words && data.words.length > 0) {
                        console.log('✅ Load More successful, words count:', data.words.length);
                        appendWordsToTable(data.words, data.existingMeanings || {}, lang2);

                        // Process definitions for new words
                        processNewWordsDefinitions(data.words);

                        // Only translate words that don't have existing meanings
                        if (!languagesAreSame) {
                            console.log('🔄 Starting translation for new words');
                            translateNewWords(data.words, data.existingMeanings || {});
                        }

                        if (data.words.length < itemsPerPage) {
                            console.log('⏹️ No more words to load, hiding button');
                            loadMoreBtn.style.display = 'none';
                        }
                    } else {
                        console.log('❌ No more words or empty response, hiding button');
                        loadMoreBtn.style.display = 'none';
                    }
                })
                .catch(error => {
                    console.error('💥 Error loading more words:', error);
                    loadMoreBtn.textContent = 'Error - Click to retry';
                })
                .finally(() => {
                    isLoading = false;
                    loadMoreBtn.textContent = 'Load More';
                    loadMoreBtn.style.opacity = '1';
                });
        }

        function appendWordsToTable(words, existingMeanings, lang2) {
            console.log('📋 appendWordsToTable called with:', words.length, 'words');

            const tbody = document.querySelector('.loadmore-table tbody');
            const currentRowCount = document.querySelectorAll('.loadmore-table tbody tr').length;

            words.forEach((word, index) => {
                const srNo = currentRowCount + index + 1;
                const tr = document.createElement('tr');
                tr.setAttribute('data-word', word.word1);
                tr.setAttribute('data-srno', srNo);
                tr.setAttribute('data-wordid', word.wordId || '');

                let definition = word.definition || '';
                if (definition) {
                    definition = definition.split(',')[0].trim();
                }

                const existingMeaning = existingMeanings && existingMeanings[word.word1.toLowerCase()]
                    ? existingMeanings[word.word1.toLowerCase()]
                    : '';

                if (!languagesAreSame) {
                    tr.innerHTML = `
                        <td>${srNo}</td>
                        <td><a href="/dictionary/${word.word1.replace(/ /g, '-')}-meaning-in-${lang2}" class="word-link">${word.word1}</a></td>
                        <td id="meaning-${srNo}" class="meaning-cell">${existingMeaning}</td>
                        <td id="definition-${srNo}" class="definition-cell">${definition}</td>
                    `;
                } else {
                    tr.innerHTML = `
                        <td>${srNo}</td>
                        <td><a href="/dictionary/${word.word1.replace(/ /g, '-')}-meaning-in-${lang2}" class="word-link">${word.word1}</a></td>
                        <td id="definition-${srNo}" class="definition-cell">${definition}</td>
                    `;
                }

                tbody.appendChild(tr);
            });
        }

        // ========== DEFINITION HANDLING ==========
        async function processDefinitions() {
            console.log('📚 Processing definitions for existing words');
            const wordRows = document.querySelectorAll('tbody tr[data-word]');

            for (let i = 0; i < wordRows.length; i++) {
                const row = wordRows[i];
                const word = row.getAttribute('data-word');
                const definitionCell = row.querySelector('.definition-cell');

                if (definitionCell && !definitionCell.textContent.trim()) {
                    console.log(`🔍 Word "${word}" needs definition`);
                    definitionCell.innerHTML = '<span class="loading">Loading definition...</span>';
                    await getDefinitionFromDatabaseOrAPI(word, currentLanguage, definitionCell);
                    await new Promise(resolve => setTimeout(resolve, 200));
                } else {
                    console.log(`✅ Word "${word}" already has definition`);
                }
            }
        }

        async function processNewWordsDefinitions(words) {
            console.log('📚 Processing definitions for new words');
            await new Promise(resolve => setTimeout(resolve, 100));

            const allWordRows = document.querySelectorAll('tbody tr[data-word]');
            const newRows = Array.from(allWordRows).slice(-words.length);

            for (let i = 0; i < newRows.length; i++) {
                const row = newRows[i];
                const word = row.getAttribute('data-word');
                const definitionCell = row.querySelector('.definition-cell');

                if (definitionCell && !definitionCell.textContent.trim()) {
                    console.log(`🔍 New word "${word}" needs definition`);
                    definitionCell.innerHTML = '<span class="loading">Loading definition...</span>';
                    await getDefinitionFromDatabaseOrAPI(word, currentLanguage, definitionCell);
                    await new Promise(resolve => setTimeout(resolve, 200));
                }
            }
        }

        async function getDefinitionFromDatabaseOrAPI(word, languageCode, definitionCell) {
            console.log(`🔍 Getting definition for: ${word}`);

            try {
                // First check if we have definition in database via API
                const definition = await fetchDefinitionFromAPI(word, languageCode);

                if (definition && definition !== 'N/A' && definition !== 'Error') {
                    console.log(`✅ Definition found: ${definition}`);
                    definitionCell.textContent = definition;

                    // Save definition to database
                    await saveWordDefinition(word, languageCode, definition);
                } else {
                    console.log(`❌ No definition found for: ${word}`);
                    definitionCell.textContent = 'Definition not available';
                }
            } catch (error) {
                console.error(`💥 Error getting definition for ${word}:`, error);
                definitionCell.textContent = 'Error loading definition';
            }
        }

        async function fetchDefinitionFromAPI(word, languageCode) {
            console.log(`🌐 Fetching definition from API for: ${word}`);

            try {
                // Use DictionaryAPI for English words
                if (languageCode === 'en' || languageCode === 'en-gb' || languageCode === 'en-us') {
                    const dictUrl = `https://api.dictionaryapi.dev/api/v2/entries/en/${encodeURIComponent(word.toLowerCase())}`;
                    console.log(`🔗 Dictionary API URL: ${dictUrl}`);

                    const response = await fetch(dictUrl);

                    if (!response.ok) {
                        if (response.status === 404) {
                            console.log(`❌ Word "${word}" not found in dictionary`);
                            return 'N/A';
                        }
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const entries = await response.json();
                    console.log(`📦 Dictionary API response for ${word}:`, entries);

                    if (entries && entries.length > 0) {
                        const firstEntry = entries[0];

                        // Get the first definition from the first meaning
                        if (firstEntry.meanings && firstEntry.meanings.length > 0) {
                            const firstMeaning = firstEntry.meanings[0];
                            if (firstMeaning.definitions && firstMeaning.definitions.length > 0) {
                                const definition = firstMeaning.definitions[0].definition;
                                console.log(`✅ Found definition: ${definition}`);
                                return definition;
                            }
                        }
                    }
                    return 'N/A';
                } else {
                    // For non-English words, use translation-based definition
                    console.log(`🌐 Non-English word, using translation-based definition for: ${word}`);

                    // Translate the word to English and then get definition
                    const translation = await fetchMeaningFromGoogleAPI(word, languageCode, 'en');
                    if (translation && translation !== 'N/A' && translation !== 'Error') {
                        console.log(`🔤 Translated "${word}" to "${translation}" for definition lookup`);

                        // Now get definition of the translated word
                        const dictUrl = `https://api.dictionaryapi.dev/api/v2/entries/en/${encodeURIComponent(translation.toLowerCase())}`;
                        const response = await fetch(dictUrl);

                        if (response.ok) {
                            const entries = await response.json();
                            if (entries && entries.length > 0 && entries[0].meanings && entries[0].meanings[0].definitions) {
                                const definition = entries[0].meanings[0].definitions[0].definition;
                                console.log(`✅ Found definition via translation: ${definition}`);
                                return definition;
                            }
                        }
                    }
                    return 'N/A';
                }
            } catch (error) {
                console.error(`💥 Error fetching definition for ${word}:`, error);
                return 'Error';
            }
        }

        async function saveWordDefinition(word, languageCode, definition) {
            console.log(`💾 Saving definition for: ${word}`);

            try {
                const requestData = {
                    word: word,
                    cleanWord: word.toLowerCase(),
                    languageCode: languageCode,
                    definition: definition,
                    partOfSpeech: null,
                    description: null,
                    example: null,
                    synonyms: null,
                    antonyms: null
                };

                const response = await fetch('/dictionary/update-word-data', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestData)
                });

                if (!response.ok) {
                    throw new Error('Failed to save word definition');
                }

                const result = await response.json();
                console.log(`✅ Definition saved successfully for ${word}:`, result);
                return result;

            } catch (error) {
                console.error(`💥 Error saving definition for ${word}:`, error);
                return { success: false, message: error.message };
            }
        }

        // ========== TRANSLATION HANDLING ==========
        async function translateWords() {
            console.log('🔄 translateWords() started');
            const wordRows = document.querySelectorAll('tbody tr[data-word]');
            const existingMeanings = @Html.Raw(Json.Serialize(ViewBag.ExistingMeanings));

            for (let i = 0; i < wordRows.length; i++) {
                const row = wordRows[i];
                const word = row.getAttribute('data-word');
                const meaningCell = row.querySelector('.meaning-cell');

                if (!meaningCell || meaningCell.textContent.trim()) {
                    continue;
                }

                meaningCell.innerHTML = '<span class="loading">Loading...</span>';
                const capitalizedWord = capitalizeWord(word);
                await getMeaningFromDatabaseOrAPI(capitalizedWord, currentLanguage, translatedLanguage, meaningCell);
                await new Promise(resolve => setTimeout(resolve, 300));
            }
        }

        async function translateNewWords(words, existingMeanings = {}) {
            console.log('🔄 translateNewWords() started for', words.length, 'words');
            await new Promise(resolve => setTimeout(resolve, 100));

            const allWordRows = document.querySelectorAll('tbody tr[data-word]');
            const newRows = Array.from(allWordRows).slice(-words.length);

            for (let i = 0; i < newRows.length; i++) {
                const row = newRows[i];
                const word = row.getAttribute('data-word');
                const meaningCell = row.querySelector('.meaning-cell');

                const hasExistingMeaning = existingMeanings && existingMeanings[word.toLowerCase()];

                if (meaningCell && !hasExistingMeaning && !meaningCell.textContent.trim()) {
                    meaningCell.innerHTML = '<span class="loading">Loading...</span>';
                    const capitalizedWord = capitalizeWord(word);
                    await getMeaningFromDatabaseOrAPI(capitalizedWord, currentLanguage, translatedLanguage, meaningCell);
                    await new Promise(resolve => setTimeout(resolve, 300));
                }
            }
        }

        async function getMeaningFromDatabaseOrAPI(word, sourceLang, targetLang, meaningCell) {
            try {
                const existingMeanings = @Html.Raw(Json.Serialize(ViewBag.ExistingMeanings));
                const lowerWord = word.toLowerCase();

                if (existingMeanings && existingMeanings[lowerWord]) {
                    meaningCell.textContent = existingMeanings[lowerWord];
                    return;
                }

                if (meaningCell.textContent.trim() && !meaningCell.querySelector('.loading')) {
                    return;
                }

                const translation = await fetchMeaningFromGoogleAPI(word, sourceLang, targetLang);

                if (translation && translation !== 'N/A' && translation !== 'Error') {
                    meaningCell.textContent = translation;
                    await saveWordAndMeaning(word, sourceLang, translation, targetLang);
                } else {
                    meaningCell.textContent = translation || 'N/A';
                }
            } catch (error) {
                console.error('Error getting meaning for', word, ':', error);
                meaningCell.textContent = 'Error';
            }
        }

        async function fetchMeaningFromGoogleAPI(word, sourceLang, targetLang) {
            try {
                const translationUrl = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${sourceLang}&tl=${targetLang}&dt=t&q=${encodeURIComponent(word)}`;
                const response = await fetch(translationUrl);

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();

                if (data && data[0] && data[0][0] && data[0][0][0]) {
                    const translatedText = data[0][0][0];
                    return translatedText;
                } else {
                    return 'N/A';
                }
            } catch (error) {
                console.error('Google API Translation error for', word, ':', error);
                return await fetchMeaningFromMyMemoryAPI(word, sourceLang, targetLang);
            }
        }

        async function fetchMeaningFromMyMemoryAPI(word, sourceLang, targetLang) {
            try {
                const translationUrl = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(word)}&langpair=${sourceLang}|${targetLang}`;
                const response = await fetch(translationUrl);

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();

                if (data.responseStatus === 200 && data.responseData && data.responseData.translatedText) {
                    return data.responseData.translatedText;
                } else {
                    return 'N/A';
                }
            } catch (error) {
                console.error('MyMemory API Translation error for', word, ':', error);
                return 'Error';
            }
        }

        async function saveWordAndMeaning(sourceWord, sourceLangCode, targetWord, targetLangCode) {
            try {
                const requestData = {
                    sourceWord: sourceWord,
                    sourceLanguageCode: sourceLangCode,
                    targetWord: targetWord,
                    targetLanguageCode: targetLangCode
                };

                const response = await fetch('/dictionary/save-word-with-meaning', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestData)
                });

                if (!response.ok) {
                    throw new Error('Failed to save word data');
                }

                const result = await response.json();
                return result;

            } catch (error) {
                console.error('Error saving word and meaning:', error);
                return { success: false, message: error.message };
            }
        }

        // ========== HEADER SEARCH FUNCTIONALITY ==========
        function initializeHeaderCustomSelect() {
            const customSelectHeader = document.getElementById('customSelectSearch');
            if (!customSelectHeader) return;

            const customOptionsHeader = customSelectHeader.nextElementSibling;
            const optionSearchHeader = document.getElementById('optionSearchHeader');
            const optionsHeader = customOptionsHeader?.querySelectorAll('span[data-value]');
            const selectedSpanHeader = customSelectHeader.querySelector('.selected');
            const searchBtnHeader = document.getElementById('searchBtnHeader');
            const wordInputHeader = document.querySelector('.ss-banner-inner .banner-form input[type="text"]');
            const customSelectWrapperHeader = customSelectHeader.parentElement;

            console.log('Initializing header search bar:', { customSelectHeader, customOptionsHeader, optionSearchHeader, options: optionsHeader?.length });

            // Toggle dropdown using CSS classes
            customSelectHeader.addEventListener('click', function(e) {
                e.stopPropagation();
                customSelectWrapperHeader.classList.toggle('active');
                customOptionsHeader.classList.toggle('active');

                if (customOptionsHeader.classList.contains('active') && optionSearchHeader) {
                    optionSearchHeader.focus();
                }
            });

            // Handle option selection
            if (optionsHeader) {
                optionsHeader.forEach(option => {
                    option.addEventListener('click', function() {
                        selectedLanguageHeader = this.getAttribute('data-value');
                        const languageName = this.textContent;
                        selectedSpanHeader.textContent = languageName;

                        // Close dropdown
                        customSelectWrapperHeader.classList.remove('active');
                        customOptionsHeader.classList.remove('active');

                        console.log('Header search bar selected:', selectedLanguageHeader);
                    });
                });
            }

            // Search filter functionality
            if (optionSearchHeader) {
                optionSearchHeader.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase();
                    let hasVisibleOptions = false;

                    if (optionsHeader) {
                        optionsHeader.forEach(option => {
                            const text = option.textContent.toLowerCase();
                            if (text.includes(searchTerm)) {
                                option.style.display = 'block';
                                hasVisibleOptions = true;
                            } else {
                                option.style.display = 'none';
                            }
                        });
                    }

                    // Show a message if no options match
                    const noResults = customOptionsHeader.querySelector('.no-results');
                    if (!hasVisibleOptions && !noResults) {
                        const noResultsMsg = document.createElement('div');
                        noResultsMsg.className = 'no-results';
                        noResultsMsg.textContent = 'No languages found';
                        noResultsMsg.style.padding = '10px 15px';
                        noResultsMsg.style.color = '#666';
                        noResultsMsg.style.fontStyle = 'italic';
                        customOptionsHeader.appendChild(noResultsMsg);
                    } else if (hasVisibleOptions && noResults) {
                        noResults.remove();
                    }
                });
            }

            // Search button functionality
            if (searchBtnHeader) {
                searchBtnHeader.addEventListener('click', function() {
                    performHeaderSearch();
                });
            }

            // Allow Enter key to trigger search
            if (optionSearchHeader) {
                optionSearchHeader.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        performHeaderSearch();
                    }
                });
            }

            if (wordInputHeader) {
                wordInputHeader.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        performHeaderSearch();
                    }
                });
            }

            // Close dropdown when clicking outside
            document.addEventListener('click', function() {
                if (customSelectWrapperHeader) {
                    customSelectWrapperHeader.classList.remove('active');
                }
                if (customOptionsHeader) {
                    customOptionsHeader.classList.remove('active');
                }
            });
        }

        function performHeaderSearch() {
            console.log('Header search triggered. Selected language:', selectedLanguageHeader);

            if (!selectedLanguageHeader) {
                selectedLanguageHeader = '@Model.lang2.Name';
            }

            // Get the word from header input
            const wordInput = document.querySelector('.ss-banner-inner .banner-form input[type="text"]');
            const wordToSearch = wordInput?.value.trim();

            if (!wordToSearch) {
                alert('Please enter a word to search');
                if (wordInput) wordInput.focus();
                return;
            }

            // Redirect to the new language page
            window.location.href = `/dictionary/${wordToSearch.toLowerCase().trim().replace(/\s+/g, "-")}-meaning-in-${selectedLanguageHeader.toLowerCase().trim()}`;
        }

        // ========== UTILITY FUNCTIONS ==========
        function capitalizeWord(word) {
            if (!word) return '';
            return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
        }

        function hideMeaningColumn() {
            const tableHeaders = document.querySelectorAll('.loadmore-table thead th');
            tableHeaders.forEach((th, index) => {
                if (th.textContent.trim() === 'Meaning') {
                    th.style.display = 'none';
                }
            });

            const meaningCells = document.querySelectorAll('.loadmore-table .meaning-cell');
            meaningCells.forEach(cell => {
                cell.style.display = 'none';
            });

            const existingRows = document.querySelectorAll('.loadmore-table tbody tr');
            existingRows.forEach(row => {
                const meaningCell = row.querySelector('.meaning-cell');
                if (meaningCell) {
                    meaningCell.remove();
                }
            });
        }
    });
</script>

