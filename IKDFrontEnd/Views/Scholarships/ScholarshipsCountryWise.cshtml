@model IKDFrontEnd.ViewModels.Common.TblCmsDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section MetaData {
    @{
        var metaTitle = Model?.MetaTitle ?? "";
        var metaDescription = Model?.MetaDesc ?? "";
        var metaKeywords = Model?.MetaKeys ?? "";
    }
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:image" content="" />
    <meta name="description" content="@metaDescription">
    <meta name="keywords" content="@metaKeywords">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@metaTitle</title>
}
@section header {
    <div class="col-lg-11">
        <ul class="navigation">
            <li>
                <a aria-label="link" href="/scholarships/">
                    <img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
                    Home
                </a>
            </li>

            <li>
                <a aria-label="link" href="/studyabroad/">
                    <img src="https://www.ilmkidunya.com/icons/study-abroad.png"
                         alt="image" />
                    Studyabroad
                </a>
            </li>
            <li>
                <a aria-label="link" href="/studyabroad/country-guides.aspx">
                    <img src="https://resources.ilmkidunya.com/ikd-guides/assets/images/icons/adm-icon.png"
                         alt="image" />
                    Guides
                </a>
            </li>
            <li>
                <a aria-label="link" href="/consultants/">
                    <img src="https://www.ilmkidunya.com/icons/tutor.png"
                         alt="image" />
                    Consultants
                </a>
            </li>
            <li>
                <a aria-label="link" href="/scholarships/topscholarship">
                    <img src="https://ikddata.ilmkidunya.com/icons/ic-courses-nav-colleges-2.png"
                         alt="image" />
                    Top Scholarship
                </a>
            </li>
        </ul>
    </div>
}
@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        <h1>@ViewBag.CountryName Scholarships for Pakistani Students</h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div id="main">
    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="ckeditorcontent">
                        @if (!string.IsNullOrEmpty(Model?.Desc1))
                        {
                            @Html.RenderWithAds(Model.Desc1)
                        }

                        @if (!string.IsNullOrEmpty(Model?.Desc2))
                        {
                            @Html.RenderWithAds(Model.Desc2)
                        }

                        @if (!string.IsNullOrEmpty(Model?.Desc3))
                        {
                            @Html.RenderWithAds(Model.Desc3)
                        }
                       

                    </div>
                </div>
            </div>
        </div>
    </div>
 
  
    <div class="contact-sec level fee-box">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="scholorship-container">
                        @if (!string.IsNullOrEmpty(Model?.Heading))
                        {
                            <h2> @Html.Raw(Model.Heading)</h2>
                        }

                        @foreach (var item in (List<IKDFrontEnd.ViewModels.ScholarshipApiViewModel>)ViewBag.LatestScholarships)
                        {
                             <a href="/scholarships/@item.Url" class="text-decoration-none text-dark">
                            <div class="single-scholorship">
                                <div class="scholorship-head">
                                    <figure>
                                        <img src="https://cdn.ilmkidunya.com/scholarshipimages/127X127/@item.Image" alt="Sch Thumb" />
                                    </figure>
                                    <div class="scholarship-info">
                                        <div class="scholarship-left-info">
                                            <h2>@item.SchName</h2>
                                            <p>
                                                <img src="https://resources.ilmkidunya.com/ikd-scholorships/assets/images/icons/signal.png" />
                                                <span>@string.Join(", ", item.StudyLevels)</span>
                                            </p>
                                            <p>
                                                <img src="https://resources.ilmkidunya.com/ikd-scholorships/assets/images/icons/deg-cap.png" />
                                                <span>@string.Join(", ", item.FieldsOfStudy)</span>
                                            </p>
                                        </div>
                                        <div class="scholarship-right-info">
                                            <p>Apply By</p>
                                            <p class="sch-apply-date">@item.Deadline?.ToString("dd MMM yyyy")</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            </a>
                        }



                       
                       
                    </div>

                    <div class="share-box" style="padding-top: 30px;">
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    @await Html.PartialAsync("_maincontenttopbanner")
                </div>
            </div>
        </div>
    </div>
   
</div>



