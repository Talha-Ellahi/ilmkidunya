<script>
    document.getElementById('searchBtn').addEventListener('click', function () {
        debugger;
        var cityId = $("#cityDropdown").val();
        var cityName = $("#cityDropdown option:selected").text().trim();
        if (!cityId) {
            cityName = "all";
        }
        var typeName = $("#typeDropdown option:selected").text().trim();
        // ✅ Add this to update URL without reloading the page
        const newUrl = `/Jobs/Search?type=${typeName}&city=${cityName}`;
        window.history.pushState({}, '', newUrl);

        // 🔥 Fetch search results
        fetch(newUrl, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('jobResults').innerHTML = html;
            bindSearchLoadMore(levelUrl, cityUrl); // rebind after new content
        })
        .catch(error => {
            console.error("Error loading search results:", error);
        });
    });


</script>
