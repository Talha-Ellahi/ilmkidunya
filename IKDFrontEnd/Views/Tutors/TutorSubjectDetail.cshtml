@model IKDFrontEnd.ViewModels.CombinedSubjectCityLevelViewModel

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	var random = new Random();
	var colorClasses = new[] { "sh-green", "sh-blue", "sh-purple", "sh-red" };
}
@section MetaData {
	@if (ViewBag.CmsData != null)
	{
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
		<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
		<meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
		<meta name="description" content="@ViewBag.CmsData.MetaDesc">
		<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
		<title>@ViewBag.CmsData.MetaTitle</title>
	}
}
@section header {
	<!-- Header Start -->
	<div class="col-lg-11">
		<partial name="_JobsNavBar" />
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@ViewBag.CmsData.Heading</h1>
					</div>
				</div>
			</div>
		</div>
	</div>
}

<!-- Main Start -->
<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if (ViewBag.CmsData != null && ViewBag.CmsData.Desc1 != null)
					{
						<style>
							 p {
								 margin: 0px !important;
							 }

							 span {
								 font-size: 16px !important;
							 }
						</style>
						<p>@Html.Raw(ViewBag.CmsData.Desc1)</p>
					}

				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					<div class="container">
						<div class="row">
							<div class="col-lg-12 col-md-12 col-sm-12">
								<div class="col-lg-12 col-md-12 col-sm-12">
									@await Html.PartialAsync("_maincontenttopbanner")
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	@if (ViewBag.Skills == "false")
	{
		<div class="content-sec level-wise">
			<div class="container">
				<div class="row">
					<div class="col-lg-12">
						<h2>Subject Wise Home @ViewBag.CmsData.Heading</h2>
                        <ul class="ss-class-list" style="padding-bottom: 20px;">
                            @foreach (var level in Model.EducationLevels)
                            {
								var cssClass = colorClasses[random.Next(colorClasses.Length)];

                                var levelSlug = level.Url.ToLower().Replace(" ", "-");
                                var subjectSlug = Model.subjectName?.ToLower().Replace(" ", "-") ?? "general";
                        
                                <li>
									<a style="min-height:135px" href="@($"/tutors/home-tutors-for-{levelSlug}-class-{subjectSlug}.aspx")" class="@cssClass">
                                        <div class="inner-text">
                                            <span>Tutor for</span>
                                            <strong>@level.EducationLevelName</strong>
                                            <em>@level.TutorCount Tutors</em>
                                        </div>
                                    </a>
                                </li>
                            }
							<script>
    document.addEventListener("DOMContentLoaded", function () {
        const listItems = document.querySelectorAll("li .inner-text strong");

        listItems.forEach(function (strongEl) {
            const originalText = strongEl.textContent;

            if (originalText.includes("/")) {
                const parts = originalText.split("/");

                // Build new structure
                const firstStrong = document.createElement("strong");
                firstStrong.textContent = parts[0] + " & ";

                const secondStrong = document.createElement("strong");
                secondStrong.textContent = parts[1];

                // Replace the original strong element
                const parent = strongEl.parentElement;
                parent.replaceChild(firstStrong, strongEl);
                parent.insertBefore(secondStrong, firstStrong.nextSibling);
            }
        });
    });
</script>

                        </ul>
						<style>
							ul.ss-class-list li a em {
								display: block;
								width: 100%;
								font-size: 14px;
								font-style: normal;
								color: #15a18d;
								transition: .3s ease-in-out;
							}

							ul.ss-class-list li a:hover em {
								color: #fff;
							}
						</style>
					</div>
				</div>
			</div>
		</div>

	}
	<div class="contact-sec fee-box">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>City Wise Home @ViewBag.CmsData.Heading</h2>
					<ul class="admission-nav" style="border: 0;">
						@foreach (var city in Model.Cities)
						{
							var citySlug = city.CityName.ToLower().Replace(" ", "-");
							var subjectSlug = Model.subjectName?.ToLower().Replace(" ", "-") ?? "general";

							<li>
								<a href="@($"/tutors/home-tutors-for-{subjectSlug}-in-{citySlug}.aspx")">
									<figure>
										<img src="@city.ImageName" onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';" />
									</figure>
									<span style="font-size: 12px;">@city.CityName</span> <span>(@city.TutorCount Tutors)</span>
								</a>
							</li>
						}
					</ul>
					<style>
						ul.admission-nav li a span {
							display: flex;
							width: 100%;
							flex-wrap: wrap;
							justify-content: center;
							font-size: 12px !important;
							color: #080808;
							text-align: center;
							line-height: 18px;
							align-items: center;
							height: 30px;
							font-weight: 500;
						}
					</style>
					@if (ViewBag.CmsData != null && ViewBag.CmsData.Desc2 != null)
						{
						<p>@Html.Raw(ViewBag.CmsData.Desc2)</p>
						}

					<h2>Find Out Your Tutors in</h2>
					<div class="institute-list">
						<ul id="tutor-list" class="skills-tutors">
							@foreach (var tutor in Model.LatestTutors)
							{
								var tutorSlug = tutor.TutorName.ToLower().Replace(" ", "-");
								<li>
									<a aria-label="link" href="@($"/tutors/{tutorSlug}-home-tutor-{tutor.MemberId}.aspx")">
										<div class="figure">
											<img onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';"  src="@tutor.ProfileImage">
										</div>
										<div class="author" style="height:200px">
											<h4>@tutor.TutorName</h4>
											<span>@tutor.CityName | @tutor.CourseName</span>
											<p>Teaching</p>
											<span>@string.Join(", ", tutor.Subjects)...</span>
										</div>
									</a>
								</li>
							}
						</ul>
						<style>
							.button {
								display: inline-block;
								background: #434343;
								font-size: 16px;
								border: none;
								padding: 5px 20px;
								color: #fff;
								border-radius: 5px;
								margin: 0;
								text-decoration: none;
								cursor: pointer;
							}

								.button:hover,
								.button:focus,
								.button.load-more {
									background-color: #15A18D;
									border-color: #15A18D;
									color: #fff;
								}

							.load-more span {
								animation-name: loading;
								animation-duration: 1.2s;
								animation-iteration-count: infinite;
								animation-fill-mode: both;
								background-color: #15A18D;
								border-color: #15A18D;
								color: #fff;
							}

							@@keyframes loading {
								0% {
									opacity: 0;
								}

								50% {
									opacity: 1;
								}

								100% {
									opacity: 0;
								}
							}

							.load-more span:nth-child(2) {
								animation-delay: 0.2s;
							}

							.load-more span:nth-child(3) {
								animation-delay: 0.4s;
							}
						</style>
						<div class="loader" style="text-align: center; margin-bottom: 20px;">
							<a href="javascript:void(0)" class="button js-load-more" id="load-more-btn" data-skip="10">Load More</a>
						</div>

						<script>
							document.getElementById("load-more-btn").addEventListener("click", function () {
								const btn = this;
								const skip = parseInt(btn.getAttribute("data-skip"));

								const subjId = '@ViewBag.SubjectId';
								const cityId = '@ViewBag.CityId';
								const levelId = '@ViewBag.LevelId';

								// Optional: show loading animation
								btn.classList.add("load-more");
								btn.innerHTML = 'Loading <span>.</span><span>.</span><span>.</span>';

								fetch(`/tutors/LoadMore?skip=${skip}&subjId=${subjId}&cityId=${cityId}&levelId=${levelId}`)
									.then(res => res.text())
									.then(html => {
										document.getElementById("tutor-list").insertAdjacentHTML("beforeend", html);
										const newSkip = skip + 10;
										btn.setAttribute("data-skip", newSkip);
										if (html.trim() === '') {
											btn.parentElement.remove(); // No more tutors
										} else {
											btn.classList.remove("load-more");
											btn.textContent = "Load More";
										}
									})
									.catch(err => {
										console.error("LoadMore error:", err);
										btn.classList.remove("load-more");
										btn.textContent = "Load More";
									});
							});
						</script>

					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="container">
					<div class="row">
						<div class="col-lg-12 col-md-12 col-sm-12">
							<div class="col-lg-12 col-md-12 col-sm-12">
								@await Html.PartialAsync("_maincontentlowerbanner")
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<!-- Main End -->

