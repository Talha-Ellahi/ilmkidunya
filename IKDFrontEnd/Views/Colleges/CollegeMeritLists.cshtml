@using IKDFrontEnd.ViewModels
@model CollegesViewModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	// ViewData["PageTitle2"] = Model.PageTitle2;
}
@section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">

	<meta property="og:title" content="@(ViewBag.CmsData?.MetaTitle ?? string.Empty)" />
	<meta property="og:description" content="@(ViewBag.CmsData?.MetaDesc ?? string.Empty)" />
	<meta property="og:image" content="" />

	<meta name="description" content="@(ViewBag.CmsData?.MetaDesc ?? string.Empty)">
	<meta name="keywords" content="@(ViewBag.CmsData?.MetaKeys ?? string.Empty)">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>@(ViewBag.CmsData?.MetaTitle ?? "IlmKiDunya")</title>
}

@section header {

	<div class="col-lg-11">
		<ul class="navigation">
			<li>
				<a aria-label="link" href="/colleges/">
					<img src="https://images.ishallwin.com/nav-icons/chem-nav-4.webp" alt="image" />
					Universities & Colleges
				</a>
			</li>

			@if (Model?.College != null)
			{
				<li>
					<a aria-label="link" href="/colleges/@(ViewBag.CollegeBaseUrl ?? string.Empty).aspx">
						<img src="https://cdn.ilmkidunya.com/Inst/logos/@(Model.College.Logo ?? "default.webp")" alt="image" />
						@Model.College.Name
					</a>
				</li>
			}

			@if (ViewBag.ShowFeeStructure == true)
			{
				<li>
					<a aria-label="link" href="/colleges/@(ViewBag.CollegeBaseUrl ?? string.Empty)-fee-structure.aspx">
						<img src="https://images.ishallwin.com/nav-icons/chem-nav-3.webp" alt="image" />
						Fee Structure
					</a>
				</li>
			}

			@if (ViewBag.ShowMeritList == true)
			{
				<li>
					<a aria-label="link" href="/colleges/@(ViewBag.CollegeBaseUrl ?? string.Empty)-merit-lists.aspx">
						<img src="https://images.ishallwin.com/nav-icons/chem-nav-9.webp" alt="image" />
						Merit List
					</a>
				</li>
			}

			@if (ViewBag.ShowAdmissions == true)
			{
				<li>
					<a aria-label="link" href="/colleges/@(ViewBag.CollegeBaseUrl ?? string.Empty)-admission.aspx">
						<img src="https://images.ishallwin.com/nav-icons/chem-nav-9.webp" alt="image" />
						Admission
					</a>
				</li>
			}
		</ul>
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@(ViewBag.CmsData?.Heading ?? string.Empty)</h1>
					</div>
				</div>
			</div>
		</div>
	</div>
}


<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(ViewBag.CmsData?.Desc1 ?? string.Empty)
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
