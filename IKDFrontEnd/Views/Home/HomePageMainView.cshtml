@section innerbanner {


	<div class="desktop-view">
		<div class="main-slides">
			<div class="container">
				<div class="row">
					<div class="col-lg-5 col-md-5 col-sm-12">
						<div class="main-slider">
							@foreach (var sliders in Model.Sliders)
							{
								<div class="inner-slide">
									<a aria-label="link" href="@sliders.Url" target="_blank">
										<img src="https://www.ilmkidunya.com/images/sliders/@sliders.Image" alt="image" />
									</a>
								</div>
							}

						</div>
					</div>
					<div class="col-lg-7 col-md-7 col-sm-12">
						<ul class="sm-news-list news-without-adds">
							@foreach (var news in Model.LatestNews)
							{
								var month = news.Dated?.Month;
								var year = news.Dated?.Year;
								<li>
									<a aria-label="link" href="edunews/@news.RewriteUrl">
										<div class="img-holder">
											<img class="lazy-load" data-src="https://cdn.ilmkidunya.com/news/newsImages/@year/@month/thumb/@news.PictureThumbnail" alt="image" />
										</div>
										<div class="text-holder">
											<span>
												<img src="https://images.ishallwin.com/icons/calendar-green.webp" alt="image" />
												@news.Dated?.ToString("dd-MMM-yyyy")
											</span>
											<p>@news.MainHeading</p>
										</div>
									</a>
								</li>
							}




						</ul>
					</div>
				</div>
			</div>
		</div>
