@using IKDFrontEnd.Services
@using IKDFrontEnd.ViewModels
@model IKDFrontEnd.ViewModels.GuidePageViewModel

@inject BannerService BannerService

@{
    var banners = await BannerService.GetBannersAsync();
    ViewBag.Banners = banners;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var courseName = ViewBag.Course != null
        ? ViewBag.Course.ToString().Replace("-", " ")
        : "Course";
}
<style>
    .ss-banner-inner {
        /* Ensure proper loading */
        content-visibility: auto;
        contain-intrinsic-size: 400px;
    }

    .ss-text-holder h1 {
        /* Prevent layout shifts */
        min-height: 1em;
        /* Optimize font loading */
        font-display: swap;
    }

    /* Ensure images in banner are optimized */
    .ss-banner-inner img {
        width: 100%;
        height: auto;
        loading: eager; /* If you have critical images */
    }

    @@media screen and (max-width: 980px) {
        .responsive-table .table.mid span img {
            display: none;
        }
    }

</style>

@section MetaData {
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta property="og:title" content="@Model.GuideDetail?.MetaTitle" />
    <meta property="og:description" content="@Model.GuideDetail?.MetaDesc" />
    <meta property="og:image" content="" />
    <meta name="description" content="@Model.GuideDetail?.MetaDesc">
    <meta name="keywords" content="@Model.GuideDetail?.MetaKeyword">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@Model.GuideDetail?.MetaTitle</title>
}

@section header {
    <div class="col-lg-11">
        <ul class="navigation">
            @if (ViewBag.HomeUrl != null)
            {
                <li>
                    <a href="/@ViewBag.HomeUrl" class="menu_main">
                        <div class="child">
                            <img class="lazyload" alt="" src="https://invent.ilmkidunya.com/nadmin/Guide/Icon/home-2.png">
                            <span>Home</span>
                        </div>
                    </a>
                </li>
            }
            @if (Model.MenuItems != null)
            {
                foreach (var item in Model.MenuItems)
                {
                    <li>
                        <a href="@item.Url" class="menu_main">
                            <div class="child">
                                <img class="lazyload" alt="" src="https://cdn.ilmkidunya.com/guidesheadericons/icons/@item.HeaderIcon">
                                <span>@item.HeaderName</span>
                            </div>
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
}
@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        <!-- LCP + CLS Optimized H1 -->
                        <h1>
                            @Model.GuideDetail?.Heading?.Replace("-", " ")
                        </h1>

                        <p>
                            @Model.GuideDetail?.HeadingDesc?.Replace("-", " ")
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

<div id="main">

    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="ckeditorcontent">
                        @Html.RenderWithAds(Model.GuideDetail?.Detail)
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                @if (Model.CityList != null && Model.CityList.Any())
                {
                    <div class="flex-container">
                        <div class="col-lg-4">
                            <div class="table-of-content" style="margin-right:0; padding-bottom:15px; width:100%;">
                                <h3>
                                    Cities with
                                    @Model.CityList.FirstOrDefault()?.ItemType
                                    in
                                    @(Model.Guide != null && Model.Guide.Abrevation != null ? Model.Guide.Abrevation : courseName)
                                </h3>


                                @if (Model.CityList != null && Model.CityList.Any())
                                {
                                    <ul>
                                        @foreach (var city in Model.CityList)
                                        {
                                            var cityUrl = city.CityName.ToLower().Replace(" ", "-");
                                            var courseUrl = courseName.ToLower().Replace(" ", "-"); // Assuming you have this property
                                            var routeType = city.ItemType.ToLower() == "admissions" ? "admissions-in" : "universities-in";

                                            <li class="citywise-list">
                                                <a href="/@courseUrl/@routeType-@cityUrl">
                                                    @city.CityName (@city.ItemCount)
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p>No cities found.</p>
                                }
                            </div>
                        </div>
                    </div>

                }

                <div class="col-lg-12 col-md-12 col-sm-12">
                    @await Html.PartialAsync("_maincontenttopbanner")
                </div>
            </div>
        </div>
    </div>
    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="ckeditorcontent">
                        @if (Model.GuideDetail.Detail2 != null)
                        {
                            @Html.RenderWithAds(Model.GuideDetail?.Detail2)
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="bs-admission-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>
                        More on
                        @(Model.Guide != null && Model.Guide.Abrevation != null
                                                ? Model.Guide.Abrevation
                                                : ViewBag.HomeUrl.ToString().Replace("-", " "))
                    </h2>

                    <ul class="admission-nav">
                        @if (ViewBag.HomeUrl != null)
                        {
                            <li>
                                <a href="/@ViewBag.HomeUrl">
                                    <figure><img src="https://invent.ilmkidunya.com/nadmin/Guide/Icon/home-2.png" alt=""></figure>
                                    <span>Home</span>
                                </a>
                            </li>
                        }
                        @if (Model.MenuItems != null)
                        {
                            foreach (var item in Model.MenuItems)
                            {
                                <li>
                                    <a href="@item.Url">
                                        <figure><img src="https://cdn.ilmkidunya.com/guidesheadericons/icons/@item.HeaderIcon" alt=""></figure>
                                        <span>@item.HeaderName</span>
                                    </a>
                                </li>
                            }
                        }

                    </ul>
                </div>
                <div class="inner-holder">
                    @if (ViewBag.ShowInqueryForm)

                    {
                        <div class="col-lg-12">
                            <div class="box-right" id="Form" style="border:none; padding:0;">
                                <h2>Free Admission Advice for @ViewBag.HomeUrl.ToString().Replace("-", " ")</h2>
                                @Html.Partial("_SuggestionFormGuides", new SuggestionViewModel())
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>


    <br />

</div>

@{
    // Get WhatsApp group data passed from controller
    var whatsappGroup = ViewBag.ShowWatsupLink;
}

@if (whatsappGroup != null && !string.IsNullOrEmpty(whatsappGroup.GroupLink))
