<script>
	let currentPage = 1;

	const loadMoreBtn = document.getElementById('loadMoreBtn');
	const admissionList = document.getElementById('admissionList');
	const levelUrl = "@ViewBag.levelUrl";
	const cityUrl = "@ViewBag.CityUrl";

	if (loadMoreBtn && admissionList) {
		loadMoreBtn.addEventListener('click', function () {
			currentPage++;
			loadMoreBtn.innerHTML = 'Loading...';
			loadMoreBtn.disabled = true;

			fetch(`/admissions/${levelUrl}-admissions-in-${cityUrl}.aspx?page=${currentPage}&pageSize=10`, {
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				}
			})
			.then(response => response.json())
			.then(data => {
				if (data.length === 0) {
					loadMoreBtn.innerHTML = 'No More Admissions';
					loadMoreBtn.disabled = true;
					return;
				}

				data.forEach(item => {
					const li = document.createElement('li');
					li.innerHTML = `
						<div class="uni-box">
							<div class="img-holder">
								<figure>
									<img src="https://cdn.ilmkidunya.com/Inst/logos/${item.collageLogo}" alt="" />
								</figure>
								${item.cityName}
							</div>
							<div class="text-holder">
								<div class="box-left">
									<div class="datewise">
										<span>Posted On <em>${item.dated}</em></span>
										<span>Last Date <em>${item.lastDate ?? 'N/A'}</em></span>
									</div>
									<h3><a href="#">${item.admissionTitle}</a></h3>
									<p>${item.collegeName}</p>
								</div>
								<div class="box-right">
									<figure>
										<img src="https://images.ishallwin.com/admission/Building-1.webp" alt="" />
									</figure>
								</div>
							</div>
						</div>
					`;
					admissionList.appendChild(li);
				});

				loadMoreBtn.innerHTML = 'Load More Admissions';
				loadMoreBtn.disabled = false;
			})
			.catch(error => {
				console.error('Error loading more Admissions:', error);
				loadMoreBtn.innerHTML = 'Error loading Admissions';
				loadMoreBtn.disabled = false;
			});
		});
	}
</script>
