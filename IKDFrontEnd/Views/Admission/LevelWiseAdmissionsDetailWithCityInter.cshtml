		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						@{
							string level = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(((string)ViewBag.LevelUrl).ToLower().Replace("-", " "));
							string city = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(((string)ViewBag.CityUrl).ToLower());
						}
						@if (ViewBag.CmsData != null)
						{
							<h1>@ViewBag.CmsData.Heading</h1>
						}
						else
						{
							<h1>@level Admission in @city @DateTime.Now.Year</h1>
						}
