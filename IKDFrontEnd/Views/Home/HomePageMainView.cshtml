							</li>
						</ul>



					</div>
					<h2>Latest Admissions in Pakistan</h2>
					<div class="home-jobs-list">
						<ul>
							@if (Model.Admissions != null)
							{
								foreach (var admission in Model.Admissions)
								{
									var month = admission.AdmissionOpenDate?.Month;
									var year = admission.AdmissionOpenDate?.Year;

									string imagePath = !string.IsNullOrEmpty(admission.Image)
									? $"https://admissions.ilmkidunya.com/admission_notices/Images/NoticeAds/{year}/{month}/Thumb/{admission.Image}"
									: "https://www.ilmkidunya.com/images/not-available.png";

									<li>
										<div class="img-holder">
											<img class="lazy-load loaded"
												 data-src="@imagePath"
												 alt="image"
												 onerror="this.onerror=null;this.src='https://www.ilmkidunya.com/images/not-available.png';" />
										</div>
										<div class="text-holder">
											<a href="/admissions/@admission.Url">@admission.Title</a>
											<span class="date">Posted: @admission.AdmissionOpenDate?.ToString("dd MMM yyyy")</span>
											<span class="apply">Apply by: @admission.AppliedDate?.ToString("dd MMM yyyy")</span>
										</div>
									</li>
								}
							}
							else
							{
								<li><p>No admissions found.</p></li>
							}
						</ul>



					</div>

		
				</div>
				<div class="col-lg-3 col-md-3 col-sm-12">
					<div class="side-bar">
