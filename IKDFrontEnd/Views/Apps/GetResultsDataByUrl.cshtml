						</div>
						<div class="half-box">
							<input type="text" class="alert-input" name="email" placeholder="Your Email ID" required="">
						</div>
						<div class="half-box">
							<input type="text" class="alert-input" name="className" placeholder="Your Class" required="">
						</div>
						<div class="half-box">
							<input type="text" class="alert-input" name="board" placeholder="Your Board/University" required="">
						</div>

						<div class="half-box">
							<button class="btn-subscribe" type="submit">Get results update</button>
						</div>
						<div id="resultSuccessMessage" style="display:none; color:green; padding-top:10px;">
							✅ Thank you! You’ll receive result updates soon.
						</div>
					</form>
				</div>
			}

