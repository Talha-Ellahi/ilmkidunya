@model IKDFrontEnd.ViewModels.CoursesViewModels
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
	.d-none {
	display: none !important;
	}
</style>

@section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
	<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
	<meta property="og:image" content="https://www.ilmkidunya.com/ikd-default-og.png" />
	<meta name="description" content="@ViewBag.CmsData.MetaDesc">
	<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>@ViewBag.CmsData.MetaTitle</title>
}
@section header {
<div class="col-lg-11">
	<ul class="navigation">
		<li>
			<a aria-label="link" href="/courses/">
				<img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
				Home
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/test-preparation.aspx">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/testprep.png" alt="image" />
				Test Preparation
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/matric">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/matric.png" alt="image" />
				Matric Level
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/intermediate">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/inter.png" alt="image" />
				Inter Level
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/bachelors">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/bachelor.png" alt="image" />
				Bachelor Level
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/masters">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/master.png" alt="image" />
				Master Level
			</a>
		</li>
		<li>
			<a aria-label="link" href="/courses/popular-courses.aspx">
				<img src="https://www.ilmkidunya.com/icons/coursesicons/popular.png" alt="image" />
				Most Popular
			</a>
		</li>

	</ul>
</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder" id="coursesHeading">
						@Html.Raw(ViewBag.HeadingHtml ?? $"<h1>Courses In Pakistan</h1><p>Search from <strong>{Model.CoursesCount}</strong> Courses</p>")
					</div>



				</div>
				<div class="ss-col-lg-12">
					<div class="banner-form" style="margin: 0 20%;">
						<div class="input-holder" style="width: 90%;">
							<div style="width: 33.33%; position: relative;">
								<select class="form-select" name="location" id="cityDropdown">
									<option value="">Select City</option>
									@foreach (var city in Model.Cities)
									{
										<option value="@city.CityId"
												selected="@(ViewBag.Location != null && ViewBag.Location.ToString() == city.CityId.ToString() ? "selected" : null)">
											@city.CityName
										</option>
									}
								</select>
							</div>
							<div style="width: 33.33%; position: relative;">
								<select class="form-select" name="level" id="levelDropdown">
									<option value="">Select Level</option>
									@foreach (var level in Model.Levels)
									{
										<option value="@level.Id"
												selected="@(ViewBag.Level != null && ViewBag.Level.ToString() == level.Id.ToString() ? "selected" : null)">
											@level.Name
										</option>
									}
								</select>
							</div>
							<div style="width: 33.33%; position: relative;">
								<select class="form-select" name="category" id="categoryDropdown">
									<option value="">Select Category</option>
									@foreach (var cat in Model.Categories)
									{
										<option value="@cat.Id"
												selected="@(ViewBag.Category != null && ViewBag.Category.ToString() == cat.Id.ToString() ? "selected" : null)">
											@cat.Name
										</option>
									}
								</select>
							</div>
						</div>

						<div class="btn-holder">
							<button type="button" id="searchBtn">
								<img src="https://images.ishallwin.com/search-icon.webp" alt="Search" />
							</button>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>
}


<div id="main">
	<div id="admissionsResults">
		@if (Model.SearchResults != null && Model.SearchResults.Any())
		{
			@Html.Partial("_CoursesHomeSearch", Model)
		}

	</div>
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(@ViewBag.CmsData.Desc1)

				</div>
			</div>
		</div>
	</div>

	<div class="college-news-sec" style="padding: 20px 0; background: none;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">

					<h3>Colleges/Universities</h3>
					<ul class="ss-company-list adm-list">
						@foreach (var item in Model.Categories)
						{
							<li>
								<a href="/courses/@(item.Url).aspx">
									<img src="https://ikddata.ilmkidunya.com/images/icons/@item.Image" alt="@item.Name" />
									<span>
										@item.Name
										
									</span>
								</a>
							</li>
						}

					</ul>
					
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec level-wise">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>Courses According to Educational Level</h2>

				</div>
				<div class="col-lg-12">
					<ul class="ss-class-list">
						<li>
							<a href="/courses/intermediate">
								<div class="inner-text">
									<span>Colleges for</span>
									<strong>Inter</strong>
								</div>
							</a>
						</li>
						<li>
							<a href="/courses/bachelors" class="sh-red">
								<div class="inner-text">
									<span>University for</span>
									<strong>Bachelor</strong>
								</div>
							</a>
						</li>
						<li>
							<a href="/courses/masters" class="sh-green">
								<div class="inner-text">
									<span>University for</span>
									<strong>Master</strong>
								</div>
							</a>
						</li>
						<li>
							<a href="/courses/mphil" class="sh-purple">
								<div class="inner-text">
									<span>University for</span>
									<strong>M.Phil</strong>
								</div>
							</a>
						</li>
						<li>
							<a href="/courses/phd" class="sh-blue">
								<div class="inner-text">
									<span>University for</span>
									<strong>Ph.D</strong>
								</div>
							</a>
						</li>
					</ul>
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">

					@await Html.PartialAsync("_maincontentlowerbanner")

				</div>
			</div>
		</div>
	</div>
	<div class="g-add-sec" style="padding: 30px 0 0 0;">
		<div class="container">
			<div class="row">
				@await Html.PartialAsync("_GoogleAd")
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(@ViewBag.CmsData.Desc2)

				</div>
			</div>
		</div>
	</div>
</div>


<script>
			document.getElementById('searchBtn').addEventListener('click', function () {
		const location = document.getElementById('cityDropdown').value;
		const level = document.getElementById('levelDropdown').value;
		const category = document.getElementById('categoryDropdown').value;

		if (!location && !level && !category) {
			alert("Please select at least one filter.");
			return;
		}

		const fetchUrl = `/courses/Index?location=${location}&level=${level}&category=${category}&page=1`;
		const cleanUrl = `/courses/Index?location=${location}&level=${level}&category=${category}`;
		history.pushState(null, '', cleanUrl);

		fetch(fetchUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
			.then(response => response.json())
			.then(data => {
				// heading replace
				document.getElementById('coursesHeading').innerHTML = data.heading;

				// results replace
				document.getElementById('admissionsResults').innerHTML = data.results;
			})
			.catch(error => console.error("Error:", error));
	});



</script>

<script>
	document.addEventListener('click', function (e) {
		if (e.target && e.target.id === 'loadMoreBtn') {
			const loadMoreBtn = e.target;
			const institutionList = document.getElementById('institutionList');
			let currentPage = parseInt(loadMoreBtn.getAttribute('data-page')) || 1;
			currentPage++;

			loadMoreBtn.innerText = 'Loading...';
			loadMoreBtn.disabled = true;

			const urlParams = new URLSearchParams(window.location.search);
			const location = urlParams.get("location") || "";
			const level = urlParams.get("level") || "";
			const category = urlParams.get("category") || "";

			const url = `/courses/Index?location=${location}&level=${level}&category=${category}&page=${currentPage}`;

			fetch(url, {
				headers: { 'X-Requested-With': 'XMLHttpRequest' }
			})
			.then(response => response.json())
			.then(data => {
				if (!data.results || data.results.trim().length === 0) {
					loadMoreBtn.innerText = 'No more institutions';
					loadMoreBtn.disabled = true;
					return;
				}

				// Extract the table rows from the results HTML
				const tempDiv = document.createElement('div');
				tempDiv.innerHTML = data.results;

				const newTableBody = tempDiv.querySelector('tbody#institutionList');
				if (!newTableBody || newTableBody.children.length === 0) {
					loadMoreBtn.innerText = 'No more institutions';
					loadMoreBtn.disabled = true;
					return;
				}

				// Append new rows to existing table
				newTableBody.querySelectorAll('tr').forEach(row => {
					institutionList.appendChild(row);
				});

				loadMoreBtn.innerText = 'Load More Institutions';
				loadMoreBtn.disabled = false;
				loadMoreBtn.setAttribute('data-page', currentPage);
			})
			.catch(error => {
				console.error('Error:', error);
				loadMoreBtn.innerText = 'Error loading more';
				loadMoreBtn.disabled = false;
			});
		}
	});
</script>



