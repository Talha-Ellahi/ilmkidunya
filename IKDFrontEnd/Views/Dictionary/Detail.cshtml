    }

    async function getDbPediaDescription() {
        // Only fetch if we need description
        if (!needsDescription) {
            console.log('✅ Description already available, skipping DBPedia API');
            return;
        }

        if (!englishWord) return;

        try {
            let cleanWord = englishWord.split(' ')[0].replace(/[^a-zA-Z]/g, '').toLowerCase();
            if (!cleanWord) return;

            console.log('🌐 Fetching DBPedia description for:', cleanWord);

            const dbPediaUrl = `https://lookup.dbpedia.org/api/search/KeywordSearch?QueryString=${cleanWord}`;
            const response = await fetch(dbPediaUrl);

            if (!response.ok) {
                throw new Error('DBPedia API not available');
            }

            const xmlText = await response.text();
            const description = parseDbPediaDescription(xmlText);

            if (description) {
                // Use innerHTML to set the description in case it contains HTML
                const descriptionElement = document.getElementById('description');
                descriptionElement.innerHTML = description;

                // Save description using the complete word data method
                await saveDescriptionToDatabase(cleanWord, description);
                console.log('✅ Description fetched and saved');
            } else {
                document.getElementById('description').textContent = `Meaning of ${cleanWord} in ${translatedLanguage}`;
                console.log('❌ No description found from DBPedia');
            }

        } catch (error) {
            console.error('Error fetching DBPedia description:', error);
            document.getElementById('description').textContent = `Meaning of ${cleanWord} in ${translatedLanguage}`;
        }
    }

    // Save description to database - updated to use complete word data method
    async function saveDescriptionToDatabase(cleanWord, description) {
        try {
            const response = await fetch('/dictionary/update-complete-word-data', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    word: cleanWord,
                    languageCode: 'en',
                    description: description
                    // Only send description, other fields will remain unchanged
                })
            });

            if (response.ok) {
                console.log('✅ Description saved successfully to database');
            } else {
                console.error('❌ Failed to save description');
            }
        } catch (error) {
            console.error('❌ Error saving description:', error);
        }
    }

    // Save word and meaning to database using your existing API method
    async function saveWordAndMeaning(sourceWord, sourceLangCode, targetWord, targetLangCode) {
        try {
            // Decode any HTML entities in the targetWord before sending
            let decodedTargetWord = targetWord;
            if (targetWord && (targetWord.includes('&amp;#x') || targetWord.includes('&#x'))) {
                console.log('Decoding HTML entities in target word before saving...');
                const textArea = document.createElement('textarea');
                textArea.innerHTML = targetWord;
                decodedTargetWord = textArea.value;
                console.log('Original target word:', targetWord);
                console.log('Decoded target word:', decodedTargetWord);
            }

            const requestData = {
                sourceWord: sourceWord,
                sourceLanguageCode: sourceLangCode,
                targetWord: decodedTargetWord,
                targetLanguageCode: targetLangCode
            };

            console.log('Saving word and meaning to database:', requestData);

            const response = await fetch('/dictionary/save-word-with-meaning', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(requestData)
            });

            if (!response.ok) {
                throw new Error('Failed to save word data: ' + response.status);
            }

            const result = await response.json();
            console.log('✅ Word and meaning saved successfully to database:', result);
            return result;

        } catch (error) {
            console.error('❌ Error saving word and meaning:', error);
            return { success: false, message: error.message };
        }
    }

    function parseDbPediaDescription(xmlText) {
        try {
            // Parse the XML to extract the first description
            const parser = new DOMParser();
            const xmlDoc = parser.parseFromString(xmlText, "text/xml");

            // Get all Result elements
            const results = xmlDoc.getElementsByTagName("Result");

            if (results.length > 0) {
                // Get the first result's Description
                const firstResult = results[0];
                const descriptionElement = firstResult.getElementsByTagName("Description")[0];

                if (descriptionElement && descriptionElement.textContent) {
                    let description = descriptionElement.textContent.trim();

                    // Remove any trailing incomplete sentences
                    const lastPeriod = description.lastIndexOf('.');
                    if (lastPeriod !== -1) {
                        description = description.substring(0, lastPeriod + 1);
                    }

                    return description;
                }
            }

            return null;
        } catch (error) {
            console.error('Error parsing DBPedia XML:', error);
            return null;
        }
    }

