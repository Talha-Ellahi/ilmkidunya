@using System.Net
@using IKDFrontEnd.ViewModels
@model NewsPageViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Superior University - Admissions Open Fall 2025</title>
    <link rel="preload"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          as="style"
          onload="this.rel='stylesheet'">
    <noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    </noscript>
    <script>
        window.addEventListener("load", function () {
          // detect mobile vs desktop
          var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
          var delay = isMobile ? 10000 : 5000; // 10 sec mobile, 5 sec desktop

          setTimeout(function () {
            // Google Analytics
            var gtagScript = document.createElement("script");
            gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=G-245RQY719C";
            gtagScript.async = true;
            document.head.appendChild(gtagScript);

            gtagScript.onload = function () {
              window.dataLayer = window.dataLayer || [];
              function gtag(){ dataLayer.push(arguments); }
              gtag('js', new Date());
              gtag('config', 'G-245RQY719C');
            };

            // Google AdSense
            var adsScript = document.createElement("script");
            adsScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8866825487085085";
            adsScript.async = true;
            adsScript.setAttribute("crossorigin", "anonymous");
            document.head.appendChild(adsScript);

            // AnyMind script
            var anymind = document.createElement("script");
            anymind.src = "//anymind360.com/js/3995/ats.js";
            anymind.async = true;
            document.body.appendChild(anymind);

          }, delay);
        });
    </script>
    <style>
        /* ---------- Reset & Base ---------- */
        * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
        background: #fff;
        color: #2c3e50;
        line-height: 1.6;
        }

        a {
        text-decoration: none;
        color: inherit;
        }

        img {
        max-width: 100%;
        display: block;
        }

        .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 15px;
        }

        /* ---------- Header ---------- */
        .site-header {
        background: #fff;
        padding-bottom: 15px;
        border-bottom: 1px solid #eee;
        }

        .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        }

        .brand {
        display: flex;
        align-items: center;
        gap: 15px;
        }

        .brand-text {
        text-align: center;
        }

        .brand-title {
        font-size: 2.2rem;
        font-weight: bold;
        color: #16a085;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
        }

        .brand-subtitle {
        font-size: 1rem;
        color: #2c3e50;
        opacity: 0.9;
        letter-spacing: 1px;
        }

        .brand-logos {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        }

        .brand-logos img {
        border-radius: 6px;
        box-shadow: 0 3px 6px rgba(0,0,0,0.1);
        }

        /* ---------- Navigation ---------- */
        .main-nav {
        background: #2c3e50;
        margin-top: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }

        .nav-list {
        display: flex;
        justify-content: center;
        list-style: none;
        flex-wrap: wrap;
        padding: 12px 0;
        }

        .nav-list li {
        margin: 5px 15px;
        }

        .nav-list a {
        color: #fff;
        font-weight: 500;
        font-size: 1rem;
        padding: 6px 12px;
        border-radius: 4px;
        transition: 0.3s;
        }

        .nav-list a:hover {
        background: #16a085;
        }

        /* ---------- Banner ---------- */
        .highlight-banner {
        background: #e6fff7;
        padding: 18px;
        margin-top: 10px;
        text-align: center;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08);
        }

        .highlight-banner h2 {
        font-size: 1.8rem;
        font-weight: 700;
        text-transform: uppercase;
        }

        /* ---------- Main ---------- */

        .section-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 25px;
        border-bottom: 3px solid #16a085;
        padding-bottom: 10px;
        text-transform: uppercase;
        }

        /* Reusable card grid */
        .card-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        }

        .card {
        flex: 1 1 calc(20% - 20px); /* 5 per row on desktop */
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 12px rgba(0,0,0,0.08);
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        }

        .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }

        .card img {
        height: 140px;
        object-fit: cover;
        border-radius: 12px 12px 0 0;
        }

        .card-body {
        padding: 12px;
        flex-grow: 1;
        }

        .card-body h3 {
        font-size: 1.1rem;
        margin-bottom: 8px;
        font-weight: 600;
        color: #2c3e50;
        }

        .card-body p {
        font-size: 0.95rem;
        color: #555;
        }

        /* ---------- Footer ---------- */
        .site-footer {
        background: #2c3e50;
        color: white;
        padding: 40px 0 20px;
        margin-top: 40px;
        }

        .footer-top {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        gap: 20px;
        margin-bottom: 20px;
        }

        .footer-col {
        flex: 1 1 250px;
        background: #e6fff7;
        padding: 20px;
        border-radius: 12px;
        color: #2c3e50;
        }

        .footer-col h3 {
        background: #2c3e50;
        color: #fff;
        padding: 8px 15px;
        border-radius: 6px;
        margin-bottom: 15px;
        font-size: 1.1rem;
        display: inline-block;
        }

        .footer-col a:hover {
        color: #16a085;
        }

        .footer-bottom {
        text-align: center;
        padding-top: 15px;
        border-top: 1px solid rgba(255,255,255,0.2);
        font-size: 0.9rem;
        }

        /* ===============================
           Search Section
        ================================ */
        .search-container {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background: #e6fff7;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .search-inner {
            padding: 15px;
        }

        /* Loader Styling */
        .search-loader {
            display: none;
            margin-top: 15px;
        }

            .search-loader p {
                color: #555;
                font-size: 14px;
                margin-top: 8px;
            }

        /* Search Bar */
        .search-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            background: #f1f5f9;
            padding: 12px;
            border-radius: 50px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.1);
            flex-wrap: wrap; /* mobile friendly */
        }

            .search-bar input,
            .search-bar button {
                padding: 10px 14px;
                border: none;
                border-radius: 25px;
                font-size: 22px;
                font-weight: 400;
            }

            .search-bar input {
                background: #fff;
                border: 1px solid #ddd;
                width: 500px;
            }

            .search-bar button {
                background: #2c3e50;
                color: #fff;
                cursor: pointer;
                padding: 10px 20px;
            }

                .search-bar button:hover {
                    background: #e64a19;
                }

        /* Loader Spinner */
        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #ff5722;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            animation: spin 1s linear infinite;
            margin: auto;
        }

        @@keyframes spin {
            0%

        {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }

        }

        /* optional: small screens full width */
        @@media (max-width: 576px) {
            .search-bar input

        {
            width: 100%;
        }

        .search-bar {
            border-radius: 16px;
        }

        }

        /* ---------- Responsive ---------- */
        @@media (max-width: 992px) {
        .brand

        {
        flex-direction: column;
        text-align: center;
        }

        .card {
        flex: 1 1 calc(33.333% - 20px); /* 3 per row */
        }

        }

        @@media (max-width: 768px) {
        .nav-list

        {
        flex-direction: column;
        align-items: center;
        }

        .card {
        flex: 1 1 calc(50% - 20px); /* 2 per row */
        }

        }

        @@media (max-width: 480px) {
        .brand-title

        {
        font-size: 1.6rem;
        }

        .highlight-banner h2 {
        font-size: 1.3rem;
        }

        .card {
        flex: 1 1 100%; /* 1 per row */
        }

        }
    </style>
</head>
@{
    Layout = null;
}
<body>
    <!-- Header -->
    <header class="site-header">
        <div class="container">
            <div class="header-top">
                <div class="brand">
                    <div class="brand-text">
                        <div class="brand-title">ilmkidunya</div>
                    
                    </div>
                    <div class="brand-logos">
                        <img src="https://cdn.ilmkidunya.com/images/Banners/SZABIST-Top%20(1).gif" alt="SZABIST Banner" width="177" />
                        <img src="https://cdn.ilmkidunya.com/images/Banners/Superior%202.jpg" alt="Superior Banner" width="695" />
                    </div>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <ul class="nav-list">
                <li><a href="#"><i class="fas fa-home"></i> Home</a></li>
                <li><a href="#"><i class="fas fa-flag"></i> National</a></li>
                <li><a href="#"><i class="fas fa-globe"></i> International</a></li>
                <li><a href="#"><i class="fas fa-bullhorn"></i> Announcement</a></li>
                <li><a href="#"><i class="fas fa-list-ol"></i> Merit list</a></li>
                <li><a href="#"><i class="fas fa-calendar-alt"></i> Date Sheet</a></li>
                <li><a href="#"><i class="fas fa-chart-bar"></i> Result</a></li>
            </ul>
        </nav>
        <div class="highlight-banner">
            <div class="search-inner">
                <!-- Keyword-only search -->
                <form id="keywordSearchForm" class="search-bar" method="get">
                    <input type="text" name="keyword" placeholder="Search by keyword..." required />
                    <button type="submit">Search</button>
                </form>

                <div id="searchLoader" class="search-loader">
                    <div class="spinner"></div>
                    <p>Searching...</p>
                </div>
            </div>
        </div>
    </header>

    <!-- Main -->
    <main class="main-content container">
        <section class="news-section">
            <div class="col-lg-12">
                <div class="google-ad-bx ad-slot">

                    <!-- ikd25 -->
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-8866825487085085"
                         data-ad-slot="9990874736"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                    <script>
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    </script>

                </div>
            </div>
            <div id="newsResults"></div>
            <h2 class="section-title">Latest News</h2>
            <div class="card-grid">
                @if (Model?.LatestNews != null && Model.LatestNews.Any())
                {
                    foreach (var news in Model.LatestNews)
                    {
                        <article class="card">
                            <a href="/news/@news.RewriteUrl">
                                <img src="@news.PictureThumbnail" alt="@news.MainHeading" />
                            </a>
                            <div class="card-body">
                                <p>@news.Dated?.ToString("dd-MMM-yyyy")</p>
                                <h3>
                                    <a href="/news/@news.RewriteUrl">@news.MainHeading</a>
                                </h3>
                               
                            </div>
                        </article>
                    }
                }
                else
                {
                    <p>No news available right now.</p>
                }
            </div>
            <div class="col-lg-12">
                <div class="google-ad-bx ad-slot">

                    <!-- ikd25 -->
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client="ca-pub-8866825487085085"
                         data-ad-slot="9990874736"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                    <script>
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    </script>

                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-top">
                <div class="footer-col">
                    <h3>Contact Us</h3>
                    <p><i class="fas fa-map-marker-alt"></i> 123 Education Street, City</p>
                    <p><i class="fas fa-phone"></i> +92 123 4567890</p>
                    <p><i class="fas fa-envelope"></i> info@superior.edu.pk</p>
                </div>
                <div class="footer-col">
                    <h3>Quick Links</h3>
                    <p><a href="#">Programs Offered</a></p>
                    <p><a href="#">Fee Structure</a></p>
                    <p><a href="#">Campus Tour</a></p>
                </div>
                <div class="footer-col">
                    <h3>Follow Us</h3>
                    <p><a href="#"><i class="fab fa-facebook"></i> Facebook</a></p>
                    <p><a href="#"><i class="fab fa-twitter"></i> Twitter</a></p>
                    <p><a href="#"><i class="fab fa-instagram"></i> Instagram</a></p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 Superior University. All rights reserved.</p>
            </div>
        </div>
    </footer>
</body>
</html>
<script>
    document.getElementById("keywordSearchForm").addEventListener("submit", function (e) {
        e.preventDefault();
        const keyword = this.keyword.value;

        // show loader
        document.getElementById("searchLoader").style.display = "block";
        document.getElementById("newsResults").innerHTML = "";

        fetch(`/news/search?keyword=${encodeURIComponent(keyword)}`)
            .then(res => res.text())
            .then(html => {
                document.getElementById("newsResults").innerHTML = html;
                document.getElementById("searchLoader").style.display = "none"; // hide loader
            })
            .catch(err => {
                document.getElementById("newsResults").innerHTML = "<p style='color:red;'>Error loading results.</p>";
                document.getElementById("searchLoader").style.display = "none"; // hide loader
            });
    });
</script>