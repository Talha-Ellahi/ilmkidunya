                                </a>
                            </li>
                            <li>
                                <a href="/dictionary/urdu-to-english-dictionary">
                                    <span>
                                        Urdu To English Dictionary
                                    </span>
                                </a>
                            </li>

                            <li>
                                <a href="/dictionary/urdu-to-hindi-dictionary">
                                    <span>
                                        Urdu To Hindi Dictionary
                                    </span>
                                </a>
                            </li>
                            <li>
                                <a href="/dictionary/english-to-urdu-translator">
                                    <span>
                                        Translate English To Urdu
                                    </span>
                                </a>
                            </li>
                            <li>
                                <a href="/dictionary/urdu-to-english-translator">
                                    <span>
                                        Translate Urdu To English
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="content-sec level fee-box" style="margin: 0px 0px 30px; padding-top: 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>@Model.Word Meaning In @Model.CompleteLanguage with Detail</h2>
                    <p id="description">
                        @if (!string.IsNullOrEmpty(Model.ExistingDescription))
                        {
                            @Html.Raw(Model.ExistingDescription)
                        }
                        else
                        {
                            <text>Loading...</text>
                        }
                    </p>
                </div>
                @await Html.PartialAsync("_GoogleAd")
            </div>
        </div>
    </div>
</div>


<script>
    // Global variables
    let currentWord = '@Model.Word';
    let currentLanguage = '@Model.CurrentLanguage';
    let translatedLanguage = '@Model.TranslatedLanguageCode';
    let SecondlanguageName = '@Model.TranslatedLanguage'
    let englishWord = '';
    let selectedLanguageMain = '';
    let selectedLanguageHeader = '';
    let hasExistingData = @Json.Serialize(Model.HasExistingData);

    // Track what data we need to fetch
    let needsDefinition = true;
    let needsSynonyms = true;
    let needsAntonyms = true;
    let needsDescription = true;

    // Initialize when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadWordData();
        if(translatedLanguage != currentLanguage){
            initializeHeaderCustomSelect();
        }
        initializeHeaderCustomSelect();
    });

    async function loadWordData() {
        try {
            // Step 1: Get translation
            await getTranslation();

            // Step 2: Check what data we already have
            await checkExistingDataSeparately();

            // Step 3: Get missing data from APIs
            await fetchMissingData();

        } catch (error) {
            console.error('Error loading word data:', error);
            document.getElementById('translatedText').textContent = 'Error loading translation';
        }
    }


    function initializeHeaderCustomSelect() {
        const customSelectHeader = document.getElementById('customSelectSearch');
        const customOptionsHeader = customSelectHeader.nextElementSibling; // The .custom-options div right after customSelectSearch
        const optionSearchHeader = document.getElementById('optionSearchHeader');
        const optionsHeader = customOptionsHeader.querySelectorAll('span[data-value]');
        const selectedSpanHeader = customSelectHeader.querySelector('.selected');
        const searchBtnHeader = document.getElementById('searchBtnHeader');
        const wordInputHeader = document.querySelector('.ss-banner-inner .banner-form input[type="text"]');
        const customSelectWrapperHeader = customSelectHeader.parentElement;

        console.log('Initializing header search bar:', { customSelectHeader, customOptionsHeader, optionSearchHeader, options: optionsHeader.length });

        // Toggle dropdown using CSS classes
        customSelectHeader.addEventListener('click', function(e) {
            e.stopPropagation();
            customSelectWrapperHeader.classList.toggle('active');
            customOptionsHeader.classList.toggle('active');

                @* if (customOptionsHeader.classList.contains('active')) {
          optionSearchHeader.focus();
        } *@
        });

        // Handle option selection
        optionsHeader.forEach(option => {
            option.addEventListener('click', function() {
                selectedLanguageHeader = this.getAttribute('data-value');
                const languageName = this.textContent;
                selectedSpanHeader.textContent = languageName;

                // Close dropdown
                customSelectWrapperHeader.classList.remove('active');
                customOptionsHeader.classList.remove('active');

                console.log('Header search bar selected:', selectedLanguageHeader);
            });
        });

        // Search filter functionality
        optionSearchHeader.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            let hasVisibleOptions = false;

            optionsHeader.forEach(option => {
                const text = option.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    option.style.display = 'block';
                    hasVisibleOptions = true;
                } else {
                    option.style.display = 'none';
                }
            });

            // Show a message if no options match
            const noResults = customOptionsHeader.querySelector('.no-results');
            if (!hasVisibleOptions && !noResults) {
                const noResultsMsg = document.createElement('div');
                noResultsMsg.className = 'no-results';
                noResultsMsg.textContent = 'No languages found';
                noResultsMsg.style.padding = '10px 15px';
                noResultsMsg.style.color = '#666';
                noResultsMsg.style.fontStyle = 'italic';
                customOptionsHeader.appendChild(noResultsMsg);
            } else if (hasVisibleOptions && noResults) {
                noResults.remove();
            }
        });

        // Search button functionality - requires new word
        searchBtnHeader.addEventListener('click', function() {
            performHeaderSearch();
        });

        // Allow Enter key to trigger search in both search box and word input
        optionSearchHeader.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performHeaderSearch();
            }
        });

        wordInputHeader.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performHeaderSearch();
            }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function() {
            customSelectWrapperHeader.classList.remove('active');
            customOptionsHeader.classList.remove('active');
        });
    }

    // Check each data type separately
    async function checkExistingDataSeparately() {
        // Use proper null checking with JSON serialization
        const existingDefinition = @Html.Raw(Json.Serialize(Model.ExistingDefinition)) || '';
        const existingSynonyms = @Html.Raw(Json.Serialize(Model.ExistingSynonyms)) || '';
        const existingAntonyms = @Html.Raw(Json.Serialize(Model.ExistingAntonyms)) || '';
        const existingDescription = @Html.Raw(Json.Serialize(Model.ExistingDescription)) || '';

        console.log('🔍 Checking existing data separately...');
        console.log('Existing synonyms:', existingSynonyms);
        console.log('Existing antonyms:', existingAntonyms);

        // Check definition
        if (existingDefinition && existingDefinition.trim() !== '' && existingDefinition !== 'null') {
            console.log('✅ Using existing definition from database');
            const definitionsList = document.getElementById('definitionsList');
            const partOfSpeech = '@Html.Raw(Model.ExistingPartOfSpeech)' || '';

            if (!definitionsList.innerHTML.trim()) {
                definitionsList.innerHTML = `<p><em>${partOfSpeech}</em>. ${existingDefinition}</p>`;
            }
            document.getElementById('definitionsSection').style.display = 'block';
            needsDefinition = false;
        } else {
            console.log('❌ Definition not found in database');
            needsDefinition = true;
        }

        // Check synonyms - FIXED: Proper null/empty string checking
        if (existingSynonyms && existingSynonyms.trim() !== '' && existingSynonyms !== 'null' && existingSynonyms !== '[]') {
            console.log('✅ Using existing synonyms from database');
            const synonymsList = document.getElementById('synonymsList');
            const synonymsArray = existingSynonyms.split(',').map(s => s.trim()).filter(s => s && s !== 'null' && s.trim() !== '');

            if (synonymsArray.length > 0) {
                // Clear existing content if any
                synonymsList.innerHTML = '';

                synonymsArray.slice(0, 20).forEach(syn => {
                    if (syn && syn.trim() !== '') {
                        const link = document.createElement('a');
                        link.href = `/dictionary/${syn.replace(/\s+/g, "-")}-meaning-in-${SecondlanguageName}`;
                        link.textContent = syn;
                        synonymsList.appendChild(link);
                    }
                });

                if (synonymsList.children.length > 0) {
                    document.getElementById('synonymsSection').style.display = 'block';
                    document.getElementById('synonymsTitle').textContent = `Synonyms For ${currentWord}, Words Similar to ${currentWord}`;
                    needsSynonyms = false;
                } else {
                    console.log('❌ Synonyms array is empty after filtering');
                    needsSynonyms = true;
                }
            } else {
                console.log('❌ No valid synonyms found in database');
                needsSynonyms = true;
            }
        } else {
            console.log('❌ Synonyms not found in database');
            needsSynonyms = true;
        }

        // Check antonyms - FIXED: Proper null/empty string checking
        if (existingAntonyms && existingAntonyms.trim() !== '' && existingAntonyms !== 'null' && existingAntonyms !== '[]') {
            console.log('✅ Using existing antonyms from database');
            const antonymsList = document.getElementById('antonymsList');
            const antonymsArray = existingAntonyms.split(',').map(a => a.trim()).filter(a => a && a !== 'null' && a.trim() !== '');

            if (antonymsArray.length > 0) {
                // Clear existing content if any
                antonymsList.innerHTML = '';

                antonymsArray.slice(0, 20).forEach(ant => {
                    if (ant && ant.trim() !== '') {
                        const link = document.createElement('a');
                        link.href = `/dictionary/${ant.replace(/\s+/g, "-")}-meaning-in-${SecondlanguageName}`;
                        link.textContent = ant;
                        antonymsList.appendChild(link);
                    }
                });

                if (antonymsList.children.length > 0) {
                    document.getElementById('antonymsSection').style.display = 'block';
                    document.getElementById('antonymsTitle').textContent = `Antonyms For ${currentWord}, Words Opposite to ${currentWord}`;
                    needsAntonyms = false;
                } else {
                    console.log('❌ Antonyms array is empty after filtering');
                    needsAntonyms = true;
                }
            } else {
                console.log('❌ No valid antonyms found in database');
                needsAntonyms = true;
            }
        } else {
            console.log('❌ Antonyms not found in database');
            needsAntonyms = true;
        }

        // Check description
        if (existingDescription && existingDescription.trim() !== '' && existingDescription !== 'null') {
            console.log('✅ Using existing description from database');
            const descriptionElement = document.getElementById('description');
            if (descriptionElement.textContent.includes('Loading...') || descriptionElement.innerHTML.includes('Loading...')) {
                descriptionElement.innerHTML = existingDescription;
            }
            needsDescription = false;
        } else {
            console.log('❌ Description not found in database');
            needsDescription = true;
        }

        console.log(`📊 Data needs: Definition=${needsDefinition}, Synonyms=${needsSynonyms}, Antonyms=${needsAntonyms}, Description=${needsDescription}`);
    }

    // Fetch only the missing data
    async function fetchMissingData() {
        if (!englishWord) {
            console.log('No English word available, skipping API calls');
            return;
        }

        const hasMissingData = needsDefinition || needsSynonyms || needsAntonyms || needsDescription;

        if (!hasMissingData) {
            console.log('🎉 All data already exists in database, no API calls needed');
            return;
        }

        console.log('🔄 Fetching missing data from APIs...');

        // Fetch dictionary data if needed
        if (needsDefinition || needsSynonyms || needsAntonyms) {
            console.log('📚 Fetching dictionary data...');
            await getDictionaryDetails();
        }

        // Fetch description if needed
        if (needsDescription) {
            console.log('🌐 Fetching DBPedia description...');
            await getDbPediaDescription();
        }

        console.log('✅ All missing data fetched successfully');
    }

    async function getTranslation() {
        // Check if we already have an existing meaning from the server
        const existingMeaning = '@Html.Raw(Model.ExistingMeaning)';
        if (existingMeaning && existingMeaning.trim() !== '' && existingMeaning !== 'null') {
            console.log('✅ Using existing meaning from database:', existingMeaning);
            document.getElementById('translatedText').textContent = existingMeaning;

            if (currentLanguage === 'en-gb') {
                englishWord = currentWord.toLowerCase();
            } else if (translatedLanguage !== 'en-gb') {
                await getEnglishTranslation(existingMeaning);
            } else {
                englishWord = existingMeaning.toLowerCase();
            }
            return;
        }

        console.log('🌐 No existing meaning found, calling translation API...');

        // First translation using Google Translate API
        let translationUrl = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${currentLanguage}&tl=${translatedLanguage}&dt=t&q=${encodeURIComponent(currentWord)}`;

        try {
            let response = await fetch(translationUrl);
            let data = await response.json();

            let translatedText = '';
            if (data && data[0] && data[0][0] && data[0][0][0]) {
                translatedText = data[0][0][0];

                // Save the main translation to database
                if (translatedText && translatedText !== currentWord) {
                    await saveWordAndMeaning(currentWord, currentLanguage, translatedText, translatedLanguage);
                }
            }

            if (currentLanguage != translatedLanguage) {
                document.getElementById('translatedText').textContent = translatedText || 'Translation not available';
            }

            // Determine English word
            if (currentLanguage === 'en-gb') {
                englishWord = currentWord.toLowerCase();
            } else if (translatedLanguage !== 'en-gb') {
                await getEnglishTranslation(translatedText);
            } else {
                englishWord = translatedText;
            }
        } catch (error) {
            console.error('Translation error:', error);
            document.getElementById('translatedText').textContent = 'Translation failed';
            englishWord = currentWord.toLowerCase();
        }
    }

    // Helper function to get English translation
    async function getEnglishTranslation(translatedText) {
        const translationUrl = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${translatedLanguage}&tl=en-gb&dt=t&q=${encodeURIComponent(translatedText)}`;
        const response = await fetch(translationUrl);
        const data = await response.json();

        if (data && data[0] && data[0][0] && data[0][0][0]) {
            englishWord = data[0][0][0].toLowerCase();

            if (englishWord && englishWord !== translatedText) {
                await saveWordAndMeaning(translatedText, translatedLanguage, englishWord, 'en');
            }
        } else {
            englishWord = translatedText;
        }
    }

    // Updated getDictionaryDetails to only fetch missing data
    async function getDictionaryDetails() {
        if (!englishWord) return;

        // Only proceed if we need dictionary data
        if (!needsDefinition && !needsSynonyms && !needsAntonyms) {
            console.log('✅ All dictionary data already available, skipping API call');
            return;
        }

        console.log(`📚 Fetching dictionary details for: ${englishWord}`);
        console.log(`🔍 Needed: Definition=${needsDefinition}, Synonyms=${needsSynonyms}, Antonyms=${needsAntonyms}`);

        try {
            let cleanWord = englishWord.split(' ')[0].replace(/[^a-zA-Z]/g, '').toLowerCase();
            if (!cleanWord) return;

            // Use Free Dictionary API
            const dictionaryUrl = `https://api.dictionaryapi.dev/api/v2/entries/en/${cleanWord}`;

            try {
                const response = await fetch(dictionaryUrl);
                if (!response.ok) {
                    throw new Error('Dictionary API not available');
                }

                const data = await response.json();
                console.log('Dictionary API response:', data);

                // Process the dictionary data
                await processDictionaryData(data, cleanWord);

            } catch (apiError) {
                console.error('Dictionary API error:', apiError);
                // Fallback to other methods if needed
                await fallbackDictionaryLookup(cleanWord);
            }

        } catch (error) {
            console.error('Error fetching dictionary details:', error);
            // Only show error if we don't have existing data
            if (needsDefinition) {
                document.getElementById('definitionsSection').style.display = 'block';
                document.getElementById('definitionsList').innerHTML = '<p>No dictionary definitions found.</p>';
            }
        }
    }

    // Process dictionary API response - only update what's needed
    async function processDictionaryData(data, cleanWord) {
        if (!data || data.length === 0) {
            console.log('No dictionary data found from API');
            // Show empty state messages for missing data
            if (needsDefinition) {
                document.getElementById('definitionsSection').style.display = 'block';
                document.getElementById('definitionsList').innerHTML = '<p>No definition found.</p>';
            }
            return;
        }

        const wordData = data[0];
        let definition = '';
        let partOfSpeech = '';
        let synonyms = [];
        let antonyms = [];
        let example = '';

        // Extract data from the first meaning
        if (wordData.meanings && wordData.meanings.length > 0) {
            const firstMeaning = wordData.meanings[0];
            partOfSpeech = firstMeaning.partOfSpeech || '';

            // Get the first definition and example
            if (firstMeaning.definitions && firstMeaning.definitions.length > 0) {
                definition = firstMeaning.definitions[0].definition || '';
                example = firstMeaning.definitions[0].example || '';
            }

            // Collect all synonyms and antonyms from all meanings
            wordData.meanings.forEach(meaning => {
                if (meaning.synonyms && Array.isArray(meaning.synonyms)) {
                    const validSynonyms = meaning.synonyms.filter(s => s && s.trim() !== '');
                    synonyms = [...synonyms, ...validSynonyms];
                }
                if (meaning.antonyms && Array.isArray(meaning.antonyms)) {
                    const validAntonyms = meaning.antonyms.filter(a => a && a.trim() !== '');
                    antonyms = [...antonyms, ...validAntonyms];
                }
            });

            // Remove duplicates
            synonyms = [...new Set(synonyms)];
            antonyms = [...new Set(antonyms)];
        }

        console.log('Extracted from API:', {
            definition: definition,
            synonymsCount: synonyms.length,
            antonymsCount: antonyms.length
        });

        // Update UI only for missing data
        if (needsDefinition) {
            if (definition) {
                updateDefinitionUI(definition, partOfSpeech);
            } else {
                // Show message if no definition found
                document.getElementById('definitionsSection').style.display = 'block';
                document.getElementById('definitionsList').innerHTML = '<p>No definition found.</p>';
            }
        }

        if (needsSynonyms) {
            if (synonyms.length > 0) {
                updateSynonymsUI(synonyms);
            } else {
                // Don't show synonyms section if no synonyms found
                console.log('No synonyms found from API');
                // Optionally, you can show a message:
                // document.getElementById('synonymsSection').style.display = 'block';
                // document.getElementById('synonymsList').innerHTML = '<p>No synonyms found.</p>';
            }
        }

        if (needsAntonyms) {
            if (antonyms.length > 0) {
                updateAntonymsUI(antonyms);
            } else {
                // Don't show antonyms section if no antonyms found
                console.log('No antonyms found from API');
                // Optionally, you can show a message:
                // document.getElementById('antonymsSection').style.display = 'block';
                // document.getElementById('antonymsList').innerHTML = '<p>No antonyms found.</p>';
            }
        }

        // Save only the data we fetched to database
        await saveCompleteWordData(cleanWord, definition, partOfSpeech, synonyms, antonyms, example);
    }

    // Update definition in UI
    function updateDefinitionUI(definition, partOfSpeech) {
        const definitionsList = document.getElementById('definitionsList');
        const definitionsSection = document.getElementById('definitionsSection');

        if (definition && !definitionsList.innerHTML.includes(definition)) {
            definitionsList.innerHTML = `<p><em>${partOfSpeech}</em>. ${definition}</p>`;
            definitionsSection.style.display = 'block';
            console.log('✅ Definition updated in UI');
        }
    }

    // Update synonyms in UI
    function updateSynonymsUI(synonyms) {
        const synonymsList = document.getElementById('synonymsList');
        const synonymsSection = document.getElementById('synonymsSection');

        // Filter out any null or empty synonyms
        const validSynonyms = synonyms.filter(syn => syn && syn.trim() !== '');

        if (validSynonyms.length > 0) {
            // Clear existing content
            synonymsList.innerHTML = '';

            validSynonyms.slice(0, 20).forEach(syn => {
                const link = document.createElement('a');
                link.href = `/dictionary/${syn.replace(/\s+/g, "-")}-meaning-in-${SecondlanguageName}`;
                link.textContent = syn;
                synonymsList.appendChild(link);
            });

            synonymsSection.style.display = 'block';
            document.getElementById('synonymsTitle').textContent = `Synonyms For ${currentWord}, Words Similar to ${currentWord}`;
            console.log('✅ Synonyms updated in UI');
        } else {
            console.log('No valid synonyms to display');
            // Optionally hide the section or show a message
            // synonymsSection.style.display = 'none';
        }
    }

    // Update antonyms in UI
    function updateAntonymsUI(antonyms) {
        const antonymsList = document.getElementById('antonymsList');
        const antonymsSection = document.getElementById('antonymsSection');

        // Filter out any null or empty antonyms
        const validAntonyms = antonyms.filter(ant => ant && ant.trim() !== '');

        if (validAntonyms.length > 0) {
            // Clear existing content
            antonymsList.innerHTML = '';

            validAntonyms.slice(0, 20).forEach(ant => {
                const link = document.createElement('a');
                link.href = `/dictionary/${ant.replace(/\s+/g, "-")}-meaning-in-${SecondlanguageName}`;
                link.textContent = ant;
                antonymsList.appendChild(link);
            });

            antonymsSection.style.display = 'block';
            document.getElementById('antonymsTitle').textContent = `Antonyms For ${currentWord}, Words Opposite to ${currentWord}`;
            console.log('✅ Antonyms updated in UI');
        } else {
            console.log('No valid antonyms to display');
            // Optionally hide the section or show a message
            // antonymsSection.style.display = 'none';
        }
    }

    // Save complete word data using the UpdateCompleteWordData method
    async function saveCompleteWordData(cleanWord, definition, partOfSpeech, synonyms, antonyms, example) {
        try {
            // Filter out empty strings from arrays
            const validSynonyms = synonyms.filter(s => s && s.trim() !== '');
            const validAntonyms = antonyms.filter(a => a && a.trim() !== '');

            const synonymsText = validSynonyms.length > 0 ? validSynonyms.join(', ') : null;
            const antonymsText = validAntonyms.length > 0 ? validAntonyms.join(', ') : null;

            // Only send data that we actually fetched
            const requestData = {
                word: cleanWord,
                languageCode: 'en'
            };

            // Only include fields that we have new data for
            if (needsDefinition && definition) requestData.definition = definition;
            if (needsDefinition && partOfSpeech) requestData.partOfSpeech = partOfSpeech;
            if (needsSynonyms && synonymsText) requestData.synonyms = synonymsText;
            if (needsAntonyms && antonymsText) requestData.antonyms = antonymsText;
            if (example) requestData.example = example;

            console.log('💾 Saving dictionary data to database:', requestData);

            // Only send request if we have actual data to save
            if (Object.keys(requestData).length > 2) { // More than just word and languageCode
                const response = await fetch('/dictionary/update-complete-word-data', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestData)
                });

                if (response.ok) {
                    console.log('✅ Dictionary data saved successfully to database');
                    const result = await response.json();
                    console.log('Save result:', result);
                } else {
                    console.error('❌ Failed to save dictionary data');
                    const errorText = await response.text();
                    console.error('Error response:', errorText);
                }
            } else {
                console.log('📭 No new dictionary data to save');
            }
        } catch (error) {
            console.error('❌ Error saving dictionary data:', error);
        }
    }

