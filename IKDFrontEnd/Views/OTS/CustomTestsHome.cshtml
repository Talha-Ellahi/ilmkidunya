@model List<IKDFrontEnd.ViewModels.TestListItemViewModel>


@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
 @section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
	<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
	<meta property="og:image" content="" />
	<meta name="description" content="@ViewBag.CmsData.MetaDesc">
	<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	
	<title>@ViewBag.CmsData.MetaTitle</title>
}
@section header {
	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						 @if (ViewBag.CmsData.Heading != null)
						{
							<h1>@ViewBag.CmsData.Heading</h1>
						}
					</div>
				</div>
			</div>
		</div>
	</div>
}

<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(ViewBag.CmsData.Desc1)


				</div>
			</div>
		</div>
	</div>

	<div class="contact-sec level fee-box">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					
                        @if ( @ViewBag.SubjectName != null)
                        {
							<h2> Online Quiz for @ViewBag.SubjectName</h2>
                        }
						
					
					<ul class="sports-list">
						@foreach (var test in Model ?? Enumerable.Empty<dynamic>())
						{
							if (test != null)
							{
								<li>
									<a href="/online-test/@(test?.Url ?? "#")">
										<figure>
											<span>@(test?.AttemptedCount?.ToString() ?? "0") attempted</span>
											<img src="https://cdn.ilmkidunya.com/ots/specialtestthumb/@(test?.ImageName ?? "no-image.jpg")" alt="" />
											<figcaption>@((test?.TestName ?? "N/A").Replace("Online", ""))</figcaption>
										</figure>
									</a>
								</li>
							}
						}

					</ul>
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>

	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(ViewBag.CmsData.Desc2)


				</div>
			</div>
		</div>
	</div>
	<div class="g-add-sec" style="padding: 30px 0 0 0;">
		<div class="container">
			<div class="row">
				@await Html.PartialAsync("_GoogleAd")
			</div>
		</div>
	</div>
	

	

</div>
