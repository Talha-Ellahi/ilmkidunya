@model IKDFrontEnd.ViewModels.DateSheetCriteria
@using System.Text.RegularExpressions

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
	.result-update-alert {
		background: #f3f3f3;
		border-radius: 10px;
		padding: 25px 30px;
		max-width: 1200px;
		margin: 0 auto;
		box-shadow: 0 0 5px rgba(0,0,0,0.05);
	}

	.alert-wrapper {
		display: flex;
		align-items: center;
		margin-bottom: 20px;
	}

	.alert-figue img {
		width: 60px;
		height: 60px;
		margin-right: 15px;
	}

	.alert-content h4 {
		font-size: 18px;
		margin: 0;
		color: #333;
	}

	.alert-content p {
		margin: 5px 0 0;
		font-size: 14px;
		color: #777;
	}

	.alert-form {
		display: flex;
		flex-wrap: wrap;
		gap: 15px;
	}

	.half-box {
		width: calc(50% - 7.5px); /* two inputs per row with 15px gap */
	}

	.alert-input {
		width: 100%;
		padding: 12px 15px;
		border: none;
		border-radius: 6px;
		font-size: 14px;
		background: #fff;
		box-shadow: inset 0 0 0 1px #ccc;
		transition: box-shadow 0.3s ease;
	}

		.alert-input:focus {
			outline: none;
			box-shadow: inset 0 0 0 2px #36a3f2;
		}

	.btn-subscribe {
		width: 100%;
		padding: 12px;
		background-color: #3498db;
		color: #fff;
		border: none;
		border-radius: 6px;
		font-size: 14px;
		font-weight: bold;
		cursor: pointer;
		transition: background-color 0.3s ease;
	}

		.btn-subscribe:hover {
			background-color: #2c80b4;
		}

</style>

@section MetaData {
	@{
		var metaTitle = Model?.MetaTitle ?? "";
		var metaDescription = Model?.MetaDescription ?? "";
		var metaKeywords = Model?.MetaKeywords ?? "";
	}

	<meta charset="utf-8">
	<meta property="og:title" content="@metaTitle" />
	<meta property="og:description" content="@metaDescription" />
	<meta property="og:image" content="" />
	<meta name="description" content="@metaDescription">
	<meta name="keywords" content="@metaKeywords">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>@metaTitle</title>
}

