@model IKDFrontEnd.ViewModels.GuideDetailViewModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css-files/style/studyabroad.css" rel="stylesheet" async>
@section MetaData {
	@{
	var metaTitle = Model?.MetaTitle ?? "";
	var metaDescription = Model?.MetaDesc ?? "";
	var metaKeywords = Model?.MetaKeyword ?? "";
}
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta property="og:title" content="@metaTitle" />
		<meta property="og:description" content="@metaDescription" />
		<meta property="og:image" content="" />
		<meta name="description" content="@metaDescription">
		<meta name="keywords" content="@metaKeywords">
		<meta name="viewport" content="width=device-width, initial-scale=1">

		<title>@metaTitle</title>
}
@section header {

	<div class="col-lg-11">

		<ul class="navigation">
			<li>
				<a aria-label="link" href="/studyabroad/">
					<img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
					Home
				</a>
			</li>


			<li>
				<a aria-label="link" href="/studyabroad/country-guides.aspx">
					<img src="https://resources.ilmkidunya.com/ikd-guides/assets/images/icons/adm-icon.png"
						 alt="image" />
					Guides
				</a>
			</li>
			<li>
				<a aria-label="link" href="/consultants/">
					<img src="https://www.ilmkidunya.com/icons/tutor.png"
						 alt="image" />
					Consultants
				</a>
			</li>
			<li>
				<a aria-label="link" href="/scholarships/topscholarship">
					<img src="https://ikddata.ilmkidunya.com/icons/ic-courses-nav-colleges-2.png"
						 alt="image" />
					Top Scholarship
				</a>
			</li>
		</ul>


	</div>

}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					@{
						var country = ViewBag?.Country;
						var countryImage = country?.ImageUrl ?? "default.png"; 
						var countryName = country?.CountryName ?? "Unknown Country";
					}

					<div class="study-abroad-hero">
						<div class="study-abbxes">
							<div class="imgholder">
								<img src="https://ikddata.ilmkidunya.com/images/flags/@countryImage" alt="country-logo">
							</div>
							<h1>Study in @countryName Guide</h1>
						</div>
						<div class="study-abbxes">
							<div class="inner-flag-box">
								<div class="flag-image-section">
									<img src="https://ikddata.ilmkidunya.com/images/flags/pak-flag.png" alt="flag">
									<span>→</span>
									<img src="https://ikddata.ilmkidunya.com/images/flags/@countryImage" alt="flag">
								</div>
								<p>Want to go to @countryName for higher studies?</p>
								<a href="#" id="submitInquiryBtn" class="std-btn">Submit Inquiry</a>
								<div id="inquiryMessage" style="display:none; color: red; margin-top: 10px; font-weight: bold;">
									This service is not available at this time.
								</div>
							</div>
						</div>
					</div>


				</div>
			</div>
		</div>
	</div>
}

<div id="main">

	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if (Model?.Detail != null)
					{
						@Html.RenderWithAds(Model.Detail.Replace("https://www.ilmkidunya.com", ""))
					}

				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if (Model?.Detail2 != null)
					{
						@Html.RenderWithAds(Model.Detail2.Replace("https://www.ilmkidunya.com", ""))
					}


				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding:0 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
				</div>
			</div>
		</div>
	</div>
	
	
	


</div>


<script>
	document.addEventListener("DOMContentLoaded", function () {
		var btn = document.getElementById("submitInquiryBtn");
		var msg = document.getElementById("inquiryMessage");

		btn.addEventListener("click", function (e) {
			e.preventDefault();
			msg.style.display = "block";

			// Hide after 5 seconds
			setTimeout(function () {
				msg.style.display = "none";
			}, 2000);
		});
	});
		document.addEventListener("DOMContentLoaded", function () {
		document.querySelectorAll('a[href="#"], a[href="/#"]').forEach(a => {
			a.setAttribute("href", "javascript:void(0);");
		});
	});
</script>
