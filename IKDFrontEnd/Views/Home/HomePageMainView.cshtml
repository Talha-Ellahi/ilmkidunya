<script>
	function LoadBackEnd() {
		const location = document.getElementById('ddlCity').value;
		const level = document.getElementById('ddlLevel').value;
		const category = document.getElementById('catUlList').value;

		// Build query string
		let query = [];

		if (location && location != -1)
			query.push(`location=${location}`);
		if (level && level != -1)
			query.push(`level=${level}`);
		if (category && category != -1)
			query.push(`category=${category}`);

		if (query.length === 0) {
			alert("Please select at least one filter.");
			return false;
		}

		// Redirect to courses home page with query params
		const url = `/courses?${query.join("&")}`;
		window.location.href = url;

		return false; // Prevent form submission
	}
</script>