    <script>
        const questionSets = {};
        @foreach (var set in Model.QuestionSets)
        {
                var safeSetName = set.SetName.Replace(" ", "_");
                <text>
                questionSets['@safeSetName'] = {
                    setName: '@set.SetName',
                    safeName: '@safeSetName',
                    totalQuestions: @set.TotalQuestions,
                    questions: [
                        @foreach (var question in set.Questions)
                        {
                                <text>
                                {
                                    questionId: '@question.QuestionId',
                                    questionDescription: `@Html.Raw(question.QuestionDescription)`,
                                    answers: [
                                        @foreach (var answer in question.Answers)
                                        {
                                                <text>
                                                {
                                                    choiceDescription: `@Html.Raw(answer.ChoiceDescription)`,
                                                },
                                                </text>
                                        }
                                    ]
                                },
                                </text>
                        }
                    ]
                };
                </text>
        }

        // State per test set
        const state = {};

        window.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.launch-test-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const set = btn.dataset.set;
                    launchSpecificSet(set);
                });
            });

            document.querySelectorAll('.close-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const set = btn.dataset.set;
                    closePoll(set);
                });
            });
        });

        // Close all open polls
        function closeAllPolls() {
            document.querySelectorAll('.question-side').forEach(pol => {
                pol.style.right = '-100%';
                pol.style.opacity = '0';
                pol.style.visibility = 'hidden';
            });

            // stop timers for all sets
            Object.keys(state).forEach(set => {
                if (state[set]?.timer) {
                    resetTimer(set);
                }
            });
        }

        function closePoll(set) {
            const pol = document.getElementById('pol-' + set);
            pol.style.right = '-100%';
            pol.style.opacity = '0';
            pol.style.visibility = 'hidden';

            if (state[set]?.timer) {
                resetTimer(set);
            }
        }

        function launchSpecificSet(set) {
            const qSet = questionSets[set];

            // Close any previously open poll before opening new one
            closeAllPolls();

            state[set] = {
                questions: qSet.questions,
                currentIndex: 0,
                elapsedTime: 0,
                isRunning: false,
                timer: null
            };

            // Load questions
            loadQuestions(set);

            // Show panel
            const pol = document.getElementById('pol-' + set);
            pol.style.right = '0';
            pol.style.opacity = '1';
            pol.style.visibility = 'visible';

            resetTimer(set);
            startTimer(set);
            initNavigation(set);
        }

        function loadQuestions(set) {
            const container = document.getElementById('questions-container-' + set);
            container.innerHTML = '';

            const questions = state[set].questions;
            questions.forEach((question, i) => {
                const questionElement = document.createElement('div');
                questionElement.className = 'mid-box';
                questionElement.dataset.questionNumber = i + 1;
                questionElement.style.display = i === 0 ? 'block' : 'none';
                questionElement.style.opacity = i === 0 ? '1' : '0';

                let answersHtml = '';
                question.answers.forEach((answer, j) => {
                    const letter = String.fromCharCode(65 + j);
                    answersHtml += `
                        <li>
                            <label class="radio-container d-flex align-items-start">
                                <span class="q-detiel">${answer.choiceDescription}</span>
                                <input type="radio" name="radio-${set}-${i}" value="${letter}" data-question-id="${question.questionId}" data-correct="${answer.isCorrect}">
                                <span class="label">${letter}</span>
                                <span class="checkmark"></span>
                            </label>
                        </li>`;
                });

                questionElement.innerHTML = `
                    <strong>Question # ${i + 1}</strong>
                    <h3>${question.questionDescription}</h3>
                    <ul>${answersHtml}</ul>
                `;

                container.appendChild(questionElement);
            });
        }

        function initNavigation(set) {
            const prevBtn = document.querySelector(`.prev[data-set="${set}"]`);
            const nextBtn = document.querySelector(`.next[data-set="${set}"]`);
            const resultBtn = document.querySelector(`.get-result[data-set="${set}"]`);

            prevBtn.onclick = (e) => {
                e.preventDefault();
                if (state[set].currentIndex > 0) {
                    state[set].currentIndex--;
                    showQuestion(set, state[set].currentIndex);
                }
            };

            nextBtn.onclick = (e) => {
                e.preventDefault();
                if (state[set].currentIndex < state[set].questions.length - 1) {
                    state[set].currentIndex++;
                    showQuestion(set, state[set].currentIndex);
                }
            };

            resultBtn.onclick = (e) => {
                e.preventDefault();
                calculateResults(set);
            };
        }

        function showQuestion(set, index) {
            const questions = document.querySelectorAll(`#questions-container-${set} .mid-box`);
            questions.forEach((box, i) => {
                if (i === index) {
                    box.style.display = 'block';
                    setTimeout(() => box.style.opacity = '1', 200);
                } else {
                    box.style.opacity = '0';
                    setTimeout(() => box.style.display = 'none', 300);
                }
            });
        }

        function startTimer(set) {
            if (!state[set].isRunning) {
                state[set].startTime = Date.now() - state[set].elapsedTime;
                state[set].timer = setInterval(() => {
                    state[set].elapsedTime = Date.now() - state[set].startTime;
                    const totalSeconds = Math.floor(state[set].elapsedTime / 1000);
                    const minutes = String(Math.floor(totalSeconds / 60)).padStart(2, '0');
                    const seconds = String(totalSeconds % 60).padStart(2, '0');
                    document.getElementById('display-' + set).textContent = `${minutes}:${seconds}`;
                }, 1000);
                state[set].isRunning = true;
            }
        }

        function resetTimer(set) {
            clearInterval(state[set].timer);
            state[set].elapsedTime = 0;
            document.getElementById('display-' + set).textContent = '00:00';
            state[set].isRunning = false;
        }

        function calculateResults(set) {
            const questions = state[set].questions;
            const container = document.querySelector(`#questions-container-${set}`);
            const boxes = container.querySelectorAll('.mid-box');
            let resultHTML = '';
            let correctCount = 0;

            boxes.forEach((box, idx) => {
                const questionText = box.querySelector('h3').innerHTML;
                const inputs = box.querySelectorAll('input[type="radio"]');
                const selected = box.querySelector('input[type="radio"]:checked');
                const selectedVal = selected ? selected.value : null;

                let correctAnswer = null;
                inputs.forEach(input => {
                    if (input.dataset.correct === 'true') correctAnswer = input.value;
                });

                const isCorrect = selectedVal === correctAnswer;
                if (isCorrect) correctCount++;

                let optionsHTML = '';
                inputs.forEach(input => {
                    const label = input.value;
                    const optionText = input.closest('label').querySelector('.q-detiel').innerHTML;
                    let liClass = '';
                    if (label === correctAnswer) liClass = 'correct';
                    if (label === selectedVal && !isCorrect) liClass = 'wrong';

                    optionsHTML += `
                        <li class="${liClass}">
                            <label class="radio-container">
                                <span class="q-detiel">${optionText}</span>
                                <input type="radio" disabled ${label === selectedVal ? 'checked' : ''}>
                                <span class="label">${label}</span>
                                <span class="checkmark"></span>
                            </label>
                        </li>`;
                });

                resultHTML += `
                    <div class="mid-box1">
                        <strong>Question # ${idx + 1}</strong>
                        <h3>${questionText}</h3>
                        <ul>${optionsHTML}</ul>
                        <p>Your answer: ${selectedVal || 'Not answered'} | Correct answer: ${correctAnswer}</p>
                        <p>${isCorrect ? 'Correct!' : 'Incorrect!'}</p>
                    </div>`;
            });

            resetTimer(set);

            const pol = document.getElementById('pol-' + set);
            pol.querySelector('.ans-box').innerHTML = resultHTML;
            pol.querySelector('.holder-question').style.display = 'none';
            pol.querySelector('.last-box').style.display = 'none';
            pol.querySelector('.get-result').style.display = 'none';
            pol.querySelector('.ans-question').style.display = 'block';
        }
