						{
							<li>
								<a href="/colleges/@(college.Url).aspx" aria-label="link">
									<div class="img-holder">
										<!-- Display the logo or image associated with the college, replace this with actual image link if available -->
										<figure><img src="https://cdn.ilmkidunya.com/Inst/logos/@college.Logo" alt="" /></figure>
									</div>
									<div class="author">
										<span>@college.Name</span> <!-- Display college name -->
