@using System.Globalization
@model IKDFrontEnd.ViewModels.BookStoreCategory
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://css.ishallwin.com/style/main-page.css" rel="stylesheet" async="">
<link href="https://www.ilmkidunya.com/css-files/common/style-min.css" rel="stylesheet" async="">
@section MetaData {
    @if (ViewBag.CmsData != null)
    {
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
        <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
        <meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
        <meta name="description" content="@ViewBag.CmsData.MetaDesc">
        <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        
        <title>@ViewBag.CmsData.MetaTitle</title>
    }
}


@section header {
	<!-- Header Start -->


	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>


}
<!-- Header End -->
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>Islamic Studies Books</h1>
						<p>Search from 37 books</p>
					</div>
				</div>
				<div class="ss-col-lg-12">
					<div class="banner-form" style="margin: 0 20%;">
						<!-- <div class="input-holder" style="width: 85%;">
							<input type="text" name="" placeholder="Search Books here" style="width: 100%;">
						</div>
						<div class="btn-holder">
							<button><img src="https://images.ishallwin.com/search-icon.webp" alt=""></button>
						</div> -->
						<div class="input-holder" style="width: 90%;">
							<div style="width: 50%; position: relative; ">
								<input type="text" name="" placeholder="Any keywords" style="width: 100%;">
							</div>
							<div style="width: 50%; position: relative; ">
								<select aria-label="State" style="width: 100%;">
									<option>Select Category</option>
									<option>Islamic Studies</option>
									<option>Textbooks</option>
									<option>English</option>
									<option>Master</option>
									<option>Phd</option>
									<option>Mphil</option>
								</select>
							</div>
						</div>
						<div class="btn-holder">
							<button><img src="https://images.ishallwin.com/search-icon.webp" alt=""></button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
}
<!-- Main Start -->
<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>Books By Categories</h2>
					<ul class="books-list sml-list">
						@if (Model.Books != null && Model.Books.Any())
						{
							foreach (var book in Model.Books)
							{
								<li>
									<a href="@Url.Action("BookDetails", "Store", new { url = book.Url })">
										<figure>
											<img src="@book.Image" alt="@book.Name" />
										</figure>
										<strong>@book.Name</strong>
									</a>
								</li>
							}
						}
						else
						{
							<li>No books available in this category.</li>
						}
					</ul>

				</div>
			</div>
		</div>
	</div>
@* 	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					<div class="my-ads">
						<ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8866825487085085" data-ad-slot="7449924963" data-ad-format="auto" data-full-width-responsive="true"></ins>
						<script>
							(adsbygoogle = window.adsbygoogle || []).push({});
						</script>
					</div>
				</div>
			</div>
		</div>
	</div> *@
	<div class="content-sec level-wise">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>Related Categories</h2>
					<div class="tabs-holder">
						<div class="tabs-content cate" style="width: 100%;">
							<div id="Tab1" class="vertical-tab-content active">
								<ul>
									@if (Model.RelatedCategories != null)
									{
										foreach (var cat in Model.RelatedCategories)
										{
											// Create a URL-friendly slug
											var slug = cat.CategoryName.Trim().Replace(" ", "-").ToLower();
											<li>
												<a href="/store/category/@slug">
													@cat.CategoryName
												</a>
											</li>
										}
									}
								</ul>
							</div>

						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="container">
		<div class="row">
			<div class="col-lg-12 col-md-12 col-sm-12">
				@await Html.PartialAsync("_maincontenttopbanner")
			</div>
		</div>
	</div>
	<div class="content-sec level-wise">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>New Releases</h2>
					<ul class="books-list sml-list">
						@if (Model.LatestRelease != null && Model.LatestRelease.Any())
						{
							foreach (var book in Model.LatestRelease)
							{
								<li>
									<a href="/store/@book.Url">
										<figure>
											<img src="@book.Image" alt="@book.Name" />
										</figure>
										<strong>@book.Name</strong>
									</a>
								</li>
							}
						}
						else
						{
							<li>No latest releases available.</li>
						}
					</ul>

					
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding-bottom: 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>Featured Authors <a href="/store/allauthors">(View All Authors)</a></h2>
					<ul class="writter-list">
						@if (Model.Authors != null && Model.Authors.Any())
						{
							foreach (var author in Model.Authors)
							{
								var url = author.Name.Trim().Replace(" ", "-").ToLower(); 
								<li>
									<a href="/store/author/@url">
										<figure>
											<img src="@author.Image" alt="@author.Name" />
										</figure>
										<span>@author.Name</span>
									</a>
								</li>
							}
						}
						else
						{
							<li>No authors available.</li>
						}
					</ul>

				</div>
			</div>
		</div>
	</div>
	<div class="contact-sec fee-box" style="padding-top: 0;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if (ViewBag.CmsData != null && ViewBag.CmsData.Desc3 != null)
					{
						@Html.Raw(ViewBag.CmsData.Desc3)
					}
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontentlowerbanner")
				</div>
			</div>
		</div>
	</div>
</div>
<!-- Main End -->