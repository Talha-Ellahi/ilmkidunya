@using IKDFrontEnd.ViewModels
@* @model List<IKDFrontEnd.ViewModels.CompanyListItemViewModel> *@
@model CompanySearchViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section MetaData {
    @if (ViewBag.CmsData != null)
    {
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
        <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
        <meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
        <meta name="description" content="@ViewBag.CmsData.MetaDesc">
        <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>@ViewBag.CmsData.MetaTitle</title>
    }
}

<style>
    ul.jobs-search-links {
                               display: flex !important;
                               flex-wrap: wrap;
                               gap: 0 30px;

    }

                        ul.jobs-search-links li {
                               min-width: 300px;
                               width: calc(50% - 30px);

    }

                        ul.list-bullet li:nth-last-child(2)::before {
                                display: none;
    }
</style>
@section header {
    <!-- Header Start -->
    <div class="col-lg-11">
        <partial name="_JobsNavBar" />
    </div>
}
<!-- Header End -->
@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        @if (ViewBag.CmsData != null)
                        {
                            <h1>@ViewBag.CmsData.Heading</h1>
                        }
                    </div>
                </div>
                <div class="ss-col-lg-12">
                    <div class="banner-form" style="margin: 0 20%;">
                        <div class="input-holder" style="width: 90%;">
                            <div style="width: 50%; position: relative; ">
                                <select aria-label="State" style="width: 100%; border-left: 0;" id="typeDropdown">
                                    <option value="1">Government</option>
                                    <option value="0">Private</option>
                                </select>
                            </div>
                            <div style="width: 50%; position: relative; ">
                                <select name="cityId" id="cityDropdown">
                                    <option value="">-- Select City --</option>
                                    @if (ViewBag.Cities != null)
                                    {
                                        @foreach (var city in ViewBag.Cities as List<IKDFrontEnd.JobModels.TblDefCity>)
                                        {
                                            <option value="@city.CityId">
                                                @city.CityName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                        </div>
                        <div class="btn-holder">
                            <button type="button" id="searchBtn">
                                <img src="https://images.ishallwin.com/search-icon.webp" alt="Search">
                            </button>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



}
<!-- Main Start -->
<div id="main">
    <div class="news-ad-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12" id="jobResults">
                    <h2>List of @Model.Type Departments with Job Opportunities</h2>
                    <ul class="list-bullet jobs-search-links">
                         @foreach (var company in Model.Companies)
                        {
                            var jobCompany = company.CompanyName?.ToLower().Replace(" ", "-");
                            <li>
                                <a href="/jobs/@company.CompanyUrl">
                                    @{
                                        var maxLength = 50; // 55
                                        var displayName = company.CompanyName?.Length > maxLength
                                        ? company.CompanyName.Substring(0, maxLength) + "...."
                                        : company.CompanyName;
                                    }
                                    @displayName (@company.TotalJobs Jobs)
                                </a>
                            </li>
                            
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="ss-content">
            <div class="container">
                <div class="row">
                    @if (ViewBag.CmsData != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc1)
                    }

