									</div>
									<div class="text-holder">
										<div class="box-left">
											<div class="datewise">
												<span>Posted On <em>@item.Dated?.ToString("dd-MMM-yyyy")</em></span>
												<span>Last Date <em>@item.LastDate?.ToString("dd-MMM-yyyy")</em></span>
											</div>
											<h3>
												<a href="/admissions/@(item.Url).aspx" class="course-title" target="_blank">
													@item.AdmissionTitle
												</a>
											</h3>

											<p>@item.CollegeName </p>
										</div>
										<div class="box-right">
											<figure>
												@if (!string.IsNullOrWhiteSpace(item.AdmissionLogo))
												{
													var year = item.Dated.Value.Year;
													var month = item.Dated.Value.Month.ToString();
													<img src="https://admissions.ilmkidunya.com/admission_notices/Images/NoticeAds/@year/@month/Thumb/@item.AdmissionLogo" alt="Admission Image" />
