@using IKDFrontEnd.ViewModels
@model PastPaperPageViewModel

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@Model.MetaTitle" />
	<meta property="og:description" content="@Model.MetaDesc" />
	<meta property="og:image" content="" />
	<meta name="description" content="@Model.MetaDesc">
	<meta name="keywords" content="@Model.MetaKeywords">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	
	<title>@Model.MetaTitle </title>
}

@section header {
	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@Model.Heading</h1>
					</div>
				</div>
			</div>
		</div>
	</div>
}

<div id="main">
	 <div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<p>@Html.RenderWithAds(Model.Detail)</p>
				</div>
			</div>
		</div>
	</div>
	<div class="contact-sec fee-box">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					
					
					<div class="home-scholar-list">
						<ul>
							@if (Model.PastPapers != null)
							{
								int count = 0;
								@foreach (var paper in Model.PastPapers)
								{
								// Start a new list item for each paper
									<li>
										<a aria-label="link" href="/past_papers/@(paper.PaperName.Replace(" ", "-").ToLower() + "-" + paper.Id.ToString() + ".aspx")">
											<div class="img-holder">
												<img alt="image" src="https://pastpapers.ilmkidunya.com/past_papers/Images/@paper.Year/@paper.Month/thumb/@paper.ImageName" onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';"/>
											</div>
											<div class="text-holder">
												<div class="top-box">
													<span>Subject : @paper.SubjectName</span>
												</div>
												<h3>@paper.PaperName</h3>
												<p>@paper.BoardName</p>
											</div>
										</a>
									</li>

									
									count++;
									if (count % 12 == 0)
									{
										<div class="g-add-sec" style="padding: 30px 0 0 0;">
											<div class="container">
												<div class="row">
													<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8866825487085085"
															crossorigin="anonymous"></script>
													<!-- ikd25 -->
													<ins class="adsbygoogle"
														 style="display:block"
														 data-ad-client="ca-pub-8866825487085085"
														 data-ad-slot="9990874736"
														 data-ad-format="auto"
														 data-full-width-responsive="true"></ins>
													<script>
														(adsbygoogle = window.adsbygoogle || []).push({});
													</script>
												</div>
											</div>
										</div>
									}
								}
							}
						</ul>
					</div>
				</div>
				<div class="content-sec" style="padding: 30px 0 20px;">
					<div class="container">
						<div class="row">
							<div class="col-lg-12">
								<p>@Html.RenderWithAds(Model.Detail2)</p>
							</div>
						</div>
					</div>
				</div>
					<div class="col-lg-12">
						@await Html.PartialAsync("_maincontenttopbanner")
