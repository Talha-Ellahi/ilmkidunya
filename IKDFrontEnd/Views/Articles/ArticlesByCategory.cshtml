@section MetaData
{
	@if (Model != null && !string.IsNullOrEmpty(Model.MetaTitle) && !string.IsNullOrEmpty(Model.MetaDescription))
	{

		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta property="og:title" content="@Model.MetaTitle" />
		<meta property="og:description" content="@Model.MetaDescription" />
		<meta property="og:image" content="https://ikddata.ilmkidunya.com/images/{@Model.MetaImage}" />
		<meta name="description" content="@Model.MetaDescription">
		<meta name="keywords" content="@Model.MetaKeywords">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
		<title>@Model.MetaTitle</title>
	}
	else
	{

		<title>Pakistan Education News Colleges Scholarship Result Admission Jobs | ilmkidunya</title>

		<meta name="description" content="Latest updates about Pakistan colleges universities, study visa, scholarships and study abroad information. Get information about courses, admission and result of all Pakistani universities and colleges." />
		<meta name="keywords" content="ilmkidunya, education, educational, news, colleges, universities, result, admission, jobs, scholarship, visa, study, abroad, courses, pakistan, pakistani, information" />
		<meta property="og:image" content="https://ikddata.ilmkidunya.com/images/ilmkidunya-logo-2.jpg" />
		<meta property="og:image:width" content="200" />
		<meta property="og:image:height" content="200" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
	}
}
