


$(window).ready(function () {
  $(".accordion-list>li>a.toggle").on("click", function () {
    if ($(this).hasClass("active")) {
      $(this).removeClass("active");
      $(this)
        .siblings(".inner")
        .slideUp(200);
    } else {
      $(".accordion-list>li>a.toggle").removeClass("active");
      $(this).addClass("active");
      $(".inner").slideUp(200);
      $(this)
        .siblings(".inner")
        .slideDown(200);
    }
  });
});
