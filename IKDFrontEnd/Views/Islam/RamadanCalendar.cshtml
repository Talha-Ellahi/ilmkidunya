<style>
    .ramadan-timing-wrapper {
        display: flex;
        gap: 0px 20px;
        flex-wrap: wrap;
    }

    .prayer-times {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        min-width: 300px;
        background: #ffffff;
        border: 1px solid #15a18d;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06);
        border-radius: 12px;
        padding: 20px 30px;
        margin: 10px auto 30px;
        flex: 1 1 47%;
    }

    .prayer-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 140px;
        width: 100%;
        gap: 10px;
        position: relative;
    }

    .location-icon {
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .location-icon p {
            margin: 0;
            font-size: 15px;
        }

    .prayer-name {
        font-size: 22px;
        font-weight: 600;
        color: #15a18d;
        margin: 20px 0px 5px;
    }

    .prayer-time {
        font-size: 35px;
        font-weight: 700;
        margin-top: 20px;
        color: #222;
        line-height: 1;
    }

    .next-prayer-time {
        max-width: 420px;
        width: 100%;
        padding: 10px 10px 0px;
        justify-content: space-between;
        /* margin-top: 12px; */
        border-top: 1px solid #15a18d;
    }

    .arabic,
    .urdu-text {
        font-family: 'Noto Sans Arabic', sans-serif;
        text-align: center;
        font-size: 30px;
        font-weight: 600;
    }

    .urdu-text {
        font-size: 20px;
        font-weight: 500;
    }

    .translation-dua {
        padding: 10px 20px;
        background: #effcf4;
        border-left: 3px solid #15a18d;
        margin: 20px 0px;
        font-size: 16px;
        color: black;
    }

    @@media (max-width: 600px) {
        .prayer-times {
            gap: 15px;
            padding: 15px;
        }

        .prayer-item {
            min-width: 100px;
        }

   
    }
</style>
