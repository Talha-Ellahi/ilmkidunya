@using IKDFrontEnd.ViewModels
@model PastPaperPageViewModel

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["PageTitle2"] = Model.PageTitle2;
}

@section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@Model.PageTitle2" />
	<meta property="og:description" content="@(Model.PastPapers.FirstOrDefault()?.MetaDesc ?? "Past Paper")" />
	<meta property="og:image" content="" />
	<meta name="description" content="@(Model.PastPapers.FirstOrDefault()?.MetaDesc ?? "Past Paper")">
	<meta name="keywords" content="@(Model.PastPapers.FirstOrDefault()?.MetaKeywords ?? "Past Paper")">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	
	<title>@Model.PageTitle2</title>
}
@section header {
	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@Model.PageTitle2</h1>
					</div>
				</div>
			</div>
		</div>
	</div>
}




