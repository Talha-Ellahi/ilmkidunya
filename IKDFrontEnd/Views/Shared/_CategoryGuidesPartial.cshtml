@model List<IKDFrontEnd.ViewModels.CategoryCoursesViewModel>


    <div class="tab-container">
        <div class="tabs">
            @foreach (var category in Model)
            {
                var id = category.CategoryName.ToLower().Replace(" ", "");
                <div class="tab @(Model.First() == category ? "active" : "")"
                     onclick="toggleTab('@id')">
                    @category.CategoryName
                </div>
            }

            <a href="/Courses">
                <div class="tab" style="background: #27ae60;">
                    More+
                </div>
            </a>
        </div>

        @foreach (var category in Model)
        {
            var id = category.CategoryName.ToLower().Replace(" ", "");
            <div id="@id" class="tab-content @(Model.First() == category ? "active" : "")">
                <ul class="insti-list">
                    @foreach (var guide in category.Guides)
                    {
                        <li>
                            <a href="@guide.GuideMainUrl">@guide.GuideName</a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <!-- Accordion Section -->
    <div class="accordion-insti">
        @foreach (var category in Model)
        {
            <div class="accordion-item">
                <div class="accordion-header" onclick="toggleAccordion(this)">
                    @category.CategoryName <span></span>
                </div>
                <div class="accordion-content">
                    <ul>
                        @foreach (var guide in category.Guides)
                        {
                            <li>
                                <a href="@guide.GuideMainUrl">@guide.GuideName</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

