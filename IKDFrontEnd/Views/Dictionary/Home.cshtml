<script>

    let englishWord = '';
    let selectedLanguageMain = ''; // For main content search (second search bar)
    let selectedLanguageHeader = ''; // For header search (first search bar)

    // Initialize when page loads
    document.addEventListener('DOMContentLoaded', function() {
        initializeHeaderCustomSelect(); // Header search (first search bar)
    });


    // Header Custom Select Functionality (first search bar - requires new word input)
    function initializeHeaderCustomSelect() {
        const customSelectHeader = document.getElementById('customSelectSearch');
        const customOptionsHeader = customSelectHeader.nextElementSibling; // The .custom-options div right after customSelectSearch
        const optionSearchHeader = document.getElementById('optionSearchHeader');
        const optionsHeader = customOptionsHeader.querySelectorAll('span[data-value]');
        const selectedSpanHeader = customSelectHeader.querySelector('.selected');
        const searchBtnHeader = document.getElementById('searchBtnHeader');
        const wordInputHeader = document.querySelector('.ss-banner-inner .banner-form input[type="text"]');
        const customSelectWrapperHeader = customSelectHeader.parentElement;

        console.log('Initializing header search bar:', { customSelectHeader, customOptionsHeader, optionSearchHeader, options: optionsHeader.length });

        // Toggle dropdown using CSS classes
        customSelectHeader.addEventListener('click', function(e) {
            e.stopPropagation();
            customSelectWrapperHeader.classList.toggle('active');
            customOptionsHeader.classList.toggle('active');

            if (customOptionsHeader.classList.contains('active')) {
                optionSearchHeader.focus();
            }
        });

        // Handle option selection
        optionsHeader.forEach(option => {
            option.addEventListener('click', function() {
                selectedLanguageHeader = this.getAttribute('data-value');
                const languageName = this.textContent;
                selectedSpanHeader.textContent = languageName;

                // Close dropdown
                customSelectWrapperHeader.classList.remove('active');
                customOptionsHeader.classList.remove('active');

                console.log('Header search bar selected:', selectedLanguageHeader);
            });
        });

        // Search filter functionality
        optionSearchHeader.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            let hasVisibleOptions = false;

            optionsHeader.forEach(option => {
                const text = option.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    option.style.display = 'block';
                    hasVisibleOptions = true;
                } else {
                    option.style.display = 'none';
                }
            });

            // Show a message if no options match
            const noResults = customOptionsHeader.querySelector('.no-results');
            if (!hasVisibleOptions && !noResults) {
                const noResultsMsg = document.createElement('div');
                noResultsMsg.className = 'no-results';
                noResultsMsg.textContent = 'No languages found';
                noResultsMsg.style.padding = '10px 15px';
                noResultsMsg.style.color = '#666';
                noResultsMsg.style.fontStyle = 'italic';
                customOptionsHeader.appendChild(noResultsMsg);
            } else if (hasVisibleOptions && noResults) {
                noResults.remove();
            }
        });

        // Search button functionality - requires new word
        searchBtnHeader.addEventListener('click', function() {
            performHeaderSearch();
        });

        // Allow Enter key to trigger search in both search box and word input
        optionSearchHeader.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performHeaderSearch();
            }
        });

        wordInputHeader.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                performHeaderSearch();
            }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function() {
            customSelectWrapperHeader.classList.remove('active');
            customOptionsHeader.classList.remove('active');
        });
    }



    // Perform search for header (first search bar - requires new word input)
    function performHeaderSearch() {
        console.log('Header search triggered. Selected language:', selectedLanguageHeader);

        if (!selectedLanguageHeader) {
            selectedLanguageHeader = "urdu";
            // alert('Please select a language first from the header search bar');
            // return;
        }

        // Get the word from header input
        const wordInput = document.querySelector('.ss-banner-inner .banner-form input[type="text"]');
        const wordToSearch = wordInput.value.trim();

        if (!wordToSearch) {
            alert('Please enter a word to search');
            wordInput.focus();
            return;
        }

        // Default from language is English for header search
        const fromLanguage = 'en-gb';

        // Redirect to the new language page
        window.location.href = `/dictionary/${wordToSearch.toLowerCase().trim().replace(/\s+/g, "-")}-meaning-in-${selectedLanguageHeader.toLowerCase().trim()}`;
    }

</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const wrappers = document.querySelectorAll(".custom-select-wrapper");

        function closeAll(except = null) {
            wrappers.forEach(w => {
                if (w !== except) w.classList.remove("open");
            });
        }

        wrappers.forEach(wrapper => {
            const customSelect = wrapper.querySelector(".custom-select");
            const searchInput = wrapper.querySelector(".search-box input");
            const optionItems = Array.from(wrapper.querySelectorAll(".custom-options span[data-value]"));
            const selected = wrapper.querySelector(".custom-select .selected");

            // Toggle on header click
            customSelect.addEventListener("click", function (e) {
                e.stopPropagation();
                const willOpen = !wrapper.classList.contains("open");
                closeAll(willOpen ? wrapper : null);
                wrapper.classList.toggle("open");
                if (willOpen && searchInput) {
                    // focus search when opened
                    setTimeout(() => searchInput.focus(), 0);
                }
            });

            // Delegate clicks inside wrapper: only option clicks close+select
            wrapper.addEventListener("click", function (e) {
                e.stopPropagation();
                const option = e.target.closest("span[data-value]");
                if (option && wrapper.contains(option)) {
                    selected.textContent = option.textContent;
                    wrapper.dataset.value = option.dataset.value;
                    wrapper.classList.remove("open");
                }
                // other clicks inside wrapper (like search input) do nothing => dropdown stays open
            });

            // Live search (filter only this wrapper's options)
            if (searchInput) {
                searchInput.addEventListener("input", function () {
                    const filter = this.value.toLowerCase().trim();
                    optionItems.forEach(option => {
                        option.style.display = option.textContent.toLowerCase().includes(filter) ? "" : "none";
                    });
                    // keep it open while typing
                    if (!wrapper.classList.contains("open")) wrapper.classList.add("open");
                });
            }
        });

        // Click outside any wrapper closes all
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".custom-select-wrapper")) {
                closeAll();
            }
        });

        // Optional: close on Escape
        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") closeAll();
        });
    });

</script>



