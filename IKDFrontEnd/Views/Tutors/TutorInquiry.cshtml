	<form asp-controller="Tutors" asp-action="TutorInquiry" method="post">
		<div class="content-sec level-wise">
			<div class="container">
				<div class="row">
					<div class="col-lg-12">
						<h2>Student & Parents: Post your tutor requirments here.</h2>
						<div class="bs-admission-sec" style="padding: 0;">
							<div class="inner-holder">
								<div class="box-right">
									<div class="form-holder">

										<div class="fieldset">
											<label>I am a? *</label>
											<div class="in-box">
												<div>
													<input type="radio" asp-for="RequestType" value="false" id="p" />
													<label for="p">Parent</label>
												</div>
												<div>
													<input type="radio" asp-for="RequestType" value="true" id="s" />
													<label for="s">Student</label>
												</div>
											</div>
										</div>

										<div class="fieldset">
											<label>Your Name *</label>
											<input asp-for="Name" type="text"  placeholder="Enter your full name" />
											<span asp-validation-for="Name" class="text-danger"></span>
										</div>

										<div class="fieldset">
											<label>City *</label>
											<select asp-for="CityId" asp-items="ViewBag.CityList"  aria-label="City">
												<option value="">Select City</option>
											</select>
											<span asp-validation-for="CityId" class="text-danger"></span>
										</div>

										<div class="fieldset">
											<label>Email *</label>
											<input asp-for="Email" type="text"  placeholder="Enter your Email" />
											<span asp-validation-for="Email" class="text-danger"></span>
										</div>

										<div class="fieldset">
											<label>Contact Number</label>
											<input asp-for="PhoneNumber" type="text"  placeholder="Enter your mobile number" />
											<span asp-validation-for="PhoneNumber" class="text-danger"></span>
										</div>

										@* ✅ Password appears only if ModelState is invalid and user is not found *@
										@if (ViewBag.ShowPassword == true)
										{
											<div class="fieldset">
												<label>Password *</label>
												<input asp-for="Password" type="password" placeholder="Enter password" />
												<span asp-validation-for="Password" class="text-danger"></span>
											</div>
										}

										<div class="fieldset" style="width: 100%;">
											<h2>Tutoring Requirements</h2>
										</div>

										<div class="fieldset">
											<label>Study level *</label>
											<select asp-for="EducationLevelId" asp-items="ViewBag.LevelList" aria-label="Study Level">
												<option value="">Select study level</option>
											</select>
											<span asp-validation-for="EducationLevelId" class="text-danger"></span>
										</div>

										<div class="fieldset">
											<label>I am looking for a tutor for the following subjects or skills *</label>
											<select asp-for="SelectedSubjectIds" asp-items="ViewBag.SubjectList"  aria-label="Subjects">
												<option value="">Select skills</option>
											</select>
											<span asp-validation-for="SelectedSubjectIds" class="text-danger"></span>
										</div>

										<div class="fieldset" style="width: 100%;">
											<label>Detail *</label>
											<textarea asp-for="Detail"  style="width: 100%; height: 150px;"></textarea>
											<span asp-validation-for="Detail" class="text-danger"></span>
										</div>

										<div class="fieldset" style="width: 100%;">
											<label>Tutoring Options *</label>
											<div>
												<input type="checkbox" name="SelectedTutoringOptionIds" value="1" id="checkopt" />
												<label for="checkopt">I want tutor at home</label>
											</div>
											<div>
												<input type="checkbox" name="SelectedTutoringOptionIds" value="2" id="checkopt1" />
												<label for="checkopt1">I can visit tutor's place for tuition</label>
											</div>
											<div>
												<input type="checkbox" name="SelectedTutoringOptionIds" value="3" id="checkopt2" />
												<label for="checkopt2">I want online tutoring</label>
											</div>
											<span asp-validation-for="SelectedTutoringOptionIds" class="text-danger"></span>


										</div>

										<div>
											<input asp-for="IsShared" type="checkbox" id="checkopt3" />
											<label for="checkopt3">I understand that my information will be shared with relevant tutors</label>

										</div>
										<span asp-validation-for="IsShared" class="text-danger"></span>

										<div class="fieldset">
											<input type="submit" class="btn btn-primary" value="Submit" />
										</div>

									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</form>

