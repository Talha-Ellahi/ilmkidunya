

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
@section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
	<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
	<meta property="og:image" content="" />
	<meta name="description" content="@ViewBag.CmsData.MetaDesc">
	<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	
	<title>@ViewBag.CmsData.MetaTitle</title>
}
@section header {
	<div class="col-lg-11">
		<ul class="navigation">
			<li>
				<a aria-label="link" href="/courses/">
					<img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
					Home
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/test-preparation.aspx">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/testprep.png" alt="image" />
					Test Preparation
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/matric">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/matric.png" alt="image" />
					Matric Level
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/intermediate">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/inter.png" alt="image" />
					Inter Level
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/bachelors">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/bachelor.png" alt="image" />
					Bachelor Level
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/masters">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/master.png" alt="image" />
					Master Level
				</a>
			</li>
			<li>
				<a aria-label="link" href="/courses/popular-courses.aspx">
					<img src="https://www.ilmkidunya.com/icons/coursesicons/popular.png" alt="image" />
					Most Popular
				</a>
			</li>

		</ul>
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@ViewBag.CmsData.Heading</h1>

					</div>
				</div>
			</div>
		</div>
	</div>
}

<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(@ViewBag.CmsData.Desc1)

				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
	<div class="news-ad-sec">

		<div class="container">
			<div class="row">
				<div class="col-lg-12">

					@Html.Raw(@ViewBag.CmsData.Desc2)

				</div>
			</div>
		</div>
	</div>
	<br />
	
	<div class="news-ad-sec">

		<div class="container">
			<div class="row">
				<div class="col-lg-12">

					@Html.Raw(@ViewBag.CmsData.Desc3)

				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">

					@await Html.PartialAsync("_maincontentlowerbanner")

				</div>
			</div>
		</div>
	</div>

</div>




