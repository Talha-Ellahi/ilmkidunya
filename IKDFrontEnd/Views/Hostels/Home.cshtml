                                            btn.parentElement.remove(); // No more tutors
                                        } else {
                                            btn.classList.remove("load-more");
                                            btn.textContent = "Load More";
                                        }
                                    })
                                    .catch(err => {
                                        console.error("LoadMore error:", err);
                                        btn.classList.remove("load-more");
                                        btn.textContent = "Load More";
                                    });
                            });
                        </script>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="g-add-sec" style="padding: 30px 0 0 0;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="g-ad-box">
                        <figure>
                            <img src="./IKD_files/g-add-m.webp" alt="">
                        </figure>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="contact-sec fee-box" style="padding-top: 0;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    @if (ViewBag.CmsData != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc3)
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    @await Html.PartialAsync("_maincontentlowerbanner")
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Main End -->
