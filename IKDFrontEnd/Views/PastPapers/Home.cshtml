<script>
	document.addEventListener("DOMContentLoaded", function () {
		// Initialize only boards dropdown
		initializeBoardDropdown();

		// Board dropdown change event
		document.getElementById("boardDropdown").addEventListener("change", function () {
			const boardId = this.value;

			// Reset all dependent dropdowns
			resetDropdown('classDropdown', 'Select Class', true);
			resetDropdown('subjectDropdown', 'Select Subject', true);

			if (boardId) {
				// Enable and load classes for selected board
				enableDropdown('classDropdown');
				loadClasses(boardId);
			} else {
				// If no board selected, disable all dependent dropdowns
				disableDropdown('classDropdown');
				disableDropdown('subjectDropdown');
			}
		});

		// Class dropdown change event
		document.getElementById("classDropdown").addEventListener("change", function () {
			const boardId = document.getElementById("boardDropdown").value;
			const classId = this.value;

			// Reset subject dropdown
			resetDropdown('subjectDropdown', 'Select Subject', true);

			if (boardId && classId) {
				// Enable and load subjects for selected board and class
				enableDropdown('subjectDropdown');
				loadSubjects(boardId, classId);
			} else {
				// If no class selected, disable subject dropdown
				disableDropdown('subjectDropdown');
			}
		});

		// Search button click event
		document.getElementById("searchBtn").addEventListener("click", performSearch);

		// Enter key support
		document.querySelectorAll(".form-select").forEach(select => {
			select.addEventListener("keypress", function (e) {
				if (e.key === "Enter") {
					performSearch();
				}
			});
		});

		// -----------------------------
		// INITIALIZATION
		// -----------------------------
		function initializeBoardDropdown() {
			// Board dropdown is already populated from server-side
			console.log("Board dropdown initialized");
		}

		// -----------------------------
		// LOAD CLASSES
		// -----------------------------
		async function loadClasses(boardId) {
			try {
				setDropdownLoading('classDropdown', true);

				const response = await fetch(`/past_papers/get-classes?boardId=${boardId}`);
				if (!response.ok) throw new Error('Network response was not ok');

				const data = await response.json();
				const dropdown = document.getElementById("classDropdown");

				dropdown.innerHTML = `<option value="">Select Class</option>`;

				data.forEach(item => {
					const option = document.createElement("option");
					option.value = item.id;
					option.textContent = item.name;
					dropdown.appendChild(option);
				});

			} catch (error) {
				console.error("Error loading classes:", error);
				showDropdownError('classDropdown', 'Failed to load classes');
			} finally {
				setDropdownLoading('classDropdown', false);
			}
		}

		// -----------------------------
		// LOAD SUBJECTS
		// -----------------------------
		async function loadSubjects(boardId, classId) {
			try {
				setDropdownLoading('subjectDropdown', true);

				const response = await fetch(`/past_papers/get-subjects?boardId=${boardId}&classId=${classId}`);
				if (!response.ok) throw new Error('Network response was not ok');

				const data = await response.json();
				const dropdown = document.getElementById("subjectDropdown");

				dropdown.innerHTML = `<option value="">Select Subject</option>`;

				data.forEach(item => {
					const option = document.createElement("option");
					option.value = item.id;
					option.textContent = item.name;
					dropdown.appendChild(option);
				});

			} catch (error) {
				console.error("Error loading subjects:", error);
				showDropdownError('subjectDropdown', 'Failed to load subjects');
			} finally {
				setDropdownLoading('subjectDropdown', false);
			}
		}

		// -----------------------------
		// PERFORM SEARCH
		// -----------------------------
		function performSearch() {
			const boardId = document.getElementById("boardDropdown").value || 0;
			const classId = document.getElementById("classDropdown").value || 0;
			const subjectId = document.getElementById("subjectDropdown").value || 0;

			// Basic validation
			if (boardId == 0) {
				alert('Please select a board first');
				document.getElementById("boardDropdown").focus();
				return;
			}

			const url = `/past_papers/search_papers.aspx?boardid=${boardId}&classId=${classId}&subjectid=${subjectId}`;
			console.log("Redirecting to:", url);
			window.location.href = url;
		}

		// -----------------------------
		// HELPER FUNCTIONS
		// -----------------------------
		function setDropdownLoading(dropdownId, isLoading) {
			const dropdown = document.getElementById(dropdownId);
			if (isLoading) {
				dropdown.disabled = true;
				dropdown.classList.add('loading');
				dropdown.innerHTML = `<option value="">Loading...</option>`;
			} else {
				dropdown.disabled = false;
				dropdown.classList.remove('loading');
			}
		}

		function enableDropdown(dropdownId) {
			const dropdown = document.getElementById(dropdownId);
			dropdown.disabled = false;
			dropdown.classList.remove('disabled-dropdown');
		}

		function disableDropdown(dropdownId) {
			const dropdown = document.getElementById(dropdownId);
			dropdown.disabled = true;
			dropdown.classList.add('disabled-dropdown');
			dropdown.innerHTML = `<option value="">Select ${dropdownId.replace('Dropdown', '')}</option>`;
		}

		function resetDropdown(dropdownId, placeholder = '', disable = false) {
			const dropdown = document.getElementById(dropdownId);
			dropdown.innerHTML = `<option value="">${placeholder}</option>`;
			if (disable) {
				disableDropdown(dropdownId);
			}
		}

		function showDropdownError(dropdownId, message) {
			const dropdown = document.getElementById(dropdownId);
			dropdown.innerHTML = `<option value="">${message}</option>`;
		}
	});
</script>


