		<partial name="_NavBarPartial" />
	</div>
}

		@section innerbanner {
			<div class="ss-banner-inner left-align test">
				<div class="ss-container">
					<div class="ss-row">
						<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@Model.TestTitle</h1>
						<ul>
							<li>
								<span>Medium</span>
								<em>
									@(
																Model.TestTitle.ToLower().Contains("english") ? "English" :
																Model.TestTitle.ToLower().Contains("urdu") ? "Urdu" :
																"Not Specified"
																)
								</em>
							</li>
							<li><span>Available questions</span><em>@ViewBag.TotalAvailableQuestions</em></li>
							<li><span>Chapter Name</span><em>@ViewBag.ChName</em></li>
						</ul>
					</div>

						</div>
					</div>
				</div>
			</div>
		}
		
		<!-- Main Start -->
<div id="main">
	<div class="overlay-box"></div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					<ul class="ss-ads" style="border: 0; padding-top: 0; margin: 0;">
						@await Html.PartialAsync("_maincontenttopbanner")
					</ul>
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec level-wise">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2>@Model.TestTitle</h2>
					<ul class="contact-detail">
						<li>
							<p><span>Total Questions</span>@Model.TotalQuestions</p>
						</li>
						<li>
							<p><span>Time Allowed</span>@Model.DurationMinutes</p>
						</li>
					</ul>

					<a href="javascript:void(0)" id="launch-test-btn" onClick="launchTest()" class="text-btn">Start Test</a>
					<div class="question-side" id="pol">
						<div class="question-box">
							<div class="top-box">
								<h2>@Model.TestTitle</h2>

								<!-- <div class="switch-box">
									<input class="switch" id="first-toggle-btn" type="checkbox"/>
									<label for="first-toggle-btn"></label>
								</div> -->

								<div class="stopwatch">
									<div id="display">00:00</div>
									<!-- <button id="resetBtn">Reset</button> -->
								</div>
								<div class="close-btn">
									<a href="#" id="close"><img src="https://images.ishallwin.com/ot-images/red-cross.webp" alt="" /></a>
								</div>
							</div>
							<div class="holder-question">
								@foreach (var question in Model.Questions)
								{
									<div class="mid-box" data-question-number="@question.QuestionNumber">
										<strong>Question # @question.QuestionNumber</strong>
										<h3>@Html.Raw(question.QuestionText)</h3>
										@* Show Question Image if available *@
										@if (!string.IsNullOrEmpty(question.QuestionImageUrl))
										{
											<div class="question-image mb-2">
												<img src="@question.QuestionImageUrl" alt="Question Image" class="img-fluid" style="max-width: 100%; height: auto;" />
											</div>
										}
										<ul>
											@foreach (var option in question.Options)
											{
												var correctLabel = question.CorrectOption switch
												{
													1 => "A",
													2 => "B",
													3 => "C",
													4 => "D",
													5 => "E",
													_ => ""
												};

												var isCorrect = option.OptionLabel == correctLabel ? "true" : "false";

												<li>
													<label class="radio-container d-flex align-items-start">
														<span class="q-detiel">
															@Html.Raw(option.OptionText)

															@* Show Option Image if available *@
															@if (!string.IsNullOrEmpty(option.OptionImageUrl))
															{
																<div class="option-image mt-2">
																	<img src="@option.OptionImageUrl" alt="Option Image" class="img-fluid" style="max-width: 100%; height: auto;" />
																</div>
															}
														</span>

														<input type="radio"
															   name="question_@question.QuestionNumber"
															   value="@option.OptionLabel"
															   data-correct="@isCorrect" />
														<span class="label">@option.OptionLabel</span>
														<span class="checkmark"></span>
													</label>
												</li>
											}

										</ul>
									</div>
								}
							</div>

							<div class="last-box">
								<a href="#" class="prev"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt="" /></a>
								<a href="#" class="next"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt="" /></a>
							</div>
							
							<a href="#" class="text-btn get-result" style="margin: 30px 0 0 30px;">Submit</a>

							<!-- This stays in your view -->
							<div class="ans-question" style="display: none;">
								<div class="ans-box">
									<!-- JavaScript yahan questions insert karega -->
								</div>
								<a href="#" id="download-result" class="text-btn" style="margin: 30px 0 0 30px;">Download Result</a>

							</div>

						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="background: #f3f3f3; padding: 30px 0;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
