@model IKDFrontEnd.DictionaryViewModels.DictionaryPage
@using IKDFrontEnd.ViewModels

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://www.ilmkidunya.com/css-files/style/dictionary.css" rel="stylesheet" async="">
@section MetaData {
    @if (ViewBag.CmsData != null)
    {
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
        <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
        <meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
        <meta name="description" content="@ViewBag.CmsData.MetaDesc">
        <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="shortcut icon" href="~/images-files/images/favicon.ico">
        <title>@ViewBag.CmsData.MetaTitle</title>
    }
}


@section header {
    <!-- Header Start -->

    <div class="col-lg-11">
        <partial name="_NavBarPartial" />
    </div>


}

@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder" id="coursesHeading">
                        @if (ViewBag.CmsData != null && ViewBag.CmsData.Heading != null)
                        {
                            <h1>@ViewBag.CmsData.Heading</h1>
                            <p>@ViewBag.CmsData.ShortHeading</p>
                        }
                        else
                        {
                            <h1>English to Urdu Translation & Urdu to English Translation – Free Online Dictionary</h1>
                            <p>Type a word to find its meaning, synonyms, and examples.</p>
                        }

                    </div>
                </div>



            </div>
        </div>
    </div>
}


<style>
    .dictionary-word {
        color: #15a18d;
    }

    .dictionary-from.banner-form {
        position: relative;
    }

    .custom-select-wrapper {
        user-select: none;
        padding: 8px 20px;
    }

    .custom-select {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

        .custom-select .arrow {
            width: 0;
            height: 0;
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
            border-top: 6px solid #15a18d;
            margin-left: 10px;
            transition: transform .2s;
        }

    .custom-options {
        position: absolute;
        top: 80%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #15a18d;
        border-radius: 5px;
        margin-top: 5px;
        display: none;
        flex-direction: row;
        flex-wrap: wrap;
        z-index: 10;
        max-height: 400px;
        overflow-y: auto;
    }

        .custom-options .search-box {
            padding: 5px;
            border-bottom: 2px solid #ddd;
            flex: 1 1 100%;
        }

        .custom-options input {
            width: 100%;
            padding: 6px 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .custom-options span {
            padding: 10px;
            cursor: pointer;
            flex: 1 1 33%;
            min-width: 150px;
            transition: 0.2s;
        }

            .custom-options span:hover {
                background: #15a18d;
                color: #fff;
            }

    .custom-select-wrapper.open .custom-options {
        display: flex;
    }

    .custom-select-wrapper.open .custom-select .arrow {
        transform: rotate(180deg);
    }

    .dictionary-row {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 35px;
    }

        .dictionary-row .dictionary-boxes {
            min-width: 300px;
            min-height: 200px;
            width: 45%;
            flex: 1;
            padding: 25px;
            background: rgba(54, 229, 124, 0.1);
            border: 1px solid #36e57c;
            border-radius: 10px;
            position: relative;
        }

    .dictionary-boxes .meaning-bx {
        margin: 15px 0px;
    }

        .dictionary-boxes .meaning-bx li {
            color: #383838;
            line-height: 1.18;
            margin-bottom: 6px;
        }

    .dictionary-speaker {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .dictionary-speaker h2 {
            font-weight: bold !important;
        }

    .dictionary-boxes .spk-icon,
    .dictionary-boxes .icon {
        padding: 7px 16px;
    }

        .dictionary-boxes .spk-icon svg,
        .dictionary-boxes .icon svg {
            cursor: pointer;
            color: #15a18d;
            fill: #15a18d;
            margin-top: 5px;
            width: 28px;
            transition: all 0.3s ease;
        }

    #tspeaker-btn {
        padding-right: 0px;
    }

        #tspeaker-btn.active svg,
        #trans-copy-btn.active svg {
            color: #36e57c;
            fill: #36e57c;
            transform: scale(1.3);
        }

    .dictionary-boxes .spk-icon {
        position: absolute;
        bottom: 10px;
        right: 20px;
    }

    .dictionary-boxes .banner-form {
        margin: 0px !important;
    }

    .translation-result p {
        font-size: 20px;
        margin-top: 15px;
    }

        .translation-result p.urdu {
            font-size: 25px;
            text-align: right;
            font-weight: 600;
        }

    .responsive-table span.urdu {
        font-size: 20px;
        text-align: right;
        font-weight: 500;
        display: block;
    }

    .dictionary-synonyms-list {
        padding: 25px;
        background: rgba(54, 229, 124, 0.1);
        border: 1px solid #36e57c;
        border-radius: 10px;
        margin: 15px 0px 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .dictionary-boxes.tranlation-boxes {
        padding: 0px;
    }

    .dictionary-synonyms-list a {
        background-color: #ffffff;
        padding: 5px 14px;
        border-radius: 50px;
    }

    #user-trans-input,
    #translion-to-speak {
        width: 100%;
        margin-bottom: 10px;
        min-height: 200px;
        height: auto;
        background: transparent;
        color: #000000;
        font-size: 17px;
        padding: 12px 25px;
        border: none;
        resize: none;
    }

        #user-trans-input::placeholder,
        #translion-to-speak::placeholder {
            text-align: left;
        }

    .tranlation-boxes .urdu-lang {
        font-size: 19px !important;
        text-align: right;
    }

    .controls-dist {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        border-top: 1px solid #c8c8c8;
    }

    .tranlation-boxes .translation-result {
        min-height: 200px;
        height: auto;
        padding: 25px;
    }

        .tranlation-boxes .translation-result p {
            margin: 0px;
            font-weight: 500;
        }

    .controls-dist .dictionary-from {
        padding: 0px;
        width: 85%;
    }

        .controls-dist .dictionary-from .input-holder {
            background-color: transparent;
        }

        .controls-dist .dictionary-from .custom-select-wrapper {
            border-right: 1px solid #c8c8c8;
        }

    .translator-btns {
        text-align: center;
    }

        .translator-btns a.text-btn {
            margin: 0px 8px 30px 0px !important;
        }
</style>
