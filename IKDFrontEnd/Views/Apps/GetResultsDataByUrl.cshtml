</div>

<script>
		$(document).ready(function () {
		$("#resultUpdateForm").submit(function (e) {
			e.preventDefault();

			// Hide success message before sending request
			$("#resultSuccessMessage").addClass("d-none").hide();

			$.ajax({
				type: "POST",
				url: "/Results/resultupdates",
				data: $(this).serialize(),
				success: function (response) {
					if (response.success) {
						$("#resultUpdateForm")[0].reset();
						$("#resultSuccessMessage").removeClass("d-none").show();
					} else {
						alert("Error: " + response.message);
					}
				},
				error: function () {
					alert("An error occurred while submitting the form.");
				}
			});
		});
	});

</script>
