@model List<IKDFrontEnd.Models.TblOtsTestMcq>

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Answers Questions PDF</title>
    <style>
        @@media print {
            .no-print

        {
            display: none !important;
        }

        }
    </style>
</head>
<body style="background-color: #f7f8fa;">
    <table width="980" cellpadding="0" cellspacing="0" style="background: #fff; border: 0 #fff solid; margin: 0 auto; border-spacing: 0px; font-family: Arial, Helvetica, sans-serif">
        <tr>
            <td height="100" style="width: 800px; border-bottom: 1px solid #eaeaea; text-align: left; color: #FFF; font-size: 24px; font-family: Arial, Helvetica, sans-serif">
                <a href="#" style="display: block; padding:0 25px; text-align: center;">
                    <img src="https://cdn.ilmkidunya.com/logo.svg" width="auto" height="74px" alt="Logo" />



                </a>
            </td>
        </tr>
        <tr>
            <td colspan="2" style="width: 930px; background-color: #35e87e !important; padding: 15px 25px; font-family: Arial, Helvetica, sans-serif">
                <table>
                    <tr>
                        <td style="width: 930px;">
                            <p style="margin: 0; color: #000; line-height: 30px; font-size: 22px; text-align: center;">
                                @ViewBag.TestName
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td colspan="2" style="width: 930px; background-color: #fff; padding: 15px 25px 10px; font-family: Arial, Helvetica, sans-serif">
                <table style="width: 100%; border: 0;">
                    <tr>
                        <td style="width: 100%;">
                            <table style="width: 100%; border: 0; border-spacing: 0;">
                                <tr>
                                    <td style="background:#effcf4; padding: 8px;">
                                        <p style="margin: 0; color: #000; font-size: 14px;">Sr</p>
                                    </td>
                                    <td style="background:#effcf4; padding: 8px;">
                                        <p style="margin: 0; color: #000; font-size: 14px;">Questions</p>
                                    </td>
                                    <td style="background:#effcf4; padding: 8px;">
                                        <p style="margin: 0; color: #000; font-size: 14px;">Answers Choice</p>
                                    </td>
                                </tr>
                                @{
                                    int index = 1;
                                    foreach (var q in Model)
                                    {
                                        <tr>
                                            <td style="width: 60px; padding: 8px; border-bottom: 1px solid #eaeaea;">
                                                <p style="margin: 0; color: #000; font-size: 15px;">@index</p>
                                            </td>
                                            <td style="width: 617px; padding: 8px; border-bottom: 1px solid #eaeaea;">
                                                <p style="margin: 0; color: #000; font-size: 14px;">
                                                    @if (!string.IsNullOrEmpty(q.QuestionImage))
                                                    {
                                                        <img src="@q.QuestionImage" style="width: 100%;" alt="Question Image" />
                                                    }
                                                    else
                                                    {
                                                        @Html.Raw(q.Question)
                                                    }
                                                </p>
                                            </td>
                                            <td style="width: 245px; padding: 8px; border-bottom: 1px solid #eaeaea;">
                                                <p style="margin: 0; color: #000; font-size: 14px;">
                                                    @if (!string.IsNullOrEmpty(q.Choice1))
                                                    {
                                                        <span style="display: block; color:@(q.CorrectAnswer == 1 ? "#35e87e" : "#000")">
                                                            A. @q.Choice1
                                                        </span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(q.Choice2))
                                                    {
                                                        <span style="display: block; color:@(q.CorrectAnswer == 2 ? "#35e87e" : "#000")">
                                                            B. @q.Choice2
                                                        </span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(q.Choice3))
                                                    {
                                                        <span style="display: block; color:@(q.CorrectAnswer == 3 ? "#35e87e" : "#000")">
                                                            C. @q.Choice3
                                                        </span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(q.Choice4))
                                                    {
                                                        <span style="display: block; color:@(q.CorrectAnswer == 4 ? "#35e87e" : "#000")">
                                                            D. @q.Choice4
                                                        </span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(q.Choice5))
                                                    {
                                                        <span style="display: block; color:@(q.CorrectAnswer == 5 ? "#35e87e" : "#000")">
                                                            E. @q.Choice5
                                                        </span>
                                                    }
                                                </p>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                }
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
