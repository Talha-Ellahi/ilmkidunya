        border-radius: 10px;
        transition: all 0.3s ease;
        object-fit: cover;
    }

        .whatsapp-group-img:hover {
            transform: translateY(-50%) scale(1.1);
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
            cursor: pointer;
        }
</style>
