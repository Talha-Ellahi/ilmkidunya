<!-- Main Start -->

<div id="main">
    <div class="college-news-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">


                    @if (Model.CurrentLanguage != Model.TranslatedLanguage)
                    {
                        <!-- Word Title -->
                        <div class="ckeditorcontent">
                            <h2>
                                <span class="dictionary-word" id="wordTitle">@Model.Word</span>
                                Meaning in <span id="translatedLanguage">@Model.CompleteLanguage</span>
                            </h2>
                        </div>

                        <div class="dictionary-row">
                            <div class="dictionary-boxes">
                                <div class="dictionary-speaker">
                                    <h2 id="wordHeading">@Model.Word</h2>
                                </div>

                                <span class="pronociation" id="pronunciation" style="display:none;"></span>



                                <span class="spk-icon" id="speakerIcon" style="cursor:pointer;" onclick="playAudio()">
                                    <svg focusable="false" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                         viewBox="0 0 24 24" width="24" height="24">
                                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5
                                                         3c0-1.77-1.02-3.29-2.5-4.03v8.05
                                                         c1.48-.73 2.5-2.25 2.5-4.02zM14
                                                         3.23v2.06c2.89.86 5 3.54 5
                                                         6.71s-2.11 5.85-5 6.71v2.06c4.01-.91
                                                         7-4.49 7-8.77s-2.99-7.86-7-8.77z">
                                        </path>
                                    </svg>
                                </span>

                                <!-- hidden audio element -->
                                <audio id="customAudio" style="display:none;"></audio>
                            </div>

                            <!-- Translation Box -->
                            <div class="dictionary-boxes search-dict" style="padding-top: 5px;">


                                <div class="translation-result">
                                    <div class="translation-result">
                                        <p class="urdu" id="translatedText">
                                            @if (!string.IsNullOrEmpty(Model.ExistingMeaning))
                                            {
                                                <!-- Debug Information -->
                                                <div style="background: #f0f0f0; padding: 10px; margin: 10px 0; display: none;" id="debugInfo">
                                                    <strong>Debug Info:</strong><br />
                                                    Raw from Model: @Model.ExistingMeaning<br />
                                                    Contains &amp;#x: @Model.ExistingMeaning.Contains("&#x")<br />
                                                    Length: @Model.ExistingMeaning.Length<br />
                                                    First 20 chars: @Model.ExistingMeaning.Substring(0, Math.Min(20, Model.ExistingMeaning.Length))<br />
                                                    After HtmlDecode: @System.Net.WebUtility.HtmlDecode(Model.ExistingMeaning)<br />
                                                    After HtmlDecode Contains &amp;#x: @System.Net.WebUtility.HtmlDecode(Model.ExistingMeaning).Contains("&#x")
                                                </div>

                                                @Model.ExistingMeaning
                                            }
                                            else
                                            {
                                                <span class="loading">Loading translation...</span>
                                            }
                                        </p>
                                        <script>
                                            document.addEventListener('DOMContentLoaded', function() {
                                                function fixEncodedText() {
                                                    const translatedElement = document.getElementById('translatedText');
                                                    if (translatedElement) {
                                                        const currentContent = translatedElement.innerHTML;

                                                        // Check if content is encoded
                                                        if (currentContent.includes('&amp;#x') || currentContent.includes('&#x')) {
                                                            console.log('Fixing encoded text from response compression...');

                                                            // Decode the HTML entities
                                                            const textArea = document.createElement('textarea');
                                                            textArea.innerHTML = currentContent;
                                                            const decodedContent = textArea.value;

                                                            // Update the content
                                                            translatedElement.innerHTML = decodedContent;
                                                        }
                                                    }
                                                }

                                                // Run immediately
                                                fixEncodedText();

                                                // Run again after a short delay in case content loads async
                                                setTimeout(fixEncodedText, 100);
                                            });
                                        </script>
                                    </div>



                                </div>
                            </div>



                        </div>

                    }
                    <!-- Definitions -->
                    <div class="ckeditorcontent" id="definitionsSection" style="display:none;">
                        <h3 id="definitionsTitle">Definitions</h3>
                        <div id="definitionsList">
                            @if (!string.IsNullOrEmpty(Model.ExistingDefinition))
                            {
                                <p><em>@Model.ExistingPartOfSpeech</em>. @Model.ExistingDefinition</p>
                            }
                        </div>
                        <p id="sourceLink" style="display:none;"><strong>Source:</strong> <a id="sourceUrl" target="_blank"></a></p>
                    </div>

                    <!-- Synonyms -->
                    <div id="synonymsSection" style="display:none;">
                        <h3 id="synonymsTitle">Synonyms</h3>
                        <div class="dictionary-synonyms-list" id="synonymsList">
                            @if (!string.IsNullOrEmpty(Model.ExistingSynonyms))
                            {
                                var synonyms = Model.ExistingSynonyms.Split(',').Select(s => s.Trim()).Where(s => !string.IsNullOrEmpty(s));
                                if (synonyms.Any())
                                {
                                    foreach (var syn in synonyms.Take(20))
                                    {
                                        <a href="/dictionary/@syn.Replace(" ", "-")-meaning-in-@Model.TranslatedLanguage">@syn</a>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <!-- Antonyms -->
                    <div id="antonymsSection" style="display:none;">
                        <h3 id="antonymsTitle">Antonyms</h3>
                        <div class="dictionary-synonyms-list" id="antonymsList">
                            @if (!string.IsNullOrEmpty(Model.ExistingAntonyms))
                            {
                                var antonyms = Model.ExistingAntonyms.Split(',').Select(a => a.Trim()).Where(a => !string.IsNullOrEmpty(a));
                                if (antonyms.Any())
                                {
                                    foreach (var ant in antonyms.Take(20))
                                    {
                                        <a href="/dictionary/@ant.Replace(" ", "-")-meaning-in-@Model.TranslatedLanguage">@ant</a>
                                    }
                                }
                            }
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>


    <div class="content-sec level-wise" style="margin-bottom: 30px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Explore the Meaning of Words with the Best Complies Dictionary</h2>
                    <div class="subjects-tble2 diclinkclr">
                        <ul>
                            <li>
                                <a href="/dictionary/english-to-english-dictionary">
