@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
@section MetaData {
	@if (ViewBag.CmsData != null)
	{
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
		<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
		<meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
		<meta name="description" content="@ViewBag.CmsData.MetaDesc">
		<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<link rel="shortcut icon" href="~/images-files/images/favicon.ico">
		<title>@ViewBag.CmsData.MetaTitle</title>
	}
}
@section header {
	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						@if (ViewBag.CmsData != null && ViewBag.CmsData.Heading != null)
						{
							<h1>@ViewBag.CmsData.Heading</h1>
						}


						<div class="banner-form" style="margin: 0 20%;">
							<div class="input-holder" style="width: 90%;">
								<div style="width: 33.33%; position: relative;">
									<select class="form-select" name="boardId" id="boardDropdown">
										<option value="">Select Board</option>
										@if (ViewBag.InitialBoards != null)
										{
											foreach (var board in ViewBag.InitialBoards)
											{
												<option value="@board.id">@board.name</option>
											}
										}
									</select>
								</div>
								<div style="width: 33.33%; position: relative;">
									<select class="form-select" name="classId" id="classDropdown" disabled>
										<option value="">Select Class</option>
									</select>
								</div>
								<div style="width: 33.33%; position: relative;">
									<select class="form-select" name="subjectId" id="subjectDropdown" disabled>
										<option value="">Select Subject</option>
									</select>
								</div>
							</div>
							<div class="btn-holder">
								<button type="button" id="searchBtn">
									<img src="https://images.ishallwin.com/search-icon.webp" alt="Search">
								</button>
							</div>
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>


}
