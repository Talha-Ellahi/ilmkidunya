<script>
    // -----------------------------
    // Time Left Calculation Functions
    // -----------------------------
    function parsePrayerTime(timeStr) {
        // Remove spaces and convert to uppercase for consistent parsing
        timeStr = timeStr.trim().toUpperCase();

        // Check if it's AM/PM format
        const hasAmPm = timeStr.includes('AM') || timeStr.includes('PM');

        if (hasAmPm) {
            // Extract time and period
            const timePart = timeStr.replace(/AM|PM/gi, '').trim();
            const period = timeStr.includes('PM') ? 'PM' : 'AM';

            let [hours, minutes] = timePart.split(':').map(Number);

            // Convert to 24-hour format
            if (period === 'PM' && hours !== 12) {
                hours += 12;
            } else if (period === 'AM' && hours === 12) {
                hours = 0;
            }

            return { hours, minutes };
        } else {
            // Assume 24-hour format
            const [hours, minutes] = timeStr.split(':').map(Number);
            return { hours, minutes };
        }
    }

    function updateTimeLeft(prayerTime, elementId) {
        const now = new Date();
        const { hours, minutes } = parsePrayerTime(prayerTime);

        const prayerDate = new Date(now.getFullYear(), now.getMonth(), now.getDate(), hours, minutes);
        let diffMs = prayerDate - now;

        if (diffMs < 0) {
            // If prayer already passed today, set to next day's prayer
            prayerDate.setDate(prayerDate.getDate() + 1);
            diffMs = prayerDate - now;
        }

        const totalMinutes = Math.floor(diffMs / (1000 * 60));
        const h = Math.floor(totalMinutes / 60);
        const m = totalMinutes % 60;

        document.getElementById(elementId).textContent = `Time Left: ${h}h ${m}m`;
    }

    function updateAllTimeLeft() {
        // Update Hanafi times
        updateTimeLeft("@Model.TodayHanafi.Sehri", "hanafi-sehri-time-left");
        updateTimeLeft("@Model.TodayHanafi.Iftar", "hanafi-iftar-time-left");

        // Update Jafaria times
        updateTimeLeft("@Model.TodayJafaria.Sehri", "jafaria-sehri-time-left");
        updateTimeLeft("@Model.TodayJafaria.Iftar", "jafaria-iftar-time-left");
    }

    // Initial call for all prayer times
    updateAllTimeLeft();

    // Update every minute
    setInterval(updateAllTimeLeft, 60000);

    // -----------------------------
    // Islamic Date Calculation
    // -----------------------------
    async function getIslamicDateByCoordinates(latitude, longitude) {
        try {
            const apiUrl = `https://api.aladhan.com/v1/gToH?latitude=${latitude}&longitude=${longitude}`;
            const response = await fetch(apiUrl);
            if (response.ok) {
                const data = await response.json();
                if (data.code === 200 && data.data) {
                    const hijri = data.data.hijri;
                    const islamicDate = `${hijri.day} ${hijri.month.en} ${hijri.year} ${hijri.designation.abbreviated}`;

                    // Set Islamic date for ALL sections
                    document.getElementById("hanafi-sehri-islamic-date").textContent = islamicDate;
                    document.getElementById("hanafi-iftar-islamic-date").textContent = islamicDate;
                    document.getElementById("jafaria-sehri-islamic-date").textContent = islamicDate;
                    document.getElementById("jafaria-iftar-islamic-date").textContent = islamicDate;
                    return;
                }
            }
            fallbackToIntl();
        } catch (error) {
            console.log("Islamic API failed:", error);
            fallbackToIntl();
        }
    }

    function fallbackToIntl() {
        const today = new Date();
        const islamic = new Intl.DateTimeFormat('en-SA-u-ca-islamic', { day: 'numeric', month: 'long', year: 'numeric' }).formatToParts(today);
        const day = islamic.find(p => p.type === 'day').value;
        const month = islamic.find(p => p.type === 'month').value;
        const year = islamic.find(p => p.type === 'year').value;
        const islamicDate = `${day} ${month} ${year} AH`;

        // Set Islamic date for ALL sections
        document.getElementById("hanafi-sehri-islamic-date").textContent = islamicDate;
        document.getElementById("hanafi-iftar-islamic-date").textContent = islamicDate;
        document.getElementById("jafaria-sehri-islamic-date").textContent = islamicDate;
        document.getElementById("jafaria-iftar-islamic-date").textContent = islamicDate;
    }

    const latitude = @Model.City.Latitude ?? 0;
    const longitude = @Model.City.Longitude ?? 0;

    if (latitude && longitude) {
        getIslamicDateByCoordinates(latitude, longitude);
    } else {
        fallbackToIntl();
    }
</script>