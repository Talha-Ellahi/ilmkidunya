                <div class="content-sec level-wise">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-12">
                                <h2>Online Short Questions For Chapter @Model.Chapters.FirstOrDefault()?.ChapterName  "@Model.TestName "</h2>
                                <p>Try The Short Questions For @Model.TestName</p>
                                <ul class="contact-detail">
                                    <li>
                                        <p><span>Total Questions</span>@Model.CriteriaDetail.TotalQuestions</p>
                                    </li>
                                    @if (Model.CanCreateSets)
                                    {
                                        <li>
                                            <p><span>Available Sets</span>@Model.ActualNumberOfSets</p>
                                        </li>
                                    }
                                </ul>
                                <div class="teststartbtn">
                                    <a href="javascript:void(0)" id="launch-test-btn" onclick="shortQuestionPolOpen(0)" class="text-btn">Start Test</a>
                                    <a href="/short-questions/download-short-questions/@Model.Url" class="text-btn" target="_blank">
                                        Download PDF
                                    </a>
                                </div>

                                <!-- Main Question Popup -->
                                <div class="question-side shortquestion-box" id="pol-mode">
                                    <div class="question-box">
                                        <div class="top-box">
                                            <h2>@Model.SubjectName - @Model.TestName</h2>

                                            <div class="close-btn">
                                                <a href="javascript:void(0)" id="close"><img src="https://images.ishallwin.com/ot-images/red-cross.webp" alt=""></a>
                                            </div>
                                        </div>
                                        <div class="holder-question short-qestion-holder">
                                            @for (int i = 0; i < Model.QuestionSets[0].Questions.Count; i++)
                                            {
                                                var question = Model.QuestionSets[0].Questions[i];
                                                <div class="mid-box" data-question-number="@(i + 1)" style="display: @(i == 0 ? "block" : "none");">
                                                    <strong>Question # @(i + 1)</strong>
                                                    <h3>
                                                        @Html.Raw(question.QuestionDescription)
                                                    </h3>
                                                    @if (!string.IsNullOrWhiteSpace(question.QuestionImage))
                                                    {
                                                        <img src="https://ikddata.ilmkidunya.com/images/short-question/Q_@(question.QuestionId)_@(question.QuestionImage)" alt="pic" />
                                                    }
                                                    <ul>
                                                        @for (int j = 0; j < question.Answers.Count; j++)
                                                        {
                                                            var answer = question.Answers[j];
                                                            <li>
                                                                <span>Ans @(j + 1):</span> @Html.Raw(answer.ChoiceDescription)
                                                                @if (!string.IsNullOrWhiteSpace(answer.ChoiceImage))
                                                                {
                                                                    <img src="https://ikddata.ilmkidunya.com/images/short-question/Ans_@(answer.ChoiceId)_Q_@(question.QuestionId)_@(answer.ChoiceImage)" alt="pic" />
                                                                }
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </div>
                                        <div class="last-box">
                                            <a href="javascript:void(0)" class="prev disabled" style="background-color: rgb(204, 204, 204);"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt=""></a>
                                            <a href="javascript:void(0)" class="next" style="background-color: rgb(111, 229, 125);"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt=""></a>
                                        </div>

                                        <!-- Fake Submit -->
                                        <a href="javascript:void(0)" class="text-btn" style="margin: 30px 0 0 30px;">Submit</a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-12">
                                <div class="all-test-box">
                                    <h2>
                                        Prepare Complete Set Wise Questions For Chapter @Model.Chapters.FirstOrDefault()?.ChapterName  "@Model.TestName "
                                    </h2>
                                    <ul>
                                        @for (int i = 0; i < Model.QuestionSets.Count; i++)
