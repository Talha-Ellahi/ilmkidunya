@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        <h1>@Model.PrayerName Prayer Time</h1>
                        <p>Search @Model.PrayerName timings worldwide with fast country and city-based filters</p>
                        <div class="banner-form" style="margin: 0 20%;">
                            <div class="input-holder" style="width: 90%;">
                                <div style="width: 50%; position: relative;">
                                    <select class="form-select" name="country" id="countryDropdown">
                                        <option value="">Select Country</option>
                                        @if (ViewBag.Countries != null)
                                        {
                                            foreach (var country in ViewBag.Countries)
                                            {
                                                <option value="@country.Id">@country.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div style="width: 50%; position: relative;">
                                    <select class="form-select" name="city" id="cityDropdown" disabled>
                                        <option value="">Select City</option>
                                    </select>
                                </div>
                            </div>

                            <div class="btn-holder">
                                <button type="button" id="searchBtn" disabled>
                                    <img src="https://images.ishallwin.com/search-icon.webp" alt="Search">
                                </button>
                            </div>
                        </div>

                        <script>
                            // Country dropdown change event
                            document.getElementById('countryDropdown').addEventListener('change', function() {
                                const countryId = this.value;
                                const cityDropdown = document.getElementById('cityDropdown');
                                const searchBtn = document.getElementById('searchBtn');

                                // Reset city dropdown
                                cityDropdown.innerHTML = '<option value="">Select City</option>';
                                cityDropdown.disabled = true;
                                searchBtn.disabled = true;

                                if (countryId) {
                                    // Fetch cities for selected country
                                    fetch(`/islam/getAllCities/${countryId}`)
                                        .then(response => {
                                            if (!response.ok) {
                                                throw new Error('Network response was not ok');
                                            }
                                            return response.json();
                                        })
                                        .then(cities => {
                                            // Populate city dropdown
                                            cities.forEach(city => {
                                                const option = document.createElement('option');
                                                option.value = city.id;
                                                option.textContent = city.cityName;
                                                cityDropdown.appendChild(option);
                                            });

                                            cityDropdown.disabled = false;
                                        })
                                        .catch(error => {
                                            console.error('Error fetching cities:', error);
                                            alert('Error loading cities. Please try again.');
                                        });
                                }
                            });

                            // City dropdown change event
                            document.getElementById('cityDropdown').addEventListener('change', function() {
                                const searchBtn = document.getElementById('searchBtn');
                                searchBtn.disabled = !this.value;
                            });

                            // Search button click event
                            document.getElementById('searchBtn').addEventListener('click', function() {
                                const cityDropdown = document.getElementById('cityDropdown');
                                const selectedCityId = cityDropdown.value;
                                const selectedCityName = cityDropdown.options[cityDropdown.selectedIndex].textContent;

                                if (!selectedCityId) {
                                    alert('Please select a city');
                                    return;
                                }

                                // Convert city name to slug format
                                const citySlug = selectedCityName.toLowerCase().replace(/\s+/g, '-');

                                // Redirect to the prayer timing page
                                window.location.href = `/islam/${citySlug}-namaz-timing`;
                            });
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
