@model IKDFrontEnd.ViewModels.HostelHomeViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var random = new Random();
    var colorClasses = new[] { "sh-green", "sh-blue", "sh-purple", "sh-red" };
}



<link href="https://css.ishallwin.com/style/main-page.css" rel="stylesheet" async>

@section MetaData {
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
    <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
    <meta property="og:image" content="" />
    <meta name="description" content="@ViewBag.CmsData.MetaDesc">
    <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <title>@ViewBag.CmsData.MetaTitle</title>
}


@section header {


    <div class="col-lg-11">
        <partial name="_NavBarPartial" />
    </div>
}

@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        @if (ViewBag.CmsData != null)
                        {
                            <h1>@ViewBag.CmsData.Heading</h1>
                            @Html.Raw(ViewBag.CmsData.Desc2)
                        }
                    </div>
                </div>
                <div class="ss-col-lg-12">
                    <form id="cityForm" method="get">
                        <div class="banner-form" style="margin: 0 30%;">

                            <div class="input-holder" style="width: 85%;">
                                <select id="citySelect" name="cityId" aria-label="State" style="width: 100%; padding: 0 20px;">
                                    <option value="">Select City</option>
                                    @foreach (var city in Model.CitySelectList)
                                    {
                                        <option value="@city.Text">@city.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="btn-holder">
                                <button type="submit">
                                    <img src="https://images.ishallwin.com/search-icon.webp" alt="">
                                </button>
                            </div>
                        </div>
                    </form>

                    <script>
                        document.getElementById("cityForm").addEventListener("submit", function (e) {
                            e.preventDefault(); // Stop normal form submit
                            const selectedCity = document.getElementById("citySelect").value;

                            if (selectedCity) {
                                // Create slug: lowercase, replace spaces with hyphens
                                const citySlug = selectedCity.toLowerCase().replace(/\s+/g, '-');
                                window.location.href = `/hostels/hostels-in-${citySlug}`;
                            }
                        });
                    </script>

                </div>



            </div>
        </div>
    </div>
}


<!-- Main Start -->
<div id="main">

    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    @if (ViewBag.CmsData != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc1)
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    <div class="my-ads">
                        <div id="map" style="height: 300px; width: 100%;"></div>
                        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8866825487085085" data-ad-slot="7449924963" data-ad-format="auto" data-full-width-responsive="true"></ins>
                        <script>
                            (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyC8MxkfkgeZC_pThpstNdSeiibVwpBwMOQ&sensor=false"></script>
                    <script>
                        async function initMap() {
                        
                            // Create base map centered on Pakistan
                            const map = new google.maps.Map(document.getElementById("map"), {
                                center: { lat: 30.3753, lng: 69.3451 },
                                zoom: 6
                            });
                                console.log("hello");
                            try {
                                // Fetch hostel data from API with MVC-generated URL
                                const apiUrl = '@Url.Action("GetHostelLocations", "Hostels")';
                                const response = await fetch(apiUrl);
                                const hostels = await response.json();

                                // Add markers for each hostel
                                hostels.forEach(hostel => {
                                    const marker = new google.maps.Marker({
                                        position: {
                                            lat: parseFloat(hostel.latitude),
                                            lng: parseFloat(hostel.longitude)
                                        },
                                        map: map,
                                        title: hostel.hostelName
                                    });

                                    const infoWindow = new google.maps.InfoWindow({
                                        content: `<div><strong>${hostel.hostelName}</strong><br>${hostel.fullAddress}</div>`
                                    });

                                    marker.addListener("click", () => {
                                        infoWindow.open(map, marker);
                                    });
                                });

                            } catch (error) {
                                console.error("Error loading hostel data:", error);
                            }
                        }

                        // Initialize map when window loads
                        window.onload = initMap;
                    </script>

                </div>
            </div>
        </div>
    </div>


    <div class="content-sec level-wise">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Click on any city to view hostels and rooms</h2>
                    <div class="row">
                        <ul class="admission-nav">
                            @foreach (var city in Model.CitiesWithImages)
                            {
                                <li>
                                    @{
                                        var cityName = city.CityName.ToLower().Replace(" ","-");
                                    }
                                    <a href="/hostels/hostels-in-@cityName">
                                        <figure><img src="@city.ImagePath" alt="@city.CityName"></figure>
                                        <span>@city.CityName</span>
                                    </a>
                                </li>
                            }
                        </ul>
                        <a href="/hostels/city-wise-hostels-and-rooms" class="load-more">More Cities</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12">
                @await Html.PartialAsync("_maincontenttopbanner")
            </div>
        </div>
    </div>
    <div class="content-sec level-wise">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Latest Hostels &amp; Rooms Listings</h2>
                    <div class="institute-list hostel-list">
                        <ul id="hostelList">
                            @foreach (var hostel in Model.LatestHostels)
                            {
                                <li>
                                    @{
                                        var cityName = hostel.CityName.ToLower().Replace(" ", "-");
                                    }
                                    <a href="/hostels/@($"{hostel.HostelUrl}-{cityName}-{hostel.HostelId}")">
                                        <div class="figure">
                                            <img alt="image" src="@hostel.MainImage">
                                        </div>
                                        <div class="author">
                                            <h3>@hostel.HostelName</h3>
                                            <p>@hostel.CityName</p>
                                            <span class="load-more">
                                                @(hostel.Price != null ? hostel.Price.Value.ToString("N0") + " / month" : "N/A")
                                            </span>

                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>



                        <div class="ss-loadmore">
                            <a href="javascript:void(0)" class="button js-load-more" id="load-more-btn" data-skip="10">Load More</a>
                        </div>
                        <script>
                            let skipCount = 10;
                            document.getElementById("load-more-btn").addEventListener("click", function () {
                                const btn = this;
                                const skip = parseInt(btn.getAttribute("data-skip"));



                                // Optional: show loading animation
                                btn.classList.add("load-more");
                                btn.innerHTML = 'Loading <span>.</span><span>.</span><span>.</span>';

                                fetch(`/hostels/load-more?skip=${skipCount}`)
                                    .then(res => res.text())
                                    .then(html => {
