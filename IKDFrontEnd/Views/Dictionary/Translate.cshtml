<script>

    // Check Base64 string

    function isBase64(str) {

        try {

            return btoa(atob(str)) === str;

        } catch {

            return false;

        }

    }



    // Decode Base64

    function decodeBase64Url(base64Url) {

        try {

            return decodeURIComponent(escape(window.atob(base64Url)));

        } catch {

            return base64Url;

        }

    }



    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll("a.decode-banner-url").forEach(function (a) {

            a.addEventListener("click", function (e) {

                var encodedUrl = a.getAttribute("data-url");



                if (encodedUrl && isBase64(encodedUrl)) {

                    e.preventDefault();

                    var decodedUrl = decodeBase64Url(encodedUrl);

                    window.open(decodedUrl, "_blank");

                }

            });

        });

    });

</script>
<script>
    // Speech Recognition for Microphone
    let recognition = null;
    let isListening = false;

    // Check browser support for Speech Recognition
    if ('webkitSpeechRecognition' in window) {
        recognition = new webkitSpeechRecognition();
    } else if ('SpeechRecognition' in window) {
        recognition = new SpeechRecognition();
    }

    if (recognition) {
        recognition.continuous = false;
        recognition.interimResults = false;

        // Get the selected language code
        recognition.lang = document.querySelector('.custom-select-wrapper[data-value]').getAttribute('data-value');

        recognition.onresult = function(event) {
            const transcript = event.results[0][0].transcript;
            document.getElementById('user-trans-input').value = transcript;

            // Auto-translate if you have a translate function
            if (window.translateText) {
                window.translateText(transcript);
            }
        };

        recognition.onerror = function(event) {
            console.error('Speech recognition error:', event.error);
        };

        recognition.onend = function() {
            isListening = false;
            updateMicButton();
        };
    }

    // Microphone button click handler
    document.getElementById('translate-record-btn').addEventListener('click', function() {
        if (!recognition) {
            alert('Speech recognition is not supported in your browser. Try Chrome or Edge.');
            return;
        }

        if (isListening) {
            recognition.stop();
            isListening = false;
        } else {
            // Update language before starting
            const langCode = document.querySelector('.custom-select-wrapper[data-value]').getAttribute('data-value');
            recognition.lang = langCode;

            recognition.start();
            isListening = true;
        }

        updateMicButton();
    });

    function updateMicButton() {
        const micBtn = document.getElementById('translate-record-btn');
        if (isListening) {
            micBtn.style.backgroundColor = '#ff4444';
            micBtn.title = 'Stop listening';
        } else {
            micBtn.style.backgroundColor = '';
            micBtn.title = 'Start speaking';
        }
    }

    // Speaker button click handler
    document.getElementById('tspeaker-btn').addEventListener('click', function() {
        const translationText = document.getElementById('translion-to-speak').value;

        if (!translationText.trim()) {
            alert('No translation text to speak');
            return;
        }

        // Get target language for speech synthesis
        const targetLang = document.querySelectorAll('.custom-select-wrapper')[1].getAttribute('data-value');

        speakText(translationText, targetLang);
    });

    function speakText(text, langCode) {
        if ('speechSynthesis' in window) {
            // Cancel any ongoing speech
            speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);

            // Map language codes to speech synthesis voices
            utterance.lang = langCode;

            // Try to find a suitable voice for the language
            const voices = speechSynthesis.getVoices();
            const suitableVoice = voices.find(voice =>
                voice.lang.startsWith(langCode) ||
                voice.lang.startsWith(langCode.split('-')[0])
            );

            if (suitableVoice) {
                utterance.voice = suitableVoice;
            }

            utterance.rate = 1.0;
            utterance.pitch = 1.0;
            utterance.volume = 1.0;

            utterance.onstart = function() {
                document.getElementById('tspeaker-btn').style.backgroundColor = '#4CAF50';
            };

            utterance.onend = function() {
                document.getElementById('tspeaker-btn').style.backgroundColor = '';
            };

            utterance.onerror = function(event) {
                console.error('Speech synthesis error:', event);
                document.getElementById('tspeaker-btn').style.backgroundColor = '';
                alert('Error playing speech. Please try again.');
            };

            speechSynthesis.speak(utterance);
        } else {
            alert('Speech synthesis is not supported in your browser');
        }
    }

    // Load voices when they become available
    if ('speechSynthesis' in window) {
        speechSynthesis.onvoiceschanged = function() {
            // Voices are now loaded
        };
    }

    // Copy button functionality (if needed)
    document.getElementById('trans-copy-btn').addEventListener('click', function() {
        const translationText = document.getElementById('translion-to-speak').value;

        if (!translationText.trim()) {
            alert('No text to copy');
            return;
        }

        navigator.clipboard.writeText(translationText).then(function() {
            // Optional: Show copied notification
            alert('Translation copied to clipboard!');
        }).catch(function(err) {
            console.error('Copy failed:', err);
            alert('Failed to copy text');
        });
    });
</script>
<script>
    // Translation functionality
    document.addEventListener('DOMContentLoaded', function() {
        // Use the Translate button from translator-btns div, not the microphone icon
        const translateBtn = document.querySelector('.translator-btns #translate-record-btn');
        const userInput = document.getElementById('user-trans-input');
        const translationOutput = document.getElementById('translion-to-speak');

        // Get both select wrappers
        const selectWrappers = document.querySelectorAll('.custom-select-wrapper');
        console.log("SelectWrappers: ",selectWrappers);
        const sourceLangSelect = selectWrappers[0];
        const targetLangSelect = selectWrappers[1];

        console.log('Translate button found:', translateBtn);
        console.log('Source lang:', sourceLangSelect.dataset.value);
        console.log('Target lang:', targetLangSelect.dataset.value);

        if (translateBtn) {
            translateBtn.addEventListener('click', function() {
                const textToTranslate = userInput.value.trim();

                if (!textToTranslate) {
                    alert('Please enter some text to translate!');
                    return;
                }

                // Get selected languages
                const sourceLang = sourceLangSelect.dataset.value || 'auto';
                const targetLang = targetLangSelect.dataset.value || 'en';

                console.log('Translating from:', sourceLang, 'to:', targetLang, 'Text:', textToTranslate);

                // Translate the text
                translateText(textToTranslate, sourceLang, targetLang);
            });
        } else {
            console.error('Translate button not found!');
        }

        function translateText(text, sourceLang, targetLang) {
            // Show loading state
            translationOutput.value = 'Translating...';

            const apiUrl = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${sourceLang}&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;

            console.log('API URL:', apiUrl);

            fetch(apiUrl)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('API Response received:', data);

                    let translatedText = '';

                    if (data && data[0]) {
                        data[0].forEach(item => {
                            if (item && item[0]) {
                                translatedText += item[0];
                            }
                        });
                    }

                    translationOutput.value = translatedText || 'Translation not available';

                    // Auto-resize the output textarea
                    translationOutput.style.height = 'auto';
                    translationOutput.style.height = translationOutput.scrollHeight + 'px';
                })
                .catch(error => {
                    console.error('Translation error:', error);
                    translationOutput.value = 'Translation failed. Please try again.';
                });
        }

        // Add reset functionality
        const resetBtn = document.querySelector('.translator-btns .text-btn:nth-child(2)');
        if (resetBtn) {
            resetBtn.addEventListener('click', function() {
                userInput.value = '';
                translationOutput.value = '';
                userInput.style.height = '200px';
                translationOutput.style.height = 'auto';

                // Reset to original languages from Model
                const sourceSelected = sourceLangSelect.querySelector('.selected');
                const targetSelected = targetLangSelect.querySelector('.selected');

                if (sourceSelected) {
                    sourceSelected.textContent = '@Model.lang1.Name';
                    sourceLangSelect.dataset.value = '@Model.lang1.Code';
                }

                if (targetSelected) {
                    targetSelected.textContent = '@Model.lang2.Name';
                    targetLangSelect.dataset.value = '@Model.lang2.Code';
                }

                console.log('Reset completed');
            });
        }
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const wrappers = document.querySelectorAll(".custom-select-wrapper");

        function closeAll(except = null) {
            wrappers.forEach(w => {
                if (w !== except) w.classList.remove("open");
            });
        }

        wrappers.forEach(wrapper => {
            const customSelect = wrapper.querySelector(".custom-select");
            const searchInput = wrapper.querySelector(".search-box input");
            const optionItems = Array.from(wrapper.querySelectorAll(".custom-options span[data-value]"));
            const selected = wrapper.querySelector(".custom-select .selected");

            // Toggle on header click
            customSelect.addEventListener("click", function (e) {
                e.stopPropagation();
                const willOpen = !wrapper.classList.contains("open");
                closeAll(willOpen ? wrapper : null);
                wrapper.classList.toggle("open");
                if (willOpen && searchInput) {
                    // focus search when opened
                    setTimeout(() => searchInput.focus(), 0);
                }
            });

            // Delegate clicks inside wrapper: only option clicks close+select
            wrapper.addEventListener("click", function (e) {
                e.stopPropagation();
                const option = e.target.closest("span[data-value]");
                if (option && wrapper.contains(option)) {
                    selected.textContent = option.textContent;
                    wrapper.dataset.value = option.dataset.value;
                    wrapper.classList.remove("open");
                }
                // other clicks inside wrapper (like search input) do nothing => dropdown stays open
            });

            // Live search (filter only this wrapper's options)
            if (searchInput) {
                searchInput.addEventListener("input", function () {
                    const filter = this.value.toLowerCase().trim();
                    optionItems.forEach(option => {
                        option.style.display = option.textContent.toLowerCase().includes(filter) ? "" : "none";
                    });
                    // keep it open while typing
                    if (!wrapper.classList.contains("open")) wrapper.classList.add("open");
                });
            }
        });

        // Click outside any wrapper closes all
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".custom-select-wrapper")) {
                closeAll();
            }
        });

        // Optional: close on Escape
        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") closeAll();
        });
    });

</script>
<script>
    const transTextarea = document.getElementById("user-trans-input");
    const transRecordBtn = document.getElementById("translate-record-btn");
    const transSpeakerBtn = document.getElementById("tspeaker-btn");
    const transCopyBtn = document.getElementById("trans-copy-btn");
    const transResult = document.getElementById("translion-to-speak");

    // ✅ Auto resize textarea
    function transAutoResize(el) {
        el.style.height = "auto";
        el.style.height = el.scrollHeight + "px";
    }
    transTextarea.addEventListener("input", function () {
        transAutoResize(this);
    });
    transAutoResize(transTextarea);

    // To Speak Answer
    function setupTextToSpeech(textId, btnId) {
        const textEl = document.getElementById(textId);
        const btnEl = document.getElementById(btnId);

        btnEl.addEventListener("click", function () {
            const text = textEl.innerText || textEl.value || ""; // p ya textarea dono handle
            if (text.trim() !== "") {
                let utterance = new SpeechSynthesisUtterance(text);

                // 🔥 Start bolte hi active class add
                btnEl.classList.add("active");

                // 🔥 Jab bolna khatam ho jaye to remove kar do
                utterance.onend = function () {
                    btnEl.classList.remove("active");
                };

                // Agar kisi wajah se cancel ho jaye (user stop kar de ya naya bolna start ho jaye)
                utterance.onerror = function () {
                    btnEl.classList.remove("active");
                };

                speechSynthesis.speak(utterance);
            } else {
                alert("Please enter some text first!");
            }
        });
    }
    // Call function with IDs
    setupTextToSpeech("translion-to-speak", "tspeaker-btn");

    function setupCopyFunction(textId, btnId) {
        const textEl = document.getElementById(textId);
        const btnEl = document.getElementById(btnId);

        btnEl.addEventListener("click", function () {
            let textToCopy = textEl.value || textEl.innerText || "";

            if (textToCopy.trim() !== "") {
                navigator.clipboard.writeText(textToCopy).then(() => {
                    // original button text ya icon save kar lo
                    let originalHTML = btnEl.innerHTML;

                    // btn update
                    btnEl.classList.add("active");

                    // 0.5s ke baad wapis original
                    setTimeout(() => {
                        btnEl.classList.remove("active");
                    }, 500);
                });
            }
        });
    }

    // Call function
    setupCopyFunction("translion-to-speak", "trans-copy-btn");
</script>





