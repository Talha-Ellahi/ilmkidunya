@model IEnumerable<dynamic>
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
 @section MetaData {
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
	<meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
	<meta property="og:image" content="" />
	<meta name="description" content="@ViewBag.CmsData.MetaDesc">
	<meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	
	<title>@ViewBag.CmsData.MetaTitle</title>
}
@section header {

				<div class="col-lg-11">
					<ul class="navigation">
						<li>
							<a aria-label="link" href="/admissions/">
								<img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
								Home
							</a>
						</li>
						<li>
							<a aria-label="link" href="/admissions/city-wise-admission.aspx">
								<img src="https://images.ishallwin.com/nav-icons/menu-icon-2.webp" alt="image" />
								City Wise Admissions
							</a>
						</li>
						<li>
							<a aria-label="link" href="/admissions/level-wise-admissions.aspx">
								<img src="https://images.ishallwin.com/nav-icons/menu-icon-3.webp" alt="image" />
								Level wise Admissions
							</a>
						</li>
						<li>
							<a aria-label="link" href="/admissions/categories-wise-admissions.aspx">
								<img src="https://images.ishallwin.com/nav-icons/menu-icon-4.webp" alt="image" />
								Category wise Admissions
							</a>
						</li>
						<li>
							<a aria-label="link" href="/admissions/most-popular-admissions-pakistan.aspx">
								<img src="https://images.ishallwin.com/nav-icons/menu-icon-5.webp" alt="image" />
								Popular Admissions
							</a>
						</li>

					</ul>
				</div>
			
		
}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@ViewBag.CmsData.Heading</h1>
					</div>
				</div>
				
			</div>
		</div>
	</div>
}

<div id="main">

	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.Raw(ViewBag.CmsData.Desc1)
				</div>
			</div>
		</div>
	</div>
	
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					<ul class="ss-ads" style="border: 0; padding-top: 0; margin:30px 0 0 0;">
						@await Html.PartialAsync("_maincontenttopbanner")
					</ul>
				</div>
			</div>
		</div>
	</div>
	<div class="study-institute contact-sec" style="padding-bottom: 0;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<h2 style="display: flex; flex-wrap: wrap; justify-content: space-between; margin-bottom: 15px;">Latest Admissions in Top Colleges/Universities of Pakistan <a style="font-size: 15px; font-weight: normal;" </a></h2>
					<ul class="institute-list" id="admissionList">
						@foreach (var item in Model)
						{
							<li>
								<a href="/colleges/@(item.CollegeUrl)-admission.aspx" aria-label="link">
									<div class="img-holder">
										<figure><img src="https://cdn.ilmkidunya.com/Inst/logos/@item.CollageLogo" alt="" /></figure>
									</div>
									<div class="author">
										<span>@item.CollegeName</span>
									</div>
								</a>
							</li>
						}
					</ul>
					<p style="text-align: center;">
						<button type="button" class="load-more-button" id="loadMoreBtn">Load More</button>
					</p>
					<div class="share-box" style="float: left; padding-top: 30px;">
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontentlowerbanner")
				</div>
			</div>
		</div>
	</div>
	
</div>
<script>
	let currentPage = 1;

	const loadMoreBtn = document.getElementById('loadMoreBtn');
	const admissionList = document.getElementById('admissionList');
	

	if (loadMoreBtn && admissionList) {
		loadMoreBtn.addEventListener('click', function () {
			currentPage++;
			loadMoreBtn.innerHTML = 'Loading...';
			loadMoreBtn.disabled = true;

			fetch(`/admissions/latest-admissions-in-top-colleges-universities-of-pakistan?page=${currentPage}&pageSize=50`, {
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				}
			})
			.then(response => response.json())
			.then(data => {
				if (data.length === 0) {
					loadMoreBtn.innerHTML = 'No More Colleges';
					loadMoreBtn.disabled = true;
					return;
				}

				data.forEach(item => {
					const li = document.createElement('li');
					li.innerHTML = `
						<a href="#" aria-label="link">
			<div class="img-holder">
				<figure>
					<img src="https://cdn.ilmkidunya.com/Inst/logos/${item.collageLogo}" alt="${item.collegeName}" />
				</figure>
			</div>
			<div class="author">
				<span>${item.collegeName}</span>
			</div>
		</a>
					`;
					admissionList.appendChild(li);
				});

				loadMoreBtn.innerHTML = 'Load More Colleges';
				loadMoreBtn.disabled = false;
			})
			.catch(error => {
				console.error('Error loading more Colleges:', error);
				loadMoreBtn.innerHTML = 'Error loading Colleges';
				loadMoreBtn.disabled = false;
			});
		});
	}
</script>

