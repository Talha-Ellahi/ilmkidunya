<script>
	let scriptLoaded = false;

	function loadShareThisScript() {
		if (!scriptLoaded) {
		const script = document.createElement("script");
		script.id = "sharethis";
		script.type = "text/javascript";
		script.src = "https://platform-api.sharethis.com/js/sharethis.js#property=64e86dff0ba20000199f75ba&product=sop";
		script.async = true;
		script.defer = true;
		document.body.appendChild(script);
		scriptLoaded = true; // Ensure the script is loaded only once
		window.removeEventListener("scroll", loadShareThisScript); // Remove the scroll listener
		}
	}

	window.addEventListener("scroll", loadShareThisScript);
</script>
<script>
		window.addEventListener('scroll', function () {
		// Check if the share-box exists
		const shareBox = document.querySelector('.share-box');
		if (shareBox) {
			// Check if the ShareThis div already exists
			let newDiv = shareBox.querySelector('.sharethis-inline-share-buttons');
			if (!newDiv) {
				// Create the new ShareThis div element
				newDiv = document.createElement('div');
				newDiv.className = 'sharethis-inline-share-buttons';
				newDiv.style.marginBottom = '20px';

				// Append the new div to the share-box
				shareBox.appendChild(newDiv);

				// Initialize ShareThis (requires reinitialization for dynamic elements)
				if (window.__sharethis__) {
					window.__sharethis__.load('inline-share-buttons', '64e86dff0ba20000199f75ba');
				}
			}
		} else {
			console.error('Error: share-box not found.');
		}
	});
</script>
