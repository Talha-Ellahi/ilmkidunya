                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Set-wise Question Popups -->
                @for (int setIndex = 0; setIndex < Model.QuestionSets.Count; setIndex++)
                {
                    var questionSet = Model.QuestionSets[setIndex];
                    <div class="question-side shortquestion-box set-popup" id="set-pol-mode-@setIndex" data-set-index="@setIndex">
                        <div class="question-box">
                            <div class="top-box">
                                <h2>@Model.TestName - @questionSet.SetName</h2>

                                <div class="close-btn">
                                    <a href="javascript:void(0)" class="setclose" data-set-index="@setIndex"><img src="https://images.ishallwin.com/ot-images/red-cross.webp" alt=""></a>
                                </div>
                            </div>
                            <div class="holder-question short-qestion-holder">
                                @for (int i = 0; i < questionSet.Questions.Count; i++)
                                {
                                    var question = questionSet.Questions[i];
                                    <div class="mid-box" data-question-number="@(i + 1)" style="display: @(i == 0 ? "block" : "none");">
                                        <strong>Question # @(i + 1)</strong>
                                        <h3>@Html.Raw(question.QuestionDescription)</h3>
                                        @if (!string.IsNullOrWhiteSpace(question.QuestionImage))
                                        {
                                            <img src="https://ikddata.ilmkidunya.com/images/short-question/Q_@(question.QuestionId)_@(question.QuestionImage)" alt="pic" />
                                        }
                                        <ul>
                                            @for (int j = 0; j < question.Answers.Count; j++)
                                            {
                                                var answer = question.Answers[j];
                                                <li>
                                                    <span>Ans @(j + 1):</span> @Html.Raw(answer.ChoiceDescription)
                                                    @if (!string.IsNullOrWhiteSpace(answer.ChoiceImage))
                                                    {
                                                        <img src="https://ikddata.ilmkidunya.com/images/short-question/Ans_@(answer.ChoiceId)_Q_@(question.QuestionId)_@(answer.ChoiceImage)" alt="pic" />
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                            <div class="last-box">
                                <a href="javascript:void(0)" class="prev disabled" style="background-color: rgb(204, 204, 204);"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt=""></a>
                                <a href="javascript:void(0)" class="next" style="background-color: rgb(111, 229, 125);"><img src="https://images.ishallwin.com/ot-images/arrow-down.webp" alt=""></a>
                            </div>

                            <!-- Fake Submit -->
                            <a href="javascript:void(0)" class="text-btn" style="margin: 30px 0 0 30px;">Submit</a>
                        </div>
                    </div>
                }

                <style>
                    .question-side {
                        position: fixed;
                        right: -100%;
                        top: 0;
                        opacity: 0;
                        visibility: hidden;
                        z-index: 999;
                        transition: 0.3s ease-in-out;
                        width: 800px;
                        height: 100vh;
                        overflow-y: auto;
                        background: #fff;
                    }

                        .question-side.visible-pol {
                            right: 0;
                            opacity: 1;
                            visibility: visible;
                        }

                    .set-popup {
                        display: none;
                    }

                        .set-popup.visible-pol {
                            display: block;
                        }
                </style>

                <script>
                    const targetBox = document.getElementById("pol-mode");
                    const closeBtn = document.getElementById("close");

                    // First popup - main set
                    function shortQuestionPolOpen(setIndex) {
                        targetBox.classList.toggle("visible-pol");
                    }

                    closeBtn.addEventListener("click", () => {
                        targetBox.classList.remove("visible-pol");
                    });

                    document.addEventListener("click", (e) => {
                        if (targetBox.classList.contains("visible-pol") &&
                            !targetBox.contains(e.target) &&
                            !e.target.matches("#launch-test-btn")) {
                            targetBox.classList.remove("visible-pol");
                        }
                    });

                    // Set-wise popups
                    function openAnsMode(setIndex) {
                        // Hide all set popups first
                        document.querySelectorAll('.set-popup').forEach(popup => {
                            popup.classList.remove('visible-pol');
                        });

                        // Show the selected set popup
                        const selectedPopup = document.getElementById(`set-pol-mode-${setIndex}`);
                        if (selectedPopup) {
                            selectedPopup.classList.add('visible-pol');
                        }
                    }

                    document.querySelectorAll('.setclose').forEach(btn => {
                        btn.addEventListener('click', function() {
                            const setIndex = this.getAttribute('data-set-index');
                            const popup = document.getElementById(`set-pol-mode-${setIndex}`);
                            if (popup) {
                                popup.classList.remove('visible-pol');
                            }
                        });
                    });

                    document.addEventListener("click", (e) => {
                        if (e.target.matches('.set-launch-btn')) {
                            return; // Don't close if clicking on launch button
                        }

                        document.querySelectorAll('.set-popup').forEach(popup => {
                            if (popup.classList.contains('visible-pol') &&
                                !popup.contains(e.target) &&
                                !e.target.matches('.set-launch-btn')) {
                                popup.classList.remove('visible-pol');
                            }
                        });
                    });

                    // Navigation for all popups
                    document.addEventListener("DOMContentLoaded", function () {
                        function initPopupNavigation(popupElement) {
                            if (!popupElement) return;

                            let midBoxes = popupElement.querySelectorAll(".mid-box");
                            let nextBtn = popupElement.querySelector(".next");
                            let prevBtn = popupElement.querySelector(".prev");
                            let currentIndex = 0;

                            // Hide all first
                            midBoxes.forEach((box) => (box.style.display = "none"));

                            // Show first question
                            if (midBoxes.length > 0) {
                                midBoxes[0].style.display = "block";
                            }

                            function showBox(index) {
                                midBoxes.forEach((box, i) => {
                                    box.style.display = i === index ? "block" : "none";
                                });

                                // Reset buttons
                                prevBtn.classList.remove("disabled");
                                nextBtn.classList.remove("disabled");
                                prevBtn.style.backgroundColor = "#6FE57D";
                                nextBtn.style.backgroundColor = "#6FE57D";

                                // Disable prev on first
                                if (index === 0) {
                                    prevBtn.classList.add("disabled");
                                    prevBtn.style.backgroundColor = "#ccc";
                                }
                                // Disable next on last
                                if (index === midBoxes.length - 1) {
                                    nextBtn.classList.add("disabled");
                                    nextBtn.style.backgroundColor = "#ccc";
                                }
                            }

                            // Next button
                            if (nextBtn) {
                                nextBtn.addEventListener("click", function () {
                                    if (currentIndex < midBoxes.length - 1) {
                                        currentIndex++;
                                        showBox(currentIndex);
                                    }
                                });
                            }

                            // Prev button
                            if (prevBtn) {
                                prevBtn.addEventListener("click", function () {
                                    if (currentIndex > 0) {
                                        currentIndex--;
                                        showBox(currentIndex);
                                    }
                                });
                            }

                            // Initial state
                            showBox(currentIndex);
                        }

                        // Init navigation for main popup
                        initPopupNavigation(document.getElementById("pol-mode"));

                        // Init navigation for all set popups
                        document.querySelectorAll('.set-popup').forEach(popup => {
                            initPopupNavigation(popup);
                        });
                    });
                </script>
            </div>
        </div>
    </div>
