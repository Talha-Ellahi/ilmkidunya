@model IKDFrontEnd.ViewModels.DateSheetCriteria
@using System.Text.RegularExpressions
@using System.Text.Encodings.Web


@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}





@section MetaData {
	@{
		var metaTitle = Model?.MetaTitle ?? "";
		var metaDescription = Model?.MetaDescription ?? "";
		var metaKeywords = Model?.MetaKeywords ?? "";
        
	}

	<meta charset="utf-8">
	<meta property="og:title" content="@metaTitle" />
	<meta property="og:description" content="@metaDescription" />
	<meta property="og:image" content="" />
	<meta name="description" content="@metaDescription">
	<meta name="keywords" content="@metaKeywords">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>@metaTitle</title>
}
@section header {
	<div class="col-lg-11">
		<partial name="_NavBarPartial" />
	</div>
}
@section innerbanner {
		@{
		var heading = Model?.Heading ?? "";
		}
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@heading</h1>
						@if (Model.Desc2 != null)
						{
							@Html.Raw(
													Regex.Replace(
													Model.Desc2
													
													.Replace("https://www.ilmkidunya.com", ""),
													@"##.*?##", ""
													)
													)

						}
					</div>
				</div>
			</div>
		</div>
	</div>
}

<div id="main">
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
				<div class="ckeditorcontent">

					@if (!string.IsNullOrWhiteSpace(Model.Desc1))
					{
						var cleanedDesc = Model.Desc1.Replace("https://www.ilmkidunya.com", "");
						var parts = cleanedDesc.Split("[[CRITERIA_PLACEHOLDER]]");

						@Html.RenderWithAds(parts[0])
						<div class="page-font">
							@await Html.PartialAsync("_DateSheetCriteriaPartial", Model)
						</div>
						@Html.RenderWithAds(parts.Length > 1 ? parts[1] : "")
					}
				</div>
				</div>

			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					<ul class="ss-ads" style="border: 0; padding-top: 0; margin: 0;">
						@await Html.PartialAsync("_maincontenttopbanner")
					</ul>
				</div>
			</div>
		</div>
	</div>
	<div class="contact-sec fee-box">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
				

				</div>
			</div>
		</div>
	</div>
	

</div>




<script>
    function ShowMore(chk) {
        var txt = $(chk).children('span').text();

        if (txt == "- LESS") {
            $(chk).children('span').text("+ MORE");
            $(".h").hide("fast");
        }
        else {
            $(chk).children('span').text("- LESS");
            $(".h").show("fast");
        }




    }




</script>


<script>
    function showmore2() {
        debugger;
        document.getElementById("showmore").style.display = "block";
        document.getElementById("btnshowless").style.display = "block";
        document.getElementById("btnshowmore").style.display = "none";


    }
    function showless() {
        document.getElementById("btnshowmore").style.display = "block";
        document.getElementById("showmore").style.display = "none";
        document.getElementById("btnshowless").style.display = "none";



    }
</script>