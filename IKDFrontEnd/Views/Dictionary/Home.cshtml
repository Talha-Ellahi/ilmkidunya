                    <h2>Top Trending Urdu To English Words</h2>
                    <div class="responsive-table">
                        <table class="table" id="urduToEnglishTable">
                            <thead>
                                <tr>
                                    <th><span>Sr. #</span></th>
                                    <th><span>Urdu</span></th>
                                    <th><span>English</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var existingUrToEnMeanings = ViewBag.ExistingUrToEnMeanings as Dictionary<string, string>;
                                }
                                @foreach (var item in (List<WordPair>)ViewBag.UrduToEnglish)
                                {
                                    var existingMeaning = existingUrToEnMeanings != null && existingUrToEnMeanings.ContainsKey(item.Urdu.ToLower())
                                    ? existingUrToEnMeanings[item.Urdu.ToLower()]
                                    : "";

                                    <tr data-urdu-word="@item.Urdu">
                                        <td>@item.SrNo</td>
                                        <td>
                                            <a href="/dictionary/@item.Urdu.Replace(" ", "-")-meaning-in-english" class="urdu-link" data-urdu-word="@item.Urdu">
                                                <span class="dict-urdu-word">@item.Urdu</span>
                                            </a>
                                        </td>
                                        <td>
                                            <span class="dict-english-word"
                                                  data-word="@item.Urdu"
                                                  data-lang="ur-en"
                                                  data-existing-meaning="@existingMeaning">
                                                @if (!string.IsNullOrEmpty(existingMeaning))
                                                {
                                                    @existingMeaning
                                                }
                                                else
                                                {
                                                    <span class="loading">Loading...</span>
                                                }
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                            <script>
                                document.addEventListener('DOMContentLoaded', function() {
                                    // Function to decode HTML entities
                                    function decodeHtmlEntities(text) {
                                        if (!text) return text;
                                        const textArea = document.createElement('textarea');
                                        textArea.innerHTML = text;
                                        return textArea.value;
                                    }

                                    // Function to fix encoded URLs in anchor tags
                                    function fixEncodedUrls() {
                                        console.log('🔗 Fixing encoded URLs...');

                                        const urduLinks = document.querySelectorAll('.urdu-link');
                                        urduLinks.forEach(link => {
                                            const currentHref = link.getAttribute('href');
                                            const urduWord = link.getAttribute('data-urdu-word');

                                            // If URL contains encoded entities, fix it
                                            if (currentHref && (currentHref.includes('&amp;#x') || currentHref.includes('&#x'))) {
                                                console.log('Found encoded URL:', currentHref);

                                                // Decode the URL
                                                const decodedUrl = decodeHtmlEntities(currentHref);
                                                link.setAttribute('href', decodedUrl);
                                                console.log('Fixed URL:', decodedUrl);
                                            }

                                            // Also ensure the data attribute is decoded
                                            if (urduWord && (urduWord.includes('&amp;#x') || urduWord.includes('&#x'))) {
                                                const decodedWord = decodeHtmlEntities(urduWord);
                                                link.setAttribute('data-urdu-word', decodedWord);
                                            }
                                        });
                                    }

                                    // Function to fix displayed text
                                    function fixDisplayedText() {
                                        console.log('📝 Fixing displayed text...');

                                        document.querySelectorAll('.dict-urdu-word, .dict-english-word').forEach(el => {
                                            const currentHtml = el.innerHTML;
                                            if (currentHtml.includes('&amp;#x') || currentHtml.includes('&#x')) {
                                                console.log('Found encoded text:', currentHtml);

                                                // Decode the text
                                                const decodedHtml = decodeHtmlEntities(currentHtml);
                                                el.innerHTML = decodedHtml;
                                                console.log('Fixed text:', decodedHtml);
                                            }
                                        });
                                    }

                                    // Function to fix all data attributes
                                    function fixDataAttributes() {
                                        console.log('🏷️ Fixing data attributes...');

                                        // Fix data attributes on table rows
                                        document.querySelectorAll('tr[data-urdu-word]').forEach(row => {
                                            const urduWord = row.getAttribute('data-urdu-word');
                                            if (urduWord && (urduWord.includes('&amp;#x') || urduWord.includes('&#x'))) {
                                                const decodedWord = decodeHtmlEntities(urduWord);
                                                row.setAttribute('data-urdu-word', decodedWord);
                                                console.log('Fixed row data:', decodedWord);
                                            }
                                        });

                                        // Fix data attributes on english word spans
                                        document.querySelectorAll('.dict-english-word').forEach(el => {
                                            const wordAttr = el.getAttribute('data-word');
                                            const meaningAttr = el.getAttribute('data-existing-meaning');

                                            if (wordAttr && (wordAttr.includes('&amp;#x') || wordAttr.includes('&#x'))) {
                                                const decodedWord = decodeHtmlEntities(wordAttr);
                                                el.setAttribute('data-word', decodedWord);
                                                console.log('Fixed data-word:', decodedWord);
                                            }

                                            if (meaningAttr && (meaningAttr.includes('&amp;#x') || meaningAttr.includes('&#x'))) {
                                                const decodedMeaning = decodeHtmlEntities(meaningAttr);
                                                el.setAttribute('data-existing-meaning', decodedMeaning);
                                                console.log('Fixed data-existing-meaning:', decodedMeaning);
                                            }
                                        });
                                    }

                                    // Run all fixes
                                    function runAllFixes() {
                                        console.log('🔄 Running all text decoding fixes...');
                                        fixEncodedUrls();
                                        fixDisplayedText();
                                        fixDataAttributes();
                                        console.log('✅ All fixes completed');
                                    }

                                    // Run immediately
                                    runAllFixes();

                                    // Run again after delays to catch any dynamic content
                                    setTimeout(runAllFixes, 100);
                                    setTimeout(runAllFixes, 500);
                                });
                            </script>
                        </table>
                    </div>

                    <script>
                        console.log('=== DICTIONARY HOME PAGE LOADED ===');

                        // Function to fetch translation from API with fallback
                        async function fetchTranslation(word, sourceLang, targetLang) {
                            console.log('🌐 Fetching translation for:', word, 'from', sourceLang, 'to', targetLang);

                            try {
                                // Try Google Translate first
                                console.log('   Trying Google Translate API...');
                                const googleUrl = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${sourceLang}&tl=${targetLang}&dt=t&q=${encodeURIComponent(word)}`;

                                const googleResponse = await fetch(googleUrl);
                                console.log('   Google API Response status:', googleResponse.status);

                                if (googleResponse.ok) {
                                    const googleData = await googleResponse.json();
                                    console.log('   Google API Response data:', googleData);

                                    if (googleData && googleData[0] && googleData[0][0] && googleData[0][0][0]) {
                                        const translatedText = googleData[0][0][0];
                                        console.log('   ✅ Google Translation successful:', translatedText);
                                        return translatedText;
                                    }
                                }

                                // Fallback to MyMemory API
                                console.log('   🔄 Google failed, trying MyMemory API...');
                                const myMemoryUrl = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(word)}&langpair=${sourceLang}|${targetLang}`;
                                const myMemoryResponse = await fetch(myMemoryUrl);
                                console.log('   MyMemory API Response status:', myMemoryResponse.status);

                                if (myMemoryResponse.ok) {
                                    const myMemoryData = await myMemoryResponse.json();
                                    console.log('   MyMemory API Response data:', myMemoryData);

                                    if (myMemoryData.responseStatus === 200 && myMemoryData.responseData && myMemoryData.responseData.translatedText) {
                                        console.log('   ✅ MyMemory Translation successful:', myMemoryData.responseData.translatedText);
                                        return myMemoryData.responseData.translatedText;
                                    }
                                }

                                console.log('   ❌ All translation APIs failed');
                                return "Translation not available";
                            } catch (error) {
                                console.error('   💥 Translation API error:', error);
                                return "Translation error";
                            }
                        }

                        // Function to save word and meaning to database
                        async function saveWordAndMeaning(sourceWord, sourceLangCode, targetWord, targetLangCode) {
                            console.log('💾 Saving word and meaning to database:', sourceWord, '->', targetWord);
                            try {
                                const requestData = {
                                    sourceWord: sourceWord,
                                    sourceLanguageCode: sourceLangCode,
                                    targetWord: targetWord,
                                    targetLanguageCode: targetLangCode
                                };

                                const response = await fetch('/dictionary/save-word-with-meaning', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify(requestData)
                                });

                                console.log('   Save API Response status:', response.status);

                                if (!response.ok) {
                                    throw new Error('Failed to save word data: ' + response.status);
                                }

                                const result = await response.json();
                                console.log('   ✅ Word and meaning saved successfully:', result);
                                return result;

                            } catch (error) {
                                console.error('   💥 Error saving word and meaning:', error);
                                return { success: false, message: error.message };
                            }
                        }

                        // Function to process a single translation element
                        async function processTranslationElement(element, sourceLang, targetLang) {
                            const word = element.getAttribute('data-word');
                            const existingMeaning = element.getAttribute('data-existing-meaning');

                            console.log(`🔍 Processing ${sourceLang} word: "${word}"`);
                            console.log('   Existing meaning from database:', existingMeaning);

                            // Skip if already has existing meaning and it's already displayed
                            if (existingMeaning && existingMeaning !== "" && existingMeaning !== "Loading...") {
                                console.log('   ✅ Using existing meaning from database');
                                // Check if the element still shows "Loading..." and needs to be updated
                                if (element.textContent.includes('Loading...') || element.querySelector('.loading')) {
                                    element.innerHTML = existingMeaning;
                                }
                                return; // Skip API call
                            }

                            // If we get here, we need to call the API
                            console.log('   🌐 Fetching translation from API...');
                            const translation = await fetchTranslation(word, sourceLang, targetLang);
                            console.log('   📨 Translation result:', translation);

                            if (translation && translation !== "Translation not available" && translation !== "Translation error") {
                                console.log('   ✅ Translation successful, updating UI and saving to DB');
                                element.textContent = translation;

                                // Save to database for future use
                                await saveWordAndMeaning(word, sourceLang, translation, targetLang);
                            } else {
                                console.log('   ❌ Translation failed, showing fallback');
                                element.textContent = translation || "N/A";
                            }
                        }

                        // Function to update all translations
                        async function updateAllTranslations() {
                            console.log('🔄 Starting translation updates...');

                            // Urdu to English translations
                            const urToEnElements = document.querySelectorAll('[data-lang="ur-en"]');
                            console.log('📊 Found Urdu to English elements:', urToEnElements.length);

                            for (const element of urToEnElements) {
                                await processTranslationElement(element, 'ur', 'en');

                                // Add delay to avoid rate limiting
                                console.log('   ⏳ Waiting 500ms before next translation...');
                                await new Promise(resolve => setTimeout(resolve, 500));
                            }

                            // English to Urdu translations
                            const enToUrElements = document.querySelectorAll('[data-lang="en-ur"]');
                            console.log('📊 Found English to Urdu elements:', enToUrElements.length);

                            for (const element of enToUrElements) {
                                await processTranslationElement(element, 'en', 'ur');

                                // Add delay to avoid rate limiting
                                console.log('   ⏳ Waiting 500ms before next translation...');
                                await new Promise(resolve => setTimeout(resolve, 500));
                            }

                            console.log('✅ All translations completed');
                        }

                        // Initialize translations when page loads
                        document.addEventListener('DOMContentLoaded', function() {
                            console.log('🚀 Starting translation process...');

                            // First, immediately update any elements that have existing meanings
                            const allTranslationElements = document.querySelectorAll('[data-lang]');
                            allTranslationElements.forEach(element => {
                                const existingMeaning = element.getAttribute('data-existing-meaning');
                                if (existingMeaning && existingMeaning !== "" && existingMeaning !== "Loading...") {
                                    if (element.textContent.includes('Loading...') || element.querySelector('.loading')) {
                                        element.innerHTML = existingMeaning;
                                        console.log('🔄 Immediately updated existing meaning for:', element.getAttribute('data-word'));
                                    }
                                }
                            });

                            // Then start the API translation process
                            updateAllTranslations();
                        });
                    </script>

                    <style>
                        .loading {
                            color: #666;
                            font-style: italic;
                        }
                    </style>

