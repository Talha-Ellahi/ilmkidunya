@using System.Net
@using IKDFrontEnd.ViewModels
@model LecturePageViewModel


@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["PageTitle2"] = Model.PageTitle2;
}
@section header {


				<div class="col-lg-11">
					<partial name="_NavBarPartial" />
				</div>
			


}
@section MetaData
{
	@if (Model != null && !string.IsNullOrEmpty(Model.MetaTitle) && !string.IsNullOrEmpty(Model.MetaDescription))
	{
		
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta property="og:title" content="@Model.MetaTitle" />
		<meta property="og:description" content="@Model.MetaDescription" />
		<meta property="og:image" content="https://ikddata.ilmkidunya.com/images/{Model.MetaImage}" />
		<meta name="description" content="@Model.MetaDescription">
		<meta name="keywords" content="@Model.MetaKeywords">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
		<title>@Model.MetaTitle</title>
	}
	else
	{
		
		<title>Pakistan Education News Colleges Scholarship Result Admission Jobs | ilmkidunya</title>

		<meta name="description" content="Latest updates about Pakistan colleges universities, study visa, scholarships and study abroad information. Get information about courses, admission and result of all Pakistani universities and colleges." />
		<meta name="keywords" content="ilmkidunya, education, educational, news, colleges, universities, result, admission, jobs, scholarship, visa, study, abroad, courses, pakistan, pakistani, information" />
		<meta property="og:image" content="https://ikddata.ilmkidunya.com/images/ilmkidunya-logo-2.jpg" />
		<meta property="og:image:width" content="200" />
		<meta property="og:image:height" content="200" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
	}
}


@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						@if (!string.IsNullOrEmpty(Model.PageHeading))
						{
							<h1>@Model.PageHeading</h1>
							@* <p>@Model.MetaDescription</p> *@
						}
						else
						{
							// If PageHeading is null, use PageTitle2 with transformations
							string modifiedPageTitle2 = Model.PageTitle2;

							// Remove hyphens from the PageTitle2
							modifiedPageTitle2 = modifiedPageTitle2.Replace("-", " ");

							// Check and replace specific parts of the PageTitle2
							if (modifiedPageTitle2.Contains("mdcat class"))
							{
								modifiedPageTitle2 = modifiedPageTitle2.Replace("mdcat class", "Mdcat Test");
							}
							else if (modifiedPageTitle2.Contains("ecat class"))
							{
								modifiedPageTitle2 = modifiedPageTitle2.Replace("ecat class", "Ecat Test");
							}

							// Capitalize the first letter of each word
							modifiedPageTitle2 = modifiedPageTitle2.ToLower();
							modifiedPageTitle2 = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(modifiedPageTitle2);

							// Correct "Th" to "th"
							modifiedPageTitle2 = modifiedPageTitle2.Replace("Th", "th");

							// Display the transformed PageTitle2
							<h1>Free @modifiedPageTitle2 Online Video Lectures in Urdu - @DateTime.Now.Year</h1>
							@* <p>Free  @modifiedPageTitle2 Online Video Lectures in Urdu - @DateTime.Now.Year</p> *@
						}
					</div>


				</div>
			</div>
		</div>
	</div>
}

<div id="main">
	<div class="ss-class-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<ul class="ss-class-list ss-book-list">
						@if (Model.LectureSubjects != null && Model.LectureSubjects.Any())
						{
							@foreach (var subject in Model.LectureSubjects)
							{
								<li>
									<a href="@("/study/" + Model.CurrentClassSlug + "-" + subject.Name.Replace(" ","-").ToLower() + ".aspx")">
										<div class="inner-text">
											<figure>
												<img src="https://cdn.ilmkidunya.com/lectures/subject/@subject.Image"
													 alt="@subject.Name"
													 @* style="width: 290px; height: 145px;" *@ />
												<figcaption>@subject.Name</figcaption>
											</figure>
										</div>

									</a>
								</li>
							}
						}
						else
						{
							<li>
								<p>No subjects found for this class.</p>
							</li>
						}
					</ul>
				</div>
			</div>
		</div>
	</div>

	<div class="content-sec" style="padding: 0 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if(!string.IsNullOrEmpty(Model.PageDescription1))
					{
						<p>@Html.Raw(WebUtility.HtmlDecode(Model.PageDescription1))</p>
					}
					else
					{
					string modifiedPageTitle2 = Model.PageTitle2;

					// Remove hyphens from the PageTitle2
					modifiedPageTitle2 = modifiedPageTitle2.Replace("-", " ");

					// Check and replace specific parts of the PageTitle2
					if (modifiedPageTitle2.Contains("mdcat class"))
					{
					modifiedPageTitle2 = modifiedPageTitle2.Replace("mdcat class", "Mdcat Test");
					}
					else if (modifiedPageTitle2.Contains("ecat class"))
					{
					modifiedPageTitle2 = modifiedPageTitle2.Replace("ecat class", "Ecat Test");
					}

					// Capitalize the first letter of each word
					modifiedPageTitle2 = modifiedPageTitle2.ToLower();
					modifiedPageTitle2 = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(modifiedPageTitle2);

					// Correct "Th" to "th"
					modifiedPageTitle2 = modifiedPageTitle2.Replace("Th", "th");

					
					<p>Free  @modifiedPageTitle2 Online Video Lectures in Urdu - @DateTime.Now.Year</p>
					}


			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
						@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
		<div class="g-add-sec" style="padding: 30px 0 0 0;">
			<div class="container">
				<div class="row">
					@await Html.PartialAsync("_GoogleAd")
				</div>
			</div>
		</div>
	<div class="content-sec" style="padding: 0 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@if(!string.IsNullOrEmpty(Model.PageDescription2))
					{
							<p>@Html.Raw(WebUtility.HtmlDecode(Model.PageDescription2))</p>
						}
						else
						{
							string modifiedPageTitle2 = Model.PageTitle2;

							// Remove hyphens from the PageTitle2
							modifiedPageTitle2 = modifiedPageTitle2.Replace("-", " ");

							// Check and replace specific parts of the PageTitle2
							if (modifiedPageTitle2.Contains("mdcat class"))
							{
								modifiedPageTitle2 = modifiedPageTitle2.Replace("mdcat class", "Mdcat Test");
							}
							else if (modifiedPageTitle2.Contains("ecat class"))
							{
								modifiedPageTitle2 = modifiedPageTitle2.Replace("ecat class", "Ecat Test");
							}

							// Capitalize the first letter of each word
							modifiedPageTitle2 = modifiedPageTitle2.ToLower();
							modifiedPageTitle2 = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(modifiedPageTitle2);

							// Correct "Th" to "th"
							modifiedPageTitle2 = modifiedPageTitle2.Replace("Th", "th");

							
							
							<p>Free  @modifiedPageTitle2 Online Video Lectures in Urdu - @DateTime.Now.Year</p>
						}
					</div>
			</div>
		</div>
	</div>
		<div class="new-ads-sec">
			<div class="container">
				<div class="row">
					<div class="col-lg-12 col-md-12 col-sm-12">
						@await Html.PartialAsync("_maincontentlowerbanner")
					</div>
				</div>
			</div>
		</div>
</div>