<script>
	// Download the image in a new tab when "Download This Paper" is clicked
	document.getElementById('downloadBtn').onclick = function () {
		var imageUrl = document.getElementById('paperImage').src;
		if (imageUrl) {
			var a = document.createElement('a');
			a.href = imageUrl;
			a.download = 'PastPaper.jpg';  // Set the name of the file to be downloaded
			a.click();  // Trigger the download
		}
	};

	// Print the image when "Print This Paper" is clicked
	document.getElementById('printBtn').addEventListener('click', function () {
		const imgSrc = document.getElementById('paperImage').src;
		const printWindow = window.open('', '_blank');
		printWindow.document.write(`<img src="${imgSrc}" style="max-width: 100%;"/>`);
		printWindow.document.close();
		printWindow.print();
	});
</script>
