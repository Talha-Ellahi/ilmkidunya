<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <rewrite>
        <rules>
          <rule name="Redirect non-www to www" stopProcessing="true">
            <match url="(.*)" />
            <conditions>
              <add input="{HTTP_HOST}" pattern="^ilmkidunya\.com$" />
            </conditions>
            <action
              type="Redirect"
              url="https://www.ilmkidunya.com/{R:1}"
              redirectType="Permanent" />
          </rule>
        </rules>
      </rewrite>

      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>

      <aspNetCore
        processPath="dotnet"
        arguments=".\IKDFrontEnd.dll"
        stdoutLogEnabled="false"
        stdoutLogFile=".\logs\stdout"
        hostingModel="inprocess" />

    </system.webServer>
  </location>
</configuration>
