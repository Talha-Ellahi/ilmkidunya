@model IKDFrontEnd.ViewModels.CombinedSubjectCityLevelViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var random = new Random();
    var colorClasses = new[] { "sh-green", "sh-blue", "sh-purple", "sh-red" };
}


@section MetaData {
    @if (ViewBag.CmsData != null)
    {
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
        <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
        <meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
        <meta name="description" content="@ViewBag.CmsData.MetaDesc">
        <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        
        <title>@ViewBag.CmsData.MetaTitle</title>
    }
}

@section header {
    <!-- Header Start -->
    <div class="col-lg-11">
        <partial name="_JobsNavBar" />
    </div>
}

@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        <h1>Write down the subject or skill you want to learn.</h1>
                    </div>
                </div>
                <div class="ss-col-lg-12">
                    <form method="get" action="/tutors/searchresult.aspx" class="input-holder" onsubmit="return validateSearchForm(event);">
                        <div class="banner-form" style="margin: 0 5%;">
                            <div class="input-holder" style="width: 94%;">
                                <!-- Subject Dropdown -->
                                <div style="width: 50%; position: relative;">
                                    <select name="SubjID" aria-label="State" style="width: 100%; border-left: 0;">
                                        <option value="">Such as Mathematics, Physics etc..</option>
                                        @foreach (var subject in ViewBag.Subjects)
                                        {
                                            <option value="@subject.SubjectId">@subject.SubjectName</option>
                                        }
                                    </select>
                                </div>

                                <!-- Study Level Dropdown -->
                                <div style="width: 50%; position: relative;">
                                    <select name="LevelID" aria-label="State" style="width: 100%; border-left: 0;">
                                        <option value="">Your Study Level?</option>
                                        @foreach (var level in ViewBag.EducationLevel)
                                        {
                                            <option value="@level.EducationLevelId">@level.EducationLevelName</option>
                                        }
                                    </select>
                                </div>

                                <!-- City Dropdown -->
                                <div style="width: 50%; position: relative;">
                                    <select name="CityID" aria-label="State" style="width: 100%; border-left: 0;">
                                        <option value="">And Your City is?</option>
                                        @foreach (var city in ViewBag.Cities)
                                        {
                                            <option value="@city.CityId">@city.CityName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="btn-holder">
                                <button type="submit">
                                    <img src="https://images.ishallwin.com/search-icon.webp" alt="Search" style="height: 24px;" />
                                </button>
                            </div>
                        </div>
                    </form>


                </div>
            </div>
        </div>
    </div>

}

<!-- Main Start -->
<div id="main">
    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <p>
                        @if (ViewBag.CmsData != null)
                        {
                            @Html.Raw(ViewBag.CmsData.Desc1)
                        }

                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="content-sec level-wise">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Tutors Available for Following Subjects</h2>

                    <!-- Subjects with Tutor Counts -->
                    <ul class="admission-nav quizze-list">
                        @foreach (var subject in Model.Subjects)
                        {
                            var subjectSlug = subject.SubjectName.ToLower().Replace(" ", "-");

                            <li>
                                <a href="/tutors/home-tutors-for-@($"{subjectSlug}-{subject.SubjectId}.aspx")">
                                    <figure>
                                        <img src="@(!string.IsNullOrEmpty(subject.SubjectIcon) ? subject.SubjectIcon : "/images/default-subject.webp")" onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';" />
                                    </figure>

                                    <span style="padding-bottom:30px">@subject.SubjectName</span>
                                    <em>(@subject.TutorCount) Tutors</em>
                                </a>
                            </li>
                        }
                    </ul>
                    <style>
                        ul.admission-nav.quizze-list li a span {
                            line-height: normal !important;
                        }

                        .content-sec.level-wise ul.admission-nav li a span {
                            font-size: 13px;
                        }

                        .content-sec.level-wise ul.admission-nav li a em {
                            font-size: 13px;
                            display: block;
                            text-align: center;
                            font-style: normal;
                            line-height: 1.5;
                        }
                    </style>
                    <a href="/tutors/tutors-for-all-subjects.aspx">
                        <button type="button" class="load-more-button" id="loadMoreBtn">
                            View all subjects
                        </button>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12">
                @await Html.PartialAsync("_maincontenttopbanner")
            </div>
        </div>
    </div>
    <div class="content-sec level-wise">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Find Your Desired Tutors According to Educational Level</h2>
                    <p>Explore by Class</p>
                    <!-- EDUCATION LEVELS SECTION -->
                    <ul class="ss-class-list" style="padding-bottom: 20px;">
                        @foreach (var level in Model.EducationLevels)
                        {
                            var cssClass = colorClasses[random.Next(colorClasses.Length)];
                            var levelSlug = level.Url;

                            <li>
                                <a href="@($"/tutors/tutors-for-level-{levelSlug}.aspx?id={level.EducationLevelId}")" class="@cssClass">
                                    <div class="inner-text">
                                        <span>Tutor for</span>
                                        <strong>@level.EducationLevelName</strong>
                                        <em>@level.TutorCount Tutors</em>
                                    </div>
                                </a>
                            </li>
                        }

                    </ul>


                    <style>
                        ul.ss-class-list li a em {
                            display: block;
                            width: 100%;
                            font-size: 14px;
                            font-style: normal;
                            color: #15a18d;
                            transition: .3s ease-in-out;
                        }

                        ul.ss-class-list li a:hover em {
                            color: #fff;
                        }
                    </style>
                    <a href="/tutors/tutors-for-all-levels.aspx">
                        <button type="button" class="load-more-button" id="loadMoreBtn">
                            View all Educational Levels
                        </button>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="content-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Find Tutors to Learn New Skills</h2>
                    <div class="institute-list">
                        <ul class="skills-tutors">
                            @foreach (var skill in Model.Skills)
                            {
                                var subjectSlug = skill.SubjectName.ToLower().Replace(" ", "-");

                                <li>
                                    <a href="/tutors/home-tutors-for-@($"{subjectSlug}-{skill.SubjectId}.aspx")">
                                        <div class="figure">
                                            <img src="@skill.SubjectIcon"
                                                 onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';" />

                                        </div>
                                        <div class="author">
                                            @skill.SubjectName
                                            <em>@skill.TutorCount Tutors</em>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                        <style>
                            ul.skills-tutors li .author em {
                                display: block;
                                font-style: normal;
                                font-size: 13px;
                                color: #15a18d;
                            }
                        </style>
                        <a href="/tutors/tutors-for-all-skills.aspx">
                            <button type="button" class="load-more-button" id="loadMoreBtn">
                                View all Skills
                            </button>
                        </a>
                    </div>

                    <div style="    margin-top: 30px; margin-bottom: 30px;">
                        <h2>Find Your Desired Tutors According to City</h2>
                        <!-- Cities with Tutor Counts -->
                        <ul class="admission-nav" style="border: 0;">
                            @foreach (var city in Model.Cities)
                            {
                                var citySlug = new string(city.CityName
                                .Where(c => !char.IsDigit(c))
                                .ToArray())
                                .Trim()
                                .ToLower()
                                .Replace(" ", "-");

                                <li>
                                    <a href="/tutors/home-tutors-in-@($"{citySlug}.aspx")">
                                        <figure>
                                            <img src="@(!string.IsNullOrEmpty(city.ImageName) ? city.ImageName : "/images/default-city.webp")"  onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';" />
                                        </figure>
                                        <span style="display:none;">@city.CityId</span>
                                        <span>@city.CityName</span> <span>(@city.TutorCount Tutors)</span>
                                    </a>
                                </li>
                            }
                        </ul>
                        <a href="/tutors/tutors-for-all-cities.aspx">
                            <button type="button" class="load-more-button" id="loadMoreBtn">
                                View all Cities
                            </button>
                        </a>
                    </div>
                    <h2>Featured Tutors</h2>
                    <div class="institute-list">
                        <ul class="skills-tutors">
                            @foreach (var tutor in Model.LatestTutors)
                            {
                                var slug = tutor.TutorName.ToLower().Replace(" ", "-") + "-home-tutor-" + tutor.MemberId + ".aspx";

                                <li>
                                    <a aria-label="link" href="/tutors/@slug">
                                        <div class="figure">
                                            <img  src="@tutor.ProfileImage" onerror="this.onerror=null; this.src='https://www.ilmkidunya.com/ikd-noimg.png';" />
                                        </div>
                                        <div class="author" style="height:200px">
                                            <h4>@tutor.TutorName</h4>
                                            <span>@tutor.CityName | @tutor.CourseName</span>
                                            <p>Teaching</p>
                                            <span style="height:200px; overflow:hidden">@string.Join(", ", tutor.Subjects)...</span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-lg-12">
                    <div class="share-box">
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="contact-sec fee-box">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    @if (ViewBag.CmsData != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc3)
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    @await Html.PartialAsync("_maincontentlowerbanner")
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Main End -->
