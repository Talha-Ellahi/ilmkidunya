@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>Colleges, Universities List in All Pakistan Cities</h1>
						<p>
							List of Colleges, Universities List in All Pakistan Cities
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
}

