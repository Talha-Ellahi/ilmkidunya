@model IKDFrontEnd.ViewModels.GuideDetailViewModel
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css-files/style/studyabroad.css" rel="stylesheet" async>

@section MetaData {
	@{
		var metaTitle = Model?.MetaTitle ?? "Default Title";
		var metaDesc = Model?.MetaDesc ?? "Default description for this page.";
		var metaKeyword = Model?.MetaKeyword ?? "default, keywords, here";
		
	}

	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta property="og:title" content="@metaTitle" />
	<meta property="og:description" content="@metaDesc" />
	<meta property="og:image" content="" />
	<meta name="description" content="@metaDesc">
	<meta name="keywords" content="@metaKeyword">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>@metaTitle</title>
}


@section header {
	<div class="col-lg-11">
	<ul class="navigation">
		<li>
			<a aria-label="link" href="/consultants/">
				<img src="https://images.ishallwin.com/nav-icons/chem-nav-1.webp" alt="image" />
				Home
			</a>
		</li>
		<li>
			<a aria-label="link" href="/studyabroad/">
				<img src="https://www.ilmkidunya.com/icons/study-abroad.png"
					 alt="image" />
				studyabroad
			</a>
		</li>

		<li>
			<a aria-label="link" href="/studyabroad/country-guides.aspx">
				<img src="https://resources.ilmkidunya.com/ikd-guides/assets/images/icons/adm-icon.png"
					 alt="image" />
				Guides
			</a>
		</li>

		<li>
			<a aria-label="link" href="/scholarships/topscholarship">
				<img src="https://ikddata.ilmkidunya.com/icons/ic-courses-nav-colleges-2.png"
					 alt="image" />
				Top Scholarship
			</a>
		</li>
	</ul>
	</div>

}
@section innerbanner {
	<div class="ss-banner-inner">
		<div class="ss-container">
			<div class="ss-row">
				<div class="ss-col-lg-12">
					<div class="ss-text-holder">
						<h1>@(Model?.Heading ?? "No Heading Available")</h1>
						<p>
							@(Model?.HeadingDesc ?? "No description available.")
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
}

<div id="main">

	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.RenderWithAds(Model?.Detail ?? "")

				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<div class="std-consultant">
						<h2>All Consultants List</h2>
						<div class="tp-consultant-list" id="tp-consultant-list">
							@if (Model?.Consultants != null && Model.Consultants.Any())
							{
								foreach (var consultant in Model.Consultants)
								{
									var url = consultant?.Url ?? string.Empty;
									bool hasIdAtEnd = !string.IsNullOrEmpty(url) && char.IsDigit(url.Last());

									if (!hasIdAtEnd)
									{
										url += consultant?.Id ?? 0; // fallback to 0 if Id is null
									}

									<a href="/consultants/@(url).aspx" class="consultan-icon-bx box-cnslt1">
										@if (consultant?.PremiumMember == true)
										{
											<img class="premium-consltn"
												 src="https://ikddata.ilmkidunya.com/images/img-consultant-premimum.png" alt="Premium Consultant" />
										}

										<img src="https://cdn.ilmkidunya.com/StudyAbroad/Images/@(consultant?.Image ?? "default.png")"
											 alt="@((consultant?.Name ?? "Consultant") + " Image")" />

										<span>@(consultant?.Name ?? "Unknown Consultant")</span>
									</a>
								}
							}
							else
							{
								<p>No consultants available at the moment.</p>
							}
						</div>



					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="content-sec" style="padding: 30px 0 20px;">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					@Html.RenderWithAds(Model?.Detail2 ?? "")

				</div>
			</div>
		</div>
	</div>
	<div class="new-ads-sec">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-md-12 col-sm-12">
					@await Html.PartialAsync("_maincontenttopbanner")
				</div>
			</div>
		</div>
	</div>
	
	

</div>



