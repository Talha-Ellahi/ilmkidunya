@using System.Globalization
@model List<IKDFrontEnd.ViewModels.AllBooksViewModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://css.ishallwin.com/style/main-page.css" rel="stylesheet" async="">
<link href="https://www.ilmkidunya.com/css-files/common/style-min.css" rel="stylesheet" async="">
@section MetaData {
    @if (ViewBag.CmsData != null)
    {
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:title" content="@ViewBag.CmsData.MetaTitle" />
        <meta property="og:description" content="@ViewBag.CmsData.MetaDesc" />
        <meta property="og:image" content="https://www.ilmkidunya.com/images/logo.png" />
        <meta name="description" content="@ViewBag.CmsData.MetaDesc">
        <meta name="keywords" content="@ViewBag.CmsData.MetaKeys">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        
        <title>@ViewBag.CmsData.MetaTitle</title>
    }
}


@section header {
    <!-- Header Start -->


    <div class="col-lg-11">
        <partial name="_NavBarPartial" />
    </div>


}
<!-- Header End -->
@section innerbanner {
    <div class="ss-banner-inner">
        <div class="ss-container">
            <div class="ss-row">
                <div class="ss-col-lg-12">
                    <div class="ss-text-holder">
                        @if (ViewBag.CmsData != null)
                        {
                            <h1>@ViewBag.CmsData.Heading</h1>
                            @Html.Raw(ViewBag.CmsData.Desc2)
                        }
                        else
                        {
                            <h1>Welcome to Pakistan's Largest Book Store</h1>
                        }

                        <p>Search from @ViewBag.TotalBooksCount books</p>
                    </div>
                </div>
                <div class="ss-col-lg-12">
                    <form action="/store/search" method="get">
                        <div class="banner-form" style="margin: 0 30%;">

                            <div class="input-holder" style="width: 85%;">
                                <input type="text" name="keyword" placeholder="Search Books here" style="width: 100%;">
                            </div>
                            <div class="btn-holder">
                                <button type="submit">
                                    <img src="https://images.ishallwin.com/search-icon.webp" alt="Search">
                                </button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}


<!-- Main Start -->
<div id="main">
    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    @if (ViewBag.CmsData != null && ViewBag.CmsData.Desc1 != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc1)
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    <div class="my-ads">
                        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8866825487085085" data-ad-slot="7449924963" data-ad-format="auto" data-full-width-responsive="true"></ins>
                        <script>
                            (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12">
                @await Html.PartialAsync("_maincontenttopbanner")
            </div>
        </div>
    </div>
    <div class="content-sec" style="padding: 30px 0 20px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Search Results</h2>
                    <ul class="books-list">
                        @foreach (var book in Model)
                        {
                            <li>
                                <a href="/store/@book.Url">
                                    <figure>
                                        <img src="@book.Image" alt="@book.Name" />
                                    </figure>
                                    <strong>
                                        @CultureInfo.CurrentCulture.TextInfo.ToTitleCase(book.Name)
                                    </strong>
                                </a>
                            </li>
                        }
                    </ul>
                    <ul id="booksList" class="books-list">
                        @Html.Partial("_BooksListPartial", Model)
                    </ul>

                    <div class="loader" style="text-align: center; margin-bottom: 20px;">
                        <a href="javascript:void(0)"
                           class="button js-load-more"
                           id="loadMoreBtn"
                           style="display:inline-block; padding:10px 20px; background:#007bff; color:#fff; border-radius:4px; text-decoration:none;">
                            Load More
                        </a>
                    </div>

                    @section Scripts {
                        <script>
                            let skip = @Model.Count();
                            const take = 100;
                            const totalBooks = @ViewBag.TotalBooksCount;

                            document.getElementById("loadMoreBtn").addEventListener("click", function () {
                                const btn = this;

                                if (skip >= totalBooks) return;

                                // Show loading animation
                                btn.classList.add("load-more");
                                btn.innerHTML = 'Loading <span>.</span><span>.</span><span>.</span>';

                                fetch(`/store/all-books?skip=${skip}&take=${take}`, {
                                    headers: { "X-Requested-With": "XMLHttpRequest" }
                                })
                                .then(response => response.text())
                                .then(html => {
                                    document.getElementById("booksList").insertAdjacentHTML("beforeend", html);
                                    skip += take;

                                    if (skip >= totalBooks || html.trim() === '') {
                                        btn.parentElement.remove(); // remove loader container
                                    } else {
                                        btn.classList.remove("load-more");
                                        btn.textContent = "Load More";
                                    }
                                })
                                .catch(err => {
                                    console.error(err);
                                    btn.classList.remove("load-more");
                                    btn.textContent = "Load More";
                                });
                            });
                        </script>
                    }

                </div>
            </div>
        </div>
    </div>
    <div class="contact-sec fee-box" style="padding-top: 0;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    @if (ViewBag.CmsData != null && ViewBag.CmsData.Desc3 != null)
                    {
                        @Html.Raw(ViewBag.CmsData.Desc3)
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="new-ads-sec">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    @await Html.PartialAsync("_maincontentlowerbanner")
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Main End -->
