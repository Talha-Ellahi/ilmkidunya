<body class="amp-mode-mouse" style="opacity: 1; visibility: visible; animation: auto ease 0s 1 normal none running none; overflow: hidden !important;">

    <!-- __NEXT_DATA__ -->

    <amp-story standalone
               title="@Model.Slides.First().SliderName"
               publisher="Ilm Ki Dunya"
               publisher-logo-src="~/css/assets/images/slide-logo.png"
               poster-portrait-src="https://invent.ilmkidunya.com/nadmin/Sliders/@Model.Slides.First().MainSliderImage"
               class="jsx-89924fad709a1adb i-amphtml-layout-container"
               i-amphtml-layout="container">

        <!-- Cover Page -->
        <amp-story-page id="cover" auto-advance-after="5s" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
            <amp-story-grid-layer template="fill" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
              

                <amp-story-grid-layer template="fill" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
                    <amp-img src="https://invent.ilmkidunya.com/nadmin/Sliders/@Model.Slides.First().Image"
                             width="720" height="1280" alt="Slide Image"
                             layout="responsive"
                             class="jsx-89924fad709a1adb i-amphtml-layout-responsive i-amphtml-layout-size-defined"
                             i-amphtml-layout="responsive">
                    </amp-img>
                </amp-story-grid-layer>
            </amp-story-grid-layer>

            <amp-story-grid-layer template="vertical"
                                  class="jsx-89924fad709a1adb overlay-end cover-slide bottom i-amphtml-layout-container"
                                  i-amphtml-layout="container">
                <div class="jsx-89924fad709a1adb z-index-up cover-slide">
                    @{
                        bool isEnglishTitle = IsEnglish(Model.Slides.First().Slidertitle);
                    }

                    @if (isEnglishTitle)
                    {
                        <h1 animate-in="" animate-in-delay="0.5s" animate-in-duration="0.8s" class="jsx-89924fad709a1adb">
                            @Model.Slides.First().Slidertitle
                        </h1>
                    }
                    else
                    {
                        <h1 class="jsx-89924fad709a1adb urdu" animate-in=""
                            animate-in-delay="0.5s" animate-in-duration="0.8s">
                            @Model.Slides.First().Slidertitle
                        </h1>
                    }

                    <hr animate-in="" animate-in-delay="0.5s" animate-in-duration="0.8s" class="jsx-89924fad709a1adb">

                    <div class="jsx-89924fad709a1adb flx-box">
                        <div animate-in="" animate-in-delay="0.9s" animate-in-duration="0.7s"
                             class="jsx-89924fad709a1adb">
                            <span class="jsx-89924fad709a1adb name">By @Model.Slides.First().AuthorInfo</span>
                            <span class="jsx-89924fad709a1adb date">@Model.Slides.First().Date?.ToString("dd, MMM yyyy hh:mm tt")</span>
                            <span class="jsx-89924fad709a1adb site">ilmkidunya.com</span>
                        </div>
                        <span animate-in="" animate-in-delay="0.9s" animate-in-duration="0.7s"
                              class="jsx-89924fad709a1adb label">
                            <amp-img src="https://images.ishallwin.com/logo.svg"
                                     width="103" height="38" alt="IKD Logo"
                                     class="jsx-89924fad709a1adb i-amphtml-layout-fixed i-amphtml-layout-size-defined"
                                     style="width:103px;height:38px;" i-amphtml-layout="fixed">
                            </amp-img>
                        </span>
                    </div>
                </div>
            </amp-story-grid-layer>
        </amp-story-page>


        <!-- Dynamic Story Pages -->
        @foreach (var slide in Model.Slides.Skip(1))
        {
            <amp-story-page id="page-@slide.ID" auto-advance-after="5s" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
                <amp-story-grid-layer template="fill" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
                    <amp-img src="https://invent.ilmkidunya.com/nadmin/Sliders/@slide.Image"
                             width="720" height="1280" alt="Slide Image"
                             layout="responsive"
                             class="jsx-89924fad709a1adb i-amphtml-layout-responsive i-amphtml-layout-size-defined"
                             i-amphtml-layout="responsive">
                    </amp-img>
                </amp-story-grid-layer>

                <amp-story-grid-layer template="vertical"
                                      class="jsx-89924fad709a1adb bottom overlay-end-deep i-amphtml-layout-container"
                                      i-amphtml-layout="container">
                    <div class="jsx-89924fad709a1adb z-index-up text-white">
                        @{
                            bool isEnglishTitle1 = IsEnglish(slide.Slidertitle);
                            bool isEnglishDesc = IsEnglish(slide.SliderDesc);
                        }

                        @if (isEnglishTitle1)
                        {
                            <h3 animate-in="" animate-in-delay="0.3s" animate-in-duration="0.6s" class="jsx-89924fad709a1adb">@slide.Slidertitle</h3>
                        }
                        else
                        {
                            <h3 class="urdu jsx-89924fad709a1adb" animate-in="" animate-in-delay="0.3s" style="display:block; text-align : right" animate-in-duration="0.6s">@slide.Slidertitle</h3>
                        }

                        @if (isEnglishDesc)
                        {
                            <h4 animate-in="" animate-in-delay="0.3s" animate-in-duration="0.6s" class="jsx-89924fad709a1adb">@slide.SliderDesc</h4>
                        }
                        else
                        {
                            <h4 class="urdu jsx-89924fad709a1adb" animate-in="" animate-in-delay="0.3s" style="display:block; text-align : right" animate-in-duration="0.6s">@slide.SliderDesc</h4>
                        }

                        <div animate-in="" animate-in-delay="0.3s" animate-in-duration="0.6s"
                             class="jsx-89924fad709a1adb text-right">
                            <amp-img src="~/css/assets/images/slide-logo.png"
                                     width="82" height="32" alt="IKD Logo"
                                     class="jsx-89924fad709a1adb i-amphtml-layout-fixed i-amphtml-layout-size-defined"
                                     style="width:82px;height:32px;" i-amphtml-layout="fixed">
                            </amp-img>
                        </div>
                    </div>
                </amp-story-grid-layer>

                <amp-story-grid-layer template="vertical" class="jsx-89924fad709a1adb bottom noedge i-amphtml-layout-container" i-amphtml-layout="container">
                    <amp-img src="~/css/assets/images/inner_background_patter_002.png"
                             width="720" height="251"
                             layout="responsive"
                             animate-in="fade-in" animate-in-delay="0.5s" animate-in-duration="1s"
                             class="jsx-89924fad709a1adb pattern i-amphtml-layout-responsive i-amphtml-layout-size-defined"
                             i-amphtml-layout="responsive">
                    </amp-img>
                </amp-story-grid-layer>
            </amp-story-page>
        }

        <!-- Next Slider CTA (if exists) -->
        @{
            var nextslider = Model.Sliders
            .Where(w => w.ID < Model.Slides.First().SliderId)
            .FirstOrDefault();
        }
        @if (nextslider != null)
        {
            <amp-story-page id="next-slider" auto-advance-after="5s" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
                <amp-story-grid-layer template="fill" class="jsx-89924fad709a1adb i-amphtml-layout-container" i-amphtml-layout="container">
                    <amp-img src="https://invent.ilmkidunya.com/nadmin/Sliders/@nextslider.Image"
                             width="720" height="1280"
                             alt="@nextslider.Slidertitle"
                             layout="responsive"
                             class="jsx-89924fad709a1adb i-amphtml-layout-responsive i-amphtml-layout-size-defined"
                             i-amphtml-layout="responsive">
                    </amp-img>
                </amp-story-grid-layer>

                <amp-story-grid-layer template="vertical" class="jsx-89924fad709a1adb top overlay-start-deep i-amphtml-layout-container" i-amphtml-layout="container">
                    <div class="jsx-89924fad709a1adb z-index-up text-center text-white">
                        @{
                            bool isEnglishTitle2 = IsEnglish(nextslider.Slidertitle);
                        }

                        @if (isEnglishTitle2)
                        {
                            <h3 class="jsx-89924fad709a1adb" animate-in="" animate-in-delay="0.3s">@nextslider.Slidertitle</h3>
                        }
                        else
                        {
                            <h3 class="jsx-89924fad709a1adb urdu" animate-in="" animate-in-delay="0.3s">@nextslider.Slidertitle</h3>
                        }
                    </div>
                </amp-story-grid-layer>

                <amp-story-cta-layer>
                    <div animate-in="" animate-in-delay="0.3s" class="jsx-89924fad709a1adb call-action text-center">
                        <a href="/stories/@(nextslider.Slidertitle.Replace(" ", "-").ToLower())"
                           target="_blank" rel="noreferrer">
                            Read More
                        </a>
                    </div>
                </amp-story-cta-layer>
            </amp-story-page>
        }

        <amp-story-bookend src="https://amp.dev/static/samples/json/bookend.json" layout="nodisplay"></amp-story-bookend>
    </amp-story>

    @functions {
        bool IsEnglish(string input)
        {
            foreach (char c in input)
            {
                if (char.GetUnicodeCategory(c) == System.Globalization.UnicodeCategory.LowercaseLetter ||
                char.GetUnicodeCategory(c) == System.Globalization.UnicodeCategory.UppercaseLetter)
                {
                    return true;
                }
            }
            return false;
        }
    }
</body>


</html>