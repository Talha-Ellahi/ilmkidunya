                                        foreach (var word in Model.words)
                                        {
                                            // Get existing meaning for this word if available
                                            var existingMeaning = existingMeanings != null && existingMeanings.ContainsKey(word.Word1.ToLower())
                                            ? existingMeanings[word.Word1.ToLower()]
