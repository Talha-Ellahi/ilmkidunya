<div id="main">



    @*     <div class="contact-sec level fee-box">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Explore Top @Model.lang1.Name to @Model.lang2.Name Words &amp; Their Meanings</h2>
                    <div class="responsive-table">
                        <table class="table loadmore-table">
                            <thead>
                                <tr>
                                    <th>Sr. #</th>
                                    <th>Word</th>
                                    <th id="meaning-heading">Meaning</th>
                                    <th>Definition</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.words != null && Model.words.Any())
                                {
                                    int srNo = 1;
                                    foreach (var word in Model.words)
                                    {
                                        <tr style="display:@(srNo <= 10 ? "table-row" : "none")" data-word="@word.Word1" data-srno="@srNo">
                                            <td>@srNo</td>
                                            <td><a href="/dictionary/@word.Word1.Replace(" ", "-")-meaning-in-@Model.lang2.Name" class="word-link">@word.Word1</a></td>
                                            @if (Model.lang1.Name != Model.lang2.Name)
                                            {
                                                <td id="meaning-@srNo" class="meaning-cell">
                                                    <!-- Meaning will be populated by JavaScript -->
                                                </td>
                                            }
                                            <td>@word.Definition</td>
                                        </tr>
                                        srNo++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="translator-btns">
                        <a href="javascript:void(0)" class="text-btn tbl-load-more" id="loadMoreBtn">Load More</a>
                    </div>

                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            const currentLanguage = '@Model.lang1?.Code';
                            const translatedLanguage = '@Model.lang2?.Code';
                            const loadMoreBtn = document.getElementById('loadMoreBtn');
                            let currentPage = 1;
                            const itemsPerPage = 10;
                            let isLoading = false;

                            // Check if languages are valid
                            if (!currentLanguage || !translatedLanguage) {
                                console.error('Language codes are not available');
                                return;
                            }

                            const languagesAreSame = currentLanguage === translatedLanguage;

                            // If languages are the same, hide the meaning column
                            if (languagesAreSame) {
                                console.log('Source and target languages are the same, hiding meaning column');
                                hideMeaningColumn();
                            } else {
                                // Initial translation for first page if languages are different
                                translateWords();
                            }

                            // Load More functionality (always works regardless of languages)
                            loadMoreBtn.addEventListener('click', function() {
                                if (isLoading) return;
                                loadMoreWords();
                            });

                            function loadMoreWords() {
                                isLoading = true;
                                loadMoreBtn.textContent = 'Loading...';
                                loadMoreBtn.style.opacity = '0.7';

                                currentPage++;

                                const lang1 = '@Model.lang1?.Name.ToLower()';
                                const lang2 = '@Model.lang2?.Name.ToLower()';

                                fetch(`/dictionary/${lang1}-to-${lang2}-dictionary/loadmore?page=${currentPage}`)
                                    .then(response => {
                                        if (!response.ok) {
                                            throw new Error('Network response was not ok');
                                        }
                                        return response.json();
                                    })
                                    .then(data => {
                                        if (data.words && data.words.length > 0) {
                                            appendWordsToTable(data.words,lang2);

                                            // Translate the newly loaded words only if languages are different
                                            if (!languagesAreSame) {
                                                translateNewWords(data.words);
                                            }

                                            // Hide button if no more words
                                            if (data.words.length < itemsPerPage) {
                                                loadMoreBtn.style.display = 'none';
                                            }
                                        } else {
                                            loadMoreBtn.style.display = 'none';
                                        }
                                    })
                                    .catch(error => {
                                        console.error('Error loading more words:', error);
                                        loadMoreBtn.textContent = 'Error - Click to retry';
                                    })
                                    .finally(() => {
                                        isLoading = false;
                                        loadMoreBtn.textContent = 'Load More';
                                        loadMoreBtn.style.opacity = '1';
                                    });
                            }

                            function appendWordsToTable(words,lang2) {
                                const tbody = document.querySelector('.loadmore-table tbody');
                                const currentRowCount = document.querySelectorAll('.loadmore-table tbody tr').length;

                                words.forEach((word, index) => {
                                    const srNo = currentRowCount + index + 1;
                                    const tr = document.createElement('tr');
                                    tr.setAttribute('data-word', word.word1);
                                    tr.setAttribute('data-srno', srNo);

                                    // Process definition (take first part before comma)
                                    let definition = word.definition || '';
                                    if (definition) {
                                        definition = definition.split(',')[0].trim();
                                    }

                                    // Only add meaning cell if languages are different
                                    if (!languagesAreSame) {
                                        tr.innerHTML = `
                                            <td>${srNo}</td>
                                            <td><a href="${word.Word1}-meaning-in-${lang2}" class="word-link">${word.word1}</a></td>
                                            <td id="meaning-${srNo}" class="meaning-cell"></td>
                                            <td>${definition}</td>
                                        `;
                                    } else {
                                        tr.innerHTML = `
                                            <td>${srNo}</td>
                                            <td><a href="${word.Word1}-meaning-in-${lang2}" class="word-link">${word.word1}</a></td>
                                            <td>${definition}</td>
                                        `;
                                    }

                                    tbody.appendChild(tr);
                                });
                            }

                            function translateWords() {
                                const wordRows = document.querySelectorAll('tbody tr[data-word]');

                                wordRows.forEach((row, index) => {
                                    const word = row.getAttribute('data-word');
                                    const meaningCell = row.querySelector('.meaning-cell');

                                    if (meaningCell && !meaningCell.textContent.trim()) {
                                        // Show loading indicator
                                        meaningCell.innerHTML = '<span class="loading">Loading...</span>';

                                        // Capitalize the word before sending to API
                                        const capitalizedWord = capitalizeWord(word);

                                        // Stagger requests to avoid rate limiting
                                        setTimeout(() => {
                                            fetchMeaning(capitalizedWord, currentLanguage, translatedLanguage, meaningCell);
                                        }, index * 150);
                                    }
                                });
                            }

                            function translateNewWords(words) {
                                // Wait a bit for DOM to be updated with new rows
                                setTimeout(() => {
                                    const allWordRows = document.querySelectorAll('tbody tr[data-word]');
                                    const newRows = Array.from(allWordRows).slice(-words.length);

                                    newRows.forEach((row, index) => {
                                        const word = row.getAttribute('data-word');
                                        const meaningCell = row.querySelector('.meaning-cell');

                                        if (meaningCell && !meaningCell.textContent.trim()) {
                                            // Show loading indicator
                                            meaningCell.innerHTML = '<span class="loading">Loading...</span>';

                                            // Capitalize the word before sending to API
                                            const capitalizedWord = capitalizeWord(word);

                                            // Stagger requests to avoid rate limiting
                                            setTimeout(() => {
                                                fetchMeaning(capitalizedWord, currentLanguage, translatedLanguage, meaningCell);
                                            }, index * 150);
                                        }
                                    });
                                }, 100);
                            }

                            function capitalizeWord(word) {
                                if (!word) return '';
                                return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
                            }

                            function fetchMeaning(word, sourceLang, targetLang, meaningCell) {
                                const translationUrl = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(word)}&langpair=${sourceLang}|${targetLang}`;

                                fetch(translationUrl)
                                    .then(response => {
                                        if (!response.ok) {
                                            throw new Error(`HTTP error! status: ${response.status}`);
                                        }
                                        return response.json();
                                    })
                                    .then(data => {
                                        if (data.responseStatus === 200 && data.responseData && data.responseData.translatedText) {
                                            meaningCell.textContent = data.responseData.translatedText;
                                        } else {
                                            meaningCell.textContent = 'N/A';
                                            console.warn('Translation failed for:', word, data.responseStatus);
                                        }
                                    })
                                    .catch(error => {
                                        console.error('Translation error for', word, ':', error);
                                        meaningCell.textContent = 'Error';

                                        // Retry once after 2 seconds
                                        setTimeout(() => {
                                            meaningCell.innerHTML = '<span class="loading">Retrying...</span>';
                                            fetchMeaning(word, sourceLang, targetLang, meaningCell);
                                        }, 2000);
                                    });
                            }

                            function hideMeaningColumn() {
                                // Hide the Meaning column header
                                const tableHeaders = document.querySelectorAll('.loadmore-table thead th');
                                tableHeaders.forEach((th, index) => {
                                    if (th.textContent.trim() === 'Meaning') {
                                        th.style.display = 'none';
                                    }
                                });

                                // Hide all meaning cells in existing rows
                                const meaningCells = document.querySelectorAll('.loadmore-table .meaning-cell');
                                meaningCells.forEach(cell => {
                                    cell.style.display = 'none';
                                });

                                // Also update existing rows to remove meaning cells
                                const existingRows = document.querySelectorAll('.loadmore-table tbody tr');
                                existingRows.forEach(row => {
                                    const meaningCell = row.querySelector('.meaning-cell');
                                    if (meaningCell) {
                                        meaningCell.remove();
                                    }
                                });
                            }
                        });
                    </script>

                    <style>
                        .loading {
                            color: #666;
                            font-style: italic;
                        }

                        .meaning-cell {
                            min-width: 150px;
                        }

                        #loadMoreBtn {
                            transition: opacity 0.3s ease;
                        }

                            #loadMoreBtn:disabled {
                                opacity: 0.5;
                                cursor: not-allowed;
                            }
                    </style>
                    <div class="col-lg-12">
                        @if (ViewBag.CmsData != null && ViewBag.CmsData.Desc2 != null)
                        {
                            @Html.Raw(ViewBag.CmsData.Desc2)
                        }
                    </div>
                </div>
            </div>
        </div>


